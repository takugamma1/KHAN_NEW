{% liquid
  assign s = section.settings
%}

<div
  id="KhanFooter-{{ section.id }}"
  class="khan-footer color-{{ s.color_scheme }}{% if s.text_grain %} khan-footer--grain{% endif %}"
  style="
    --ft-bg: {{ s.bg_color }};
    --ft-text: {{ s.text_color }};
    --ft-accent: {{ s.accent_color }};
    --ft-heading-size: {{ s.heading_size }}px;
    --ft-link-size: {{ s.link_size }}px;
    --ft-img-max: {{ s.image_max }}px;
    --ft-maxw: {{ s.max_width }}px;
    --ft-pt: {{ s.padding_top }}px;
    --ft-pb: {{ s.padding_bottom }}px;
    --ft-valign: {{ s.side_valign }};
    --ft-grain: url('{{ 'khan-grain.png' | asset_url }}');
  "
  data-khan-footer
>
  <div class="khan-footer__inner">
    <div class="khan-footer__grid">

      <div class="khan-footer__side khan-footer__side--left">
        {%- for block in section.blocks -%}
          {%- if block.settings.side == 'left' -%}
            {%- if block.settings.style == 'heading' -%}
              <p class="khan-footer__head" {{ block.shopify_attributes }}>{{ block.settings.text }}</p>
            {%- elsif block.settings.link != blank -%}
              <a class="khan-footer__link" href="{{ block.settings.link }}" {{ block.shopify_attributes }}>{{ block.settings.text }}</a>
            {%- else -%}
              <p class="khan-footer__text" {{ block.shopify_attributes }}>{{ block.settings.text }}</p>
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div class="khan-footer__center">
        {%- if s.image != blank -%}
          {%- if s.image_link != blank -%}<a href="{{ s.image_link }}" class="khan-footer__img-link">{%- endif -%}
            {{ s.image | image_url: width: 2000 | image_tag: class: 'khan-footer__img', loading: 'lazy', sizes: '(min-width: 990px) 48vw, 88vw', widths: '400, 600, 800, 1200, 1600, 2000', alt: s.image.alt }}
          {%- if s.image_link != blank -%}</a>{%- endif -%}
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'khan-footer__img khan-footer__img--ph' }}
        {%- endif -%}
      </div>

      <div class="khan-footer__side khan-footer__side--right">
        {%- for block in section.blocks -%}
          {%- if block.settings.side == 'right' -%}
            {%- if block.settings.style == 'heading' -%}
              <p class="khan-footer__head" {{ block.shopify_attributes }}>{{ block.settings.text }}</p>
            {%- elsif block.settings.link != blank -%}
              <a class="khan-footer__link" href="{{ block.settings.link }}" {{ block.shopify_attributes }}>{{ block.settings.text }}</a>
            {%- else -%}
              <p class="khan-footer__text" {{ block.shopify_attributes }}>{{ block.settings.text }}</p>
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      </div>

    </div>
  </div>
</div>

{% stylesheet %}
  .khan-footer {
    position: relative;
    background: var(--ft-bg, #f4f1ea);
    padding-block: var(--ft-pt, 80px) var(--ft-pb, 80px);
    padding-inline: clamp(20px, 4vw, 56px);
    overflow: hidden;
  }
  .khan-footer__inner { max-width: min(var(--ft-maxw, 1600px), 100%); margin-inline: auto; }

  .khan-footer__grid {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.7fr) minmax(0, 0.85fr);
    gap: clamp(24px, 4vw, 64px);
    align-items: var(--ft-valign, center);
  }

  /* ---- sides (blend with background; nothing in the middle) ---- */
  .khan-footer__side {
    display: flex;
    flex-direction: column;
    gap: 12px;
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
  }
  .khan-footer__side--left { text-align: left; align-items: flex-start; }
  .khan-footer__side--right { text-align: right; align-items: flex-end; }

  .khan-footer__head {
    margin: 0 0 4px;
    font-family: 'Nexa', var(--font-heading--family, sans-serif);
    font-weight: 900;
    font-size: var(--ft-heading-size, 16px);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ft-accent, #bf1616);
  }
  .khan-footer__link,
  .khan-footer__text {
    font-size: var(--ft-link-size, 14px);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ft-text, #1a1a1a);
    text-decoration: none;
    line-height: 1.4;
  }
  .khan-footer__link { transition: color 0.18s ease; }
  .khan-footer__link:hover { color: var(--ft-accent, #bf1616); }

  /* ---- center image (the only thing in the middle) ---- */
  .khan-footer__center { display: flex; align-items: center; justify-content: center; }
  .khan-footer__img-link { display: block; width: 100%; }
  .khan-footer__img {
    display: block;
    width: 100%;
    max-width: var(--ft-img-max, 760px);
    height: auto;
    margin-inline: auto;
  }
  .khan-footer__img--ph { aspect-ratio: 4 / 5; object-fit: cover; }

  /* ---- grain on text only ---- */
  .khan-footer--grain :is(.khan-footer__head, .khan-footer__link, .khan-footer__text) {
    -webkit-mask-image: var(--ft-grain); mask-image: var(--ft-grain);
    -webkit-mask-size: 170px 170px; mask-size: 170px 170px;
  }

  /* ---- responsive ---- */
  @media screen and (max-width: 749px) {
    .khan-footer__grid { grid-template-columns: 1fr; gap: 32px; text-align: center; }
    .khan-footer__center { order: -1; }
    .khan-footer__side--left, .khan-footer__side--right { align-items: center; text-align: center; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Photo footer",
  "tag": "section",
  "class": "khan-footer-wrapper section-wrapper",
  "disabled_on": { "groups": ["header"] },
  "settings": [
    { "type": "header", "content": "Center image" },
    { "type": "paragraph", "content": "The only element in the middle. Everything else sits on the sides and shares the section background." },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "url", "id": "image_link", "label": "Image link" },
    { "type": "range", "id": "image_max", "label": "Image max width", "min": 300, "max": 1200, "step": 20, "unit": "px", "default": 760 },

    { "type": "header", "content": "Side content" },
    { "type": "paragraph", "content": "Add Item blocks and set each to the Left or Right side (headings, links or plain text)." },
    {
      "type": "select",
      "id": "side_valign",
      "label": "Side vertical alignment",
      "options": [
        { "value": "flex-start", "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Bottom" }
      ],
      "default": "center"
    },
    { "type": "range", "id": "heading_size", "label": "Heading size", "min": 12, "max": 28, "step": 1, "unit": "px", "default": 16 },
    { "type": "range", "id": "link_size", "label": "Link / text size", "min": 11, "max": 22, "step": 1, "unit": "px", "default": 14 },

    { "type": "header", "content": "Style" },
    { "type": "checkbox", "id": "text_grain", "label": "Grain on text", "default": true },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#f4f1ea" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#1a1a1a" },
    { "type": "color", "id": "accent_color", "label": "Accent (red) color", "default": "#bf1616" },
    { "type": "range", "id": "max_width", "label": "Max width", "min": 1100, "max": 1900, "step": 20, "unit": "px", "default": 1600 },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 80 },

    { "type": "header", "content": "Appearance" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        {
          "type": "select",
          "id": "side",
          "label": "Side",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "right", "label": "Right" }
          ],
          "default": "left"
        },
        {
          "type": "select",
          "id": "style",
          "label": "Type",
          "options": [
            { "value": "heading", "label": "Heading" },
            { "value": "link", "label": "Link" },
            { "value": "text", "label": "Plain text" }
          ],
          "default": "link"
        },
        { "type": "text", "id": "text", "label": "Text", "default": "Link" },
        { "type": "url", "id": "link", "label": "Link URL" }
      ]
    }
  ],
  "max_blocks": 16,
  "presets": [
    {
      "name": "Photo footer",
      "category": "t:categories.storytelling",
      "blocks": [
        { "type": "item", "settings": { "side": "left", "style": "heading", "text": "Shop" } },
        { "type": "item", "settings": { "side": "left", "style": "link", "text": "All products", "link": "shopify://collections/all" } },
        { "type": "item", "settings": { "side": "left", "style": "link", "text": "New arrivals" } },
        { "type": "item", "settings": { "side": "right", "style": "heading", "text": "Info" } },
        { "type": "item", "settings": { "side": "right", "style": "link", "text": "About" } },
        { "type": "item", "settings": { "side": "right", "style": "link", "text": "Contact" } }
      ]
    }
  ]
}
{% endschema %}
