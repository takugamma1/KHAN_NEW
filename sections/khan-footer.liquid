{% liquid
  assign s = section.settings
%}

{%- unless section.settings.hide_on_home and request.page_type == 'index' -%}
<div
  id="KhanFooter-{{ section.id }}"
  class="khan-footer color-{{ s.color_scheme }}{% if s.text_grain %} khan-footer--grain{% endif %}{% if s.image_only %} khan-footer--image-only{% endif %}{% if s.content_panel %} khan-footer--panel{% endif %}"
  style="
    --ft-bg: {{ s.bg_color }};
    --ft-text: {{ s.text_color }};
    --ft-accent: {{ s.accent_color }};
    --ft-muted: {{ s.muted_color }};
    --ft-overlay: {{ s.overlay_opacity | divided_by: 100.0 }};
    --ft-minh: {{ s.min_height }}px;
    --ft-logo-w: {{ s.logo_width }}px;
    --ft-logo3d-w: {{ s.logo3d_size | default: 150 }}px;
    --ft-head-size: {{ s.heading_size }}px;
    --ft-link-size: {{ s.link_size }}px;
    --ft-pt: {{ s.padding_top }}px;
    --ft-pb: {{ s.padding_bottom }}px;
    --ft-grain: url('{{ 'khan-grain.png' | asset_url }}');
    --ft-texture: {{ s.texture_opacity | default: 10 | divided_by: 100.0 }};
    --ft-strip-h: {{ s.top_height | default: 140 }}px;
    --ft-blend: {{ s.blend_color | default: '#f1f1ee' }};
    --ft-img-fit: {{ s.image_fit | default: 'cover' }};
    --ft-img-pos: {{ s.image_position | default: 'center' }};
    --ft-img-h: {{ s.image_height | default: 320 }}px;
    --ft-valign: {{ s.content_valign | default: 'flex-end' }};
    --ft-panel: {{ s.panel_opacity | default: 50 | divided_by: 100.0 }};
    --ft-panel-blur: {{ s.panel_blur | default: 0 }}px;
    --ft-panel-radius: {{ s.panel_radius | default: 0 }}px;
  "
  data-khan-footer
>
  {%- comment -%} Full-bleed background image {%- endcomment -%}
  <div class="khan-footer__bg" aria-hidden="true">
    {%- if s.bg_image != blank -%}
      {{ s.bg_image | image_url: width: 3000 | image_tag: class: 'khan-footer__bg-img', loading: 'lazy', widths: '800, 1200, 1600, 2000, 2600, 3000', sizes: '100vw', alt: '' }}
    {%- endif -%}
    {%- if s.texture -%}<span class="khan-footer__texture"></span>{%- endif -%}
    <span class="khan-footer__overlay"></span>
    {%- if s.blend_top -%}<span class="khan-footer__blend"></span>{%- endif -%}
  </div>

  {%- comment -%} Rocks strip at the very top (flippable transition into the section above) {%- endcomment -%}
  {%- if s.top_image != blank -%}
    <div class="khan-footer__strip{% if s.flip_top %} khan-footer__strip--flip{% endif %}" aria-hidden="true">
      {{ s.top_image | image_url: width: 2600 | image_tag: class: 'khan-footer__strip-img', loading: 'lazy', widths: '800, 1200, 1600, 2000, 2600', sizes: '100vw', alt: '' }}
    </div>
  {%- endif -%}

  {%- if s.show_deco -%}
    <span class="khan-footer__cross khan-footer__cross--1" aria-hidden="true"></span>
    <span class="khan-footer__cross khan-footer__cross--2" aria-hidden="true"></span>
    <span class="khan-footer__cross khan-footer__cross--3" aria-hidden="true"></span>
    {%- if s.coordinates != blank -%}<span class="khan-footer__coords" aria-hidden="true">{{ s.coordinates }}</span>{%- endif -%}
  {%- endif -%}

  <div class="khan-footer__inner">
    <div class="khan-footer__panel">
    <div class="khan-footer__layout">

      <div class="khan-footer__leftgroup">
        <div class="khan-footer__brand">
          {%- if s.logo != blank -%}
            <img class="khan-footer__logo" src="{{ s.logo | image_url: width: 700 }}" alt="{{ shop.name }}" width="{{ s.logo.width }}" height="{{ s.logo.height }}">
          {%- else -%}
            <span class="khan-footer__logo khan-footer__logo--svg">{{ 'white-logo.svg' | inline_asset_content }}</span>
          {%- endif -%}
          {%- if s.tagline != blank -%}<p class="khan-footer__tagline">{{ s.tagline }}</p>{%- endif -%}
          {%- comment -%} 3D GPU asterisk logo; replaces the static mark when enabled {%- endcomment -%}
          {%- if s.show_logo3d -%}
            <div class="khan-footer__logo3d" aria-hidden="true">{% render 'khan-gpu-asterisk' %}</div>
          {%- else -%}
            <img class="khan-footer__brand-mark" src="{{ 'asterisk.png' | asset_url }}" alt="" width="258" height="320" loading="lazy">
          {%- endif -%}
        </div>

        <div class="khan-footer__cols">
          {%- for block in section.blocks -%}
            {%- if block.type == 'menu' -%}
              <nav class="khan-footer__col" {{ block.shopify_attributes }}>
                {%- if block.settings.heading != blank -%}<p class="khan-footer__col-head">{{ block.settings.heading }}</p>{%- endif -%}
                {%- if block.settings.menu != blank -%}
                  <ul class="khan-footer__col-list">
                    {%- for link in block.settings.menu.links -%}
                      <li><a class="khan-footer__link" href="{{ link.url }}">{{ link.title }}</a></li>
                    {%- endfor -%}
                  </ul>
                {%- endif -%}
              </nav>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>

      {%- if s.show_newsletter -%}
        <div class="khan-footer__right">
          {%- if s.news_heading != blank -%}<p class="khan-footer__news-head">{{ s.news_heading }}</p>{%- endif -%}
          {%- if s.news_text != blank -%}<p class="khan-footer__news-text">{{ s.news_text }}</p>{%- endif -%}
          {%- form 'customer' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="khan-footer__news-form">
              <input class="khan-footer__news-input" type="email" name="contact[email]" placeholder="{{ s.news_placeholder | default: 'Your email' }}" required>
              <button class="khan-footer__news-btn" type="submit" aria-label="Subscribe">+</button>
            </div>
            {%- if form.posted_successfully? -%}<p class="khan-footer__news-ok">{{ s.news_success | default: "You're in." }}</p>{%- endif -%}
            {%- if form.errors -%}<p class="khan-footer__news-err">{{ form.errors.translated_fields.email }} {{ form.errors.messages.email }}</p>{%- endif -%}
          {%- endform -%}
        </div>
      {%- endif -%}

    </div>

    <div class="khan-footer__legal">
      {%- if s.copyright != blank -%}<span>{{ s.copyright }}</span>{%- endif -%}
      {%- if s.tagline2 != blank -%}<span class="khan-footer__legal-sub">{{ s.tagline2 }}</span>{%- endif -%}
    </div>
    </div>
  </div>
</div>
{%- endunless -%}

{% stylesheet %}
  .khan-footer {
    position: relative;
    background: var(--ft-bg, #0a0a0a);
    min-height: var(--ft-minh, 560px);
    padding-block: var(--ft-pt, 64px) var(--ft-pb, 40px);
    padding-inline: clamp(20px, 4vw, 64px);
    overflow: hidden;
    isolation: isolate;
  }

  .khan-footer__bg { position: absolute; inset: 0; z-index: 0; }
  .khan-footer__bg-img { width: 100%; height: 100%; object-fit: var(--ft-img-fit, cover); object-position: center var(--ft-img-pos, center); display: block; }

  /* image-only mode: just the background image, exact height, nothing else */
  .khan-footer--image-only { min-height: var(--ft-img-h, 320px); padding: 0; }
  .khan-footer--image-only :is(.khan-footer__overlay, .khan-footer__texture, .khan-footer__blend, .khan-footer__strip, .khan-footer__inner, .khan-footer__cross, .khan-footer__coords) { display: none !important; }
  .khan-footer__overlay {
    position: absolute; inset: 0;
    background: rgb(0 0 0 / var(--ft-overlay, 0.55));
  }

  /* stone texture over the background */
  .khan-footer__texture {
    position: absolute; inset: 0;
    background-image: var(--ft-grain);
    background-repeat: repeat;
    background-size: 280px 280px;
    opacity: var(--ft-texture, 0.1);
    mix-blend-mode: screen;
  }

  /* gradient blend into the section above */
  .khan-footer__blend {
    position: absolute; left: 0; right: 0; top: 0; height: 180px;
    background: linear-gradient(to bottom, var(--ft-blend, #f1f1ee) 0%, rgb(0 0 0 / 0) 100%);
  }

  /* rocks strip at the very top */
  .khan-footer__strip {
    position: absolute; left: 0; right: 0; top: 0; z-index: 1;
    height: var(--ft-strip-h, 140px);
    pointer-events: none;
  }
  .khan-footer__strip-img { width: 100%; height: 100%; object-fit: cover; object-position: center; display: block; }
  .khan-footer__strip--flip .khan-footer__strip-img { transform: scaleY(-1); }

  .khan-footer__inner { position: relative; z-index: 2; max-width: 1920px; margin-inline: auto; min-height: calc(var(--ft-minh, 560px) - var(--ft-pt, 64px) - var(--ft-pb, 40px)); display: flex; flex-direction: column; justify-content: var(--ft-valign, flex-end); }

  /* content band — holds layout + legal; positioned within the section by --ft-valign */
  .khan-footer__panel { display: flex; flex-direction: column; gap: clamp(28px, 4vw, 56px); }
  .khan-footer--panel .khan-footer__panel {
    background: rgb(0 0 0 / var(--ft-panel, 0.55));
    padding: clamp(26px, 3.5vw, 48px) clamp(22px, 3.5vw, 52px);
    border-radius: var(--ft-panel-radius, 0px);
    border: 1px solid rgb(255 255 255 / 0.08);
    box-shadow: 0 24px 70px rgb(0 0 0 / 0.45);
    -webkit-backdrop-filter: blur(var(--ft-panel-blur, 0px));
            backdrop-filter: blur(var(--ft-panel-blur, 0px));
  }

  /* legibility over the image without a visible gradient/vignette */
  .khan-footer__inner :is(.khan-footer__tagline, .khan-footer__col-head, .khan-footer__link, .khan-footer__news-head, .khan-footer__news-text, .khan-footer__legal) { text-shadow: 0 1px 6px rgb(0 0 0 / 0.45); }
  .khan-footer__logo { filter: drop-shadow(0 2px 8px rgb(0 0 0 / 0.4)); }

  .khan-footer__layout {
    flex: 0 0 auto;
    display: flex;
    justify-content: space-between;
    gap: clamp(40px, 6vw, 120px);
  }

  .khan-footer__leftgroup { display: flex; gap: clamp(32px, 4vw, 80px); }

  /* ---- brand ---- */
  .khan-footer__brand { display: flex; flex-direction: column; align-items: flex-start; gap: 16px; }
  .khan-footer__logo { width: var(--ft-logo-w, 200px); height: auto; display: block; }
  .khan-footer__logo--svg svg { width: var(--ft-logo-w, 200px); height: auto; display: block; }
  .khan-footer__logo--svg svg path { fill: #fff; }
  .khan-footer__tagline {
    margin: 0; max-width: 16ch;
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: 15px; line-height: 1.4; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ft-text, #f2f2f2);
  }
  .khan-footer__brand-mark { width: 20px; height: 20px; object-fit: contain; margin-top: 4px; }

  /* 3D GPU asterisk logo (below the tagline) */
  .khan-footer__logo3d { width: var(--ft-logo3d-w, 150px); max-width: 100%; margin-top: 8px; }
  .khan-footer__logo3d .mg-asterisk { margin: 0; max-width: none; }

  /* ---- link columns ---- */
  .khan-footer__cols { display: flex; gap: clamp(28px, 3vw, 64px); }
  .khan-footer__col-head {
    margin: 0 0 16px;
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: var(--ft-head-size, 14px); letter-spacing: 0.18em; text-transform: uppercase; color: var(--ft-accent, #d8232a);
  }
  .khan-footer__col-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 12px; }
  .khan-footer__link {
    display: inline-block;
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: var(--ft-link-size, 14px); letter-spacing: 0.12em; text-transform: uppercase; color: var(--ft-text, #f2f2f2);
    text-decoration: none; transition: color 0.18s ease, transform 0.18s ease;
  }
  .khan-footer__link:hover { color: var(--ft-accent, #d8232a); transform: translateX(6px); }

  /* ---- newsletter ---- */
  .khan-footer__right { max-width: 360px; flex: 0 0 auto; }
  .khan-footer__news-head { margin: 0 0 12px; font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace; font-size: var(--ft-head-size, 14px); letter-spacing: 0.14em; text-transform: uppercase; color: var(--ft-accent, #d8232a); }
  .khan-footer__news-text { margin: 0 0 20px; font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace; font-size: 13px; line-height: 1.6; letter-spacing: 0.06em; text-transform: uppercase; color: var(--ft-muted, #c9c9c9); }
  .khan-footer__news-form { display: flex; align-items: stretch; border: 1px solid rgb(255 255 255 / 0.4); }
  .khan-footer__news-input { flex: 1 1 auto; min-width: 0; background: transparent; border: 0; padding: 14px 16px; color: #fff; font-family: ui-monospace, monospace; font-size: 13px; letter-spacing: 0.14em; text-transform: uppercase; }
  .khan-footer__news-input::placeholder { color: rgb(255 255 255 / 0.5); }
  .khan-footer__news-input:focus { outline: none; }
  .khan-footer__news-btn { flex: 0 0 auto; width: 52px; background: transparent; border: 0; border-left: 1px solid rgb(255 255 255 / 0.4); color: var(--ft-accent, #d8232a); font-size: 22px; cursor: pointer; transition: background 0.18s ease; }
  .khan-footer__news-btn:hover { background: rgb(255 255 255 / 0.08); }
  .khan-footer__news-ok { margin: 12px 0 0; color: #9fe6a0; font-family: monospace; font-size: 12px; }
  .khan-footer__news-err { margin: 12px 0 0; color: #ff7a7a; font-family: monospace; font-size: 12px; }

  /* ---- legal ---- */
  .khan-footer__legal { display: flex; gap: 40px; margin-top: 0; font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace; font-size: 12px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ft-muted, #9a9a9a); }
  .khan-footer__legal-sub { padding-left: 40px; border-left: 1px solid rgb(255 255 255 / 0.22); }

  /* ---- decorations ---- */
  .khan-footer__cross { position: absolute; z-index: 1; width: 18px; height: 18px; pointer-events: none; }
  .khan-footer__cross::before, .khan-footer__cross::after { content: ""; position: absolute; background: var(--ft-accent, #d8232a); opacity: 0.7; }
  .khan-footer__cross::before { left: 50%; top: 0; bottom: 0; width: 1px; transform: translateX(-50%); }
  .khan-footer__cross::after { top: 50%; left: 0; right: 0; height: 1px; transform: translateY(-50%); }
  .khan-footer__cross--1 { top: 40px; left: 38%; }
  .khan-footer__cross--2 { bottom: 60px; left: 30%; }
  .khan-footer__cross--3 { top: 30%; right: 12%; }
  .khan-footer__coords { position: absolute; z-index: 1; right: 14px; top: 50%; transform: translateY(-50%) rotate(90deg); transform-origin: right center; font-family: ui-monospace, monospace; font-size: 11px; letter-spacing: 0.2em; color: var(--ft-muted, #8a8a8a); white-space: nowrap; }

  /* ---- grain on text/marks ---- */
  .khan-footer--grain :is(.khan-footer__tagline, .khan-footer__col-head, .khan-footer__link, .khan-footer__news-head, .khan-footer__news-text, .khan-footer__legal, .khan-footer__brand-mark, .khan-footer__logo) {
    -webkit-mask-image: var(--ft-grain); mask-image: var(--ft-grain);
    -webkit-mask-size: 170px 170px; mask-size: 170px 170px;
  }

  /* ---- responsive ---- */
  @media screen and (max-width: 1100px) {
    .khan-footer__layout { flex-direction: column; gap: 44px; }
    .khan-footer__right { max-width: 420px; }
    .khan-footer__coords { display: none; }
  }
  @media screen and (max-width: 749px) {
    .khan-footer__leftgroup { flex-direction: column; gap: 36px; }
    .khan-footer__cols { flex-wrap: wrap; gap: 32px; }
    .khan-footer__legal { flex-direction: column; gap: 8px; }
    .khan-footer__legal-sub { padding-left: 0; border-left: 0; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Photo footer",
  "tag": "section",
  "class": "khan-footer-wrapper section-wrapper",
  "disabled_on": { "groups": ["header"] },
  "settings": [
    { "type": "header", "content": "Visibility" },
    { "type": "checkbox", "id": "hide_on_home", "label": "Hide on the home page", "default": false },
    { "type": "header", "content": "Background image (full-bleed)" },
    { "type": "image_picker", "id": "bg_image", "label": "Background image" },
    { "type": "checkbox", "id": "image_only", "label": "Image only (hide all content & overlays)", "default": false },
    { "type": "range", "id": "image_height", "label": "Image height (image-only mode)", "min": 80, "max": 900, "step": 10, "unit": "px", "default": 320 },
    {
      "type": "select", "id": "image_fit", "label": "Image fit",
      "options": [
        { "value": "cover", "label": "Cover (fill, may crop)" },
        { "value": "contain", "label": "Contain (no crop)" },
        { "value": "fill", "label": "Stretch to edges" }
      ],
      "default": "cover"
    },
    {
      "type": "select", "id": "image_position", "label": "Image anchor",
      "options": [
        { "value": "top", "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "bottom", "label": "Bottom" }
      ],
      "default": "center"
    },
    { "type": "range", "id": "overlay_opacity", "label": "Dark overlay", "min": 0, "max": 90, "step": 5, "unit": "%", "default": 55 },
    { "type": "checkbox", "id": "texture", "label": "Stone texture overlay", "default": true },
    { "type": "range", "id": "texture_opacity", "label": "Texture strength", "min": 0, "max": 40, "step": 2, "unit": "%", "default": 10 },

    { "type": "header", "content": "Rocks strip (top edge)" },
    { "type": "image_picker", "id": "top_image", "label": "Rocks image" },
    { "type": "checkbox", "id": "flip_top", "label": "Flip upside down", "default": true },
    { "type": "range", "id": "top_height", "label": "Strip height", "min": 60, "max": 300, "step": 4, "unit": "px", "default": 140 },
    { "type": "checkbox", "id": "blend_top", "label": "Blend into section above (gradient)", "default": false },
    { "type": "color", "id": "blend_color", "label": "Blend color (page background)", "default": "#f1f1ee" },
    { "type": "range", "id": "min_height", "label": "Footer height", "min": 360, "max": 900, "step": 20, "unit": "px", "default": 560 },

    { "type": "header", "content": "Logo & tagline (left)" },
    { "type": "image_picker", "id": "logo", "label": "Logo (upload)" },
    { "type": "range", "id": "logo_width", "label": "Logo width", "min": 80, "max": 400, "step": 4, "unit": "px", "default": 200 },
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "Изграден различно. Създаден да трае." },
    { "type": "checkbox", "id": "show_logo3d", "label": "3D animated asterisk (below tagline)", "default": true },
    { "type": "range", "id": "logo3d_size", "label": "3D asterisk size", "min": 60, "max": 320, "step": 4, "unit": "px", "default": 150 },

    { "type": "header", "content": "Newsletter (right)" },
    { "type": "checkbox", "id": "show_newsletter", "label": "Show newsletter", "default": true },
    { "type": "text", "id": "news_heading", "label": "Heading", "default": "Влез в обществото на KHAN" },
    { "type": "text", "id": "news_text", "label": "Text", "default": "Ексклузивни дропове. Ранен достъп. Без шум. Само KHAN." },
    { "type": "text", "id": "news_placeholder", "label": "Input placeholder", "default": "Твоят имейл" },
    { "type": "text", "id": "news_success", "label": "Success message", "default": "Вътре си." },

    { "type": "header", "content": "Legal (bottom-left)" },
    { "type": "text", "id": "copyright", "label": "Copyright", "default": "© 2026 Khan Apparel. Всички права запазени." },
    { "type": "text", "id": "tagline2", "label": "Sub line", "default": "Родено от миналото. Създадено за сега." },

    { "type": "header", "content": "Decoration" },
    { "type": "checkbox", "id": "show_deco", "label": "Show crosshairs & coordinates", "default": true },
    { "type": "text", "id": "coordinates", "label": "Coordinates", "default": "42.6977° N  23.3219° E" },

    { "type": "header", "content": "Style" },
    {
      "type": "select", "id": "content_valign", "label": "Content vertical position",
      "options": [
        { "value": "flex-start", "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Bottom" },
        { "value": "space-between", "label": "Spread (top & bottom)" }
      ],
      "default": "flex-end",
      "info": "Keep content over the dark part of the image so text stays visible."
    },
    { "type": "checkbox", "id": "content_panel", "label": "Dark panel behind content (for legibility)", "default": true },
    { "type": "range", "id": "panel_opacity", "label": "Panel darkness", "min": 0, "max": 90, "step": 5, "unit": "%", "default": 55 },
    { "type": "range", "id": "panel_blur", "label": "Panel glass blur", "min": 0, "max": 30, "step": 2, "unit": "px", "default": 8 },
    { "type": "range", "id": "panel_radius", "label": "Panel corner radius", "min": 0, "max": 60, "step": 2, "unit": "px", "default": 22 },
    { "type": "checkbox", "id": "text_grain", "label": "Grain on text", "default": true },
    { "type": "color", "id": "bg_color", "label": "Background fallback", "default": "#1b1b1b" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#f2f2f2" },
    { "type": "color", "id": "muted_color", "label": "Muted text color", "default": "#9a9a9a" },
    { "type": "color", "id": "accent_color", "label": "Accent (red) color", "default": "#d8232a" },
    { "type": "range", "id": "heading_size", "label": "Column heading size", "min": 11, "max": 22, "step": 1, "unit": "px", "default": 14 },
    { "type": "range", "id": "link_size", "label": "Link size", "min": 11, "max": 22, "step": 1, "unit": "px", "default": 14 },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 64 },
