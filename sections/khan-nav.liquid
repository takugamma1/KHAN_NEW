{% liquid
  assign s = section.settings
%}

<div
  id="KhanNav-{{ section.id }}"
  class="khan-nav-outer{% if s.sticky %} khan-nav-outer--sticky{% endif %}{% if s.full_width %} khan-nav-outer--full{% endif %}"
  data-khan-nav
  style="
    --nav-glass: {{ s.glass_tint }};
    --nav-bubble: {{ s.bubble_tint }};
    --nav-border: {{ s.border_color }};
    --nav-text: {{ s.text_color }};
    --nav-accent: {{ s.accent_color }};
    --nav-blur: {{ s.blur }}px;
    --nav-h: {{ s.pill_height }}px;
    --nav-logo: {{ s.logo_size }}px;
    --nav-logo-w: {{ s.logo_width | default: 120 }}px;
    --nav-maxw: {{ s.max_width }}px;
    --nav-top: {{ s.top_offset }}px;
    --nav-text-size: {{ s.text_size }}px;
    --nav-gap: {{ s.menu_gap }}px;
    --nav-pad: {{ s.side_padding }}px;
  "
>
  <div class="khan-nav-inner">
    <nav class="khan-nav__bar" aria-label="{{ s.menu.title | default: 'Primary' | escape }}">

      {%- comment -%} Logo (left) — plain or bubble {%- endcomment -%}
      <a class="khan-nav__logo{% if s.logo_style == 'plain' %} khan-nav__logo--plain{% endif %}" href="{{ routes.root_url }}" aria-label="{{ shop.name | escape }}">
        {%- if s.logo != blank -%}
          <img class="khan-nav__logo-img" src="{{ s.logo | image_url: width: 480 }}" alt="{{ shop.name | escape }}" width="{{ s.logo.width }}" height="{{ s.logo.height }}">
        {%- else -%}
          <svg class="khan-nav__star" viewBox="0 0 100 100" aria-hidden="true" focusable="false">
            <g stroke="currentColor" stroke-width="7" stroke-linecap="round">
              <line x1="50" y1="9" x2="50" y2="91"></line>
              <line x1="9" y1="50" x2="91" y2="50"></line>
              <line x1="21" y1="21" x2="79" y2="79"></line>
              <line x1="79" y1="21" x2="21" y2="79"></line>
            </g>
          </svg>
        {%- endif -%}
      </a>

      {%- comment -%} Inline menu (desktop only) {%- endcomment -%}
      {%- if s.menu != blank -%}
        <ul class="khan-nav__menu">
          {%- for link in s.menu.links -%}
            <li class="khan-nav__item">
              <a class="khan-nav__link{% if link.active or link.child_active %} is-current{% endif %}" href="{{ link.url }}"{% if link.active %} aria-current="page"{% endif %}>{{ link.title }}</a>
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- comment -%} Right actions: cart (+ burger on mobile) {%- endcomment -%}
      <div class="khan-nav__actions">
        {%- if s.show_account -%}
          <a class="khan-nav__acct" href="{{ routes.account_url }}" aria-label="Account">
            <svg class="khan-nav__acct-ic" viewBox="0 0 32 32" aria-hidden="true" focusable="false">
              <path d="M10.6666 4H21.3333L23.3333 9.33333V13.3333L21.3333 16H10.6666L8.66663 13.3333V9.33333L10.6666 4Z" fill="currentColor"></path>
              <path d="M4.66663 29.3334H27.3333L25.3333 21.3334L22.6666 18.6667H9.33329L6.66663 21.3334L4.66663 29.3334Z" fill="currentColor"></path>
            </svg>
          </a>
        {%- endif -%}

        {%- if s.show_cart -%}
          <a class="khan-nav__cart" href="{{ routes.cart_url }}" aria-label="Cart ({{ cart.item_count }})">
            <svg class="khan-nav__cart-ic" viewBox="0 0 32 32" aria-hidden="true" focusable="false">
              <path d="M7.33329 12H24.6666L27.3333 28H4.66663L7.33329 12Z" fill="currentColor" stroke="currentColor" stroke-width="2"></path>
              <path d="M10 12C10 8 12 6 16 6C20 6 22 8 22 12" fill="none" stroke="currentColor" stroke-width="2.93333"></path>
              <path d="M12 9.33341L14.6667 6.66675M20 9.33341L17.3333 6.66675" fill="none" stroke="currentColor" stroke-width="1.86667"></path>
              <path d="M13.3334 17.3333H18.6667V22.6666H13.3334V17.3333Z" fill="currentColor"></path>
            </svg>
            <span class="khan-nav__cart-count" data-khan-cart-count{% if cart.item_count == 0 %} hidden{% endif %}>{{ cart.item_count }}</span>
          </a>
        {%- endif -%}

        <button
          class="khan-nav__burger"
          type="button"
          data-khan-nav-toggle
          aria-expanded="false"
          aria-controls="KhanNavPanel-{{ section.id }}"
          aria-label="Menu"
        >
          <svg class="khan-nav__burger-ic khan-nav__burger-ic--menu" viewBox="0 0 32 32" fill="none" aria-hidden="true">
            <path fill="currentColor" d="M28 6H4v4.533h24z"></path>
            <path fill="currentColor" d="M17.333 14H4v2.667h13.333z"></path>
            <path fill="currentColor" d="M24 21.333H4v4.533h20z"></path>
          </svg>
          <svg class="khan-nav__burger-ic khan-nav__burger-ic--close" viewBox="0 0 32 32" fill="none" aria-hidden="true">
            <path stroke="currentColor" stroke-width="4.5" d="M6.667 6.667l18.666 18.666"></path>
            <path stroke="currentColor" stroke-width="2.1" d="M25.333 6.667L6.667 25.333"></path>
          </svg>
        </button>
      </div>
    </nav>

    {%- comment -%} Mobile panel {%- endcomment -%}
    <div class="khan-nav__panel" id="KhanNavPanel-{{ section.id }}" data-khan-nav-panel aria-hidden="true">
      {%- if s.menu != blank -%}
        <ul class="khan-nav__panel-list">
          {%- for link in s.menu.links -%}
            <li>
              <a class="khan-nav__panel-link{% if link.active %} is-current{% endif %}" href="{{ link.url }}"{% if link.active %} aria-current="page"{% endif %}>{{ link.title }}</a>
              {%- if link.links != blank -%}
                <ul class="khan-nav__panel-sub">
                  {%- for child in link.links -%}
                    <li><a class="khan-nav__panel-sublink" href="{{ child.url }}">{{ child.title }}</a></li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
  /* neutralize any background/padding the theme applies to the section wrapper */
  .khan-nav-wrapper { background: transparent !important; padding: 0 !important; margin: 0 !important; }

  /* overlay the content below so the glass picks up the (dark) hero behind it */
  .khan-nav-outer {
    position: absolute;
    top: 0; left: 0; right: 0;
    z-index: 60;
    width: 100%;
    padding: var(--nav-top, 16px) clamp(14px, 4vw, 40px) 0;
    pointer-events: none;
  }
  .khan-nav-outer--sticky { position: fixed; }

  .khan-nav-inner { max-width: var(--nav-maxw, 1280px); margin-inline: auto; }

  /* full-width: stretch the pill almost edge to edge */
  .khan-nav-outer--full { padding-inline: clamp(10px, 1.6vw, 28px); }
  .khan-nav-outer--full .khan-nav-inner { max-width: none; }

  /* ---- the glass pill ---- */
  .khan-nav__bar {
    pointer-events: auto;
    position: relative;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: clamp(12px, 3vw, 28px);
    height: var(--nav-h, 64px);
    padding: 0 var(--nav-pad, 12px);
    border-radius: 999px;
    color: var(--nav-text, #f3f3f3);
    background: var(--nav-glass, rgb(21 21 21 / 0.5));
    border: 1px solid var(--nav-border, rgb(255 255 255 / 0.14));
    -webkit-backdrop-filter: blur(var(--nav-blur, 18px)) saturate(1.4);
            backdrop-filter: blur(var(--nav-blur, 18px)) saturate(1.4);
    box-shadow:
      0 18px 50px rgb(0 0 0 / 0.45),
      inset 0 1px 0 rgb(255 255 255 / 0.14),
      inset 0 -1px 0 rgb(0 0 0 / 0.4);
  }

  /* ---- circular bubbles (logo + burger) ---- */
  .khan-nav__logo,
  .khan-nav__acct,
  .khan-nav__cart,
  .khan-nav__burger {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: calc(var(--nav-h, 64px) - 16px);
    height: calc(var(--nav-h, 64px) - 16px);
    border-radius: 50%;
    background: var(--nav-bubble, rgb(255 255 255 / 0.08));
    border: 1px solid var(--nav-border, rgb(255 255 255 / 0.14));
    box-shadow: inset 0 1px 0 rgb(255 255 255 / 0.18), inset 0 -2px 6px rgb(0 0 0 / 0.5);
    transition: background 0.2s ease, transform 0.2s ease;
  }
  .khan-nav__logo { color: var(--nav-text, #f3f3f3); text-decoration: none; justify-self: start; grid-column: 1; }
  .khan-nav__logo:hover { background: rgb(255 255 255 / 0.14); }
  .khan-nav__star { width: var(--nav-logo, 26px); height: var(--nav-logo, 26px); display: block; }
  .khan-nav__logo-img { width: var(--nav-logo, 26px); height: auto; display: block; object-fit: contain; }

  /* plain logo: no circle, bigger mark */
  .khan-nav__logo--plain {
    width: auto; height: auto;
    background: transparent; border: 0; box-shadow: none; border-radius: 0;
    padding: 0 6px;
  }
  .khan-nav__logo--plain:hover { background: transparent; opacity: 0.85; }
  .khan-nav__logo--plain .khan-nav__logo-img { width: var(--nav-logo-w, 120px); max-height: calc(var(--nav-h, 64px) - 20px); object-fit: contain; }
  .khan-nav__logo--plain .khan-nav__star { width: calc(var(--nav-logo, 26px) + 8px); height: calc(var(--nav-logo, 26px) + 8px); }

  /* ---- right actions + cart ---- */
  .khan-nav__actions { justify-self: end; grid-column: 3; display: inline-flex; align-items: center; gap: 10px; }
  .khan-nav__cart { position: relative; color: var(--nav-text, #f3f3f3); text-decoration: none; }
  .khan-nav__cart:hover { background: rgb(255 255 255 / 0.14); }
  .khan-nav__cart-ic { width: calc(var(--nav-logo, 26px) - 2px); height: auto; display: block; }
  .khan-nav__cart-count {
    position: absolute; top: -3px; right: -3px;
    min-width: 18px; height: 18px; padding: 0 5px; box-sizing: border-box;
    display: inline-flex; align-items: center; justify-content: center;
    background: var(--nav-accent, #560B1E); color: #fff;
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: 11px; font-weight: 700; line-height: 1;
    border-radius: 999px; border: 1.5px solid rgb(0 0 0 / 0.35);
  }
  .khan-nav__cart-count[hidden] { display: none; }
  .khan-nav__acct { color: var(--nav-text, #f3f3f3); text-decoration: none; }
  .khan-nav__acct:hover { background: rgb(255 255 255 / 0.14); }
  .khan-nav__acct-ic { width: calc(var(--nav-logo, 26px) - 2px); height: auto; display: block; }

  /* ---- menu (desktop) ---- */
  .khan-nav__menu {
    list-style: none; margin: 0; padding: 0;
    display: flex; align-items: center; gap: var(--nav-gap, 34px);
    justify-self: center; grid-column: 2;
  }
  .khan-nav__link {
    font-family: 'Nexa', var(--font-heading--family, sans-serif);
    font-weight: 900;
    font-size: var(--nav-text-size, 13px);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--nav-text, #f3f3f3);
    text-decoration: none;
    white-space: nowrap;
    opacity: 0.92;
    transition: color 0.18s ease, opacity 0.18s ease;
  }
  .khan-nav__link:hover,
  .khan-nav__link.is-current { color: var(--nav-accent, #560B1E); opacity: 1; }

  /* ---- burger (ic-menu icon, swaps to X when open) ---- */
  .khan-nav__burger { display: none; cursor: pointer; justify-self: end; color: var(--nav-accent, #560B1E); }
  .khan-nav__burger-ic { width: 20px; height: 20px; display: block; }
  .khan-nav__burger-ic--close { display: none; }
  .khan-nav-outer.is-open .khan-nav__burger-ic--menu { display: none; }
  .khan-nav-outer.is-open .khan-nav__burger-ic--close { display: block; }

  /* ---- mobile panel ---- */
  .khan-nav__panel {
    pointer-events: auto;
    margin-top: 10px;
    padding: 10px;
    border-radius: 26px;
    background: var(--nav-glass, rgb(21 21 21 / 0.6));
    border: 1px solid var(--nav-border, rgb(255 255 255 / 0.14));
    -webkit-backdrop-filter: blur(var(--nav-blur, 18px)) saturate(1.4);
            backdrop-filter: blur(var(--nav-blur, 18px)) saturate(1.4);
    box-shadow: 0 18px 50px rgb(0 0 0 / 0.5);
    visibility: hidden; opacity: 0; transform: translateY(-10px);
    transition: opacity 0.22s ease, transform 0.22s ease, visibility 0s linear 0.22s;
  }
  .khan-nav-outer.is-open .khan-nav__panel {
    visibility: visible; opacity: 1; transform: none;
    transition: opacity 0.22s ease, transform 0.22s ease, visibility 0s;
  }
  .khan-nav__panel-list, .khan-nav__panel-sub { list-style: none; margin: 0; padding: 0; }
  .khan-nav__panel-link {
    display: block; padding: 13px 16px; border-radius: 16px;
    font-family: 'Nexa', var(--font-heading--family, sans-serif); font-weight: 900;
    font-size: 15px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--nav-text, #f3f3f3); text-decoration: none;
  }
  .khan-nav__panel-link:hover, .khan-nav__panel-link.is-current { color: var(--nav-accent, #560B1E); background: rgb(255 255 255 / 0.05); }
  .khan-nav__panel-sub { padding: 0 0 6px 16px; }
  .khan-nav__panel-sublink {
    display: block; padding: 9px 16px;
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--nav-text, #f3f3f3); opacity: 0.7; text-decoration: none;
  }
  .khan-nav__panel-sublink:hover { opacity: 1; color: var(--nav-accent, #560B1E); }

  /* ---- responsive: burger under 990, inline menu above ---- */
  @media screen and (max-width: 989px) {
    .khan-nav__menu { display: none; }
    .khan-nav__burger { display: inline-flex; }
  }
  @media screen and (max-width: 749px) {
    .khan-nav__bar { height: 52px; padding: 0 8px; }
    .khan-nav__logo,
    .khan-nav__acct,
    .khan-nav__cart,
    .khan-nav__burger { width: 40px; height: 40px; }
    .khan-nav__star,
    .khan-nav__logo-img,
    .khan-nav__cart-ic,
    .khan-nav__acct-ic { width: 18px; }
    .khan-nav__actions { gap: 8px; }
    .khan-nav__cart-count { min-width: 16px; height: 16px; padding: 0 4px; font-size: 10px; }
    .khan-nav__burger-ic { width: 18px; height: 18px; }
    .khan-nav__logo--plain { width: auto; height: auto; }
    .khan-nav__logo--plain .khan-nav__logo-img { width: min(calc(var(--nav-logo-w, 120px) * 0.75), 96px); max-height: 36px; }
  }
  @media screen and (min-width: 990px) {
    .khan-nav__panel { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .khan-nav__panel, .khan-nav__logo { transition: none; }
  }
{% endstylesheet %}

<script>
  (function () {
    function init(root) {
      if (!root || root.__khanNavReady) return;
      var toggle = root.querySelector('[data-khan-nav-toggle]');
      var panel = root.querySelector('[data-khan-nav-panel]');
      if (!toggle || !panel) return;
      root.__khanNavReady = true;

      function setOpen(open) {
        root.classList.toggle('is-open', open);
        toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
        panel.setAttribute('aria-hidden', open ? 'false' : 'true');
      }
      function onToggle(e) { e.preventDefault(); setOpen(!root.classList.contains('is-open')); }
      function onKey(e) { if (e.key === 'Escape') setOpen(false); }
      function onDocClick(e) { if (root.classList.contains('is-open') && !root.contains(e.target)) setOpen(false); }
      function onPanelClick(e) { if (e.target.closest('a')) setOpen(false); }
      function onResize() { if (window.innerWidth >= 990) setOpen(false); }

      toggle.addEventListener('click', onToggle);
      document.addEventListener('keydown', onKey);
      document.addEventListener('click', onDocClick);
      panel.addEventListener('click', onPanelClick);
      window.addEventListener('resize', onResize);

      root.__khanNavCleanup = function () {
        toggle.removeEventListener('click', onToggle);
        document.removeEventListener('keydown', onKey);
        document.removeEventListener('click', onDocClick);
        panel.removeEventListener('click', onPanelClick);
        window.removeEventListener('resize', onResize);
        root.__khanNavReady = false;
        root.__khanNavCleanup = null;
      };
    }

    function initAll(scope) {
      var nodes = (scope || document).querySelectorAll('[data-khan-nav]');
      for (var i = 0; i < nodes.length; i++) init(nodes[i]);
    }

    if (document.readyState !== 'loading') initAll();
    else document.addEventListener('DOMContentLoaded', function () { initAll(); });

    // Section Rendering API lifecycle (customizer + AJAX section swaps)
    document.addEventListener('shopify:section:load', function (e) { initAll(e.target); });
    document.addEventListener('shopify:section:unload', function (e) {
      var root = e.target.querySelector('[data-khan-nav]');
      if (root && root.__khanNavCleanup) root.__khanNavCleanup();
    });
  })();

  // Cart count badge — read-only refresh, never touches the theme's cart code
  (function () {
    function setCount(n) {
      var els = document.querySelectorAll('[data-khan-cart-count]');
      for (var i = 0; i < els.length; i++) {
        els[i].textContent = n;
        if (n > 0) els[i].removeAttribute('hidden'); else els[i].setAttribute('hidden', '');
      }
    }
    function refresh() {
      if (!document.querySelector('[data-khan-cart-count]')) return;
      fetch('{{ routes.cart_url }}.js', { headers: { 'Accept': 'application/json' } })
        .then(function (r) { return r.ok ? r.json() : null; })
        .then(function (c) { if (c) setCount(c.item_count); })
        .catch(function () {});
    }
    window.addEventListener('pageshow', refresh);
    document.addEventListener('visibilitychange', function () { if (!document.hidden) refresh(); });
    ['cart:updated', 'cart:refresh', 'cart:change', 'khan:cart:refresh'].forEach(function (ev) {
      document.addEventListener(ev, refresh);
    });
  })();
</script>

{% schema %}
{
  "name": "Bubble nav (glass)",
  "tag": "section",
  "class": "khan-nav-wrapper",
  "settings": [
    { "type": "header", "content": "Menu" },
    { "type": "link_list", "id": "menu", "label": "Menu", "info": "Edit items in Content → Menus." },
    { "type": "image_picker", "id": "logo", "label": "Logo (optional)", "info": "Leave empty to use the asterisk mark." },
    { "type": "select", "id": "logo_style", "label": "Logo style", "options": [ { "value": "plain", "label": "Plain (no circle)" }, { "value": "bubble", "label": "Bubble (circle)" } ], "default": "plain" },
    { "type": "range", "id": "logo_width", "label": "Plain logo width", "min": 60, "max": 240, "step": 4, "unit": "px", "default": 120 },
    { "type": "checkbox", "id": "show_account", "label": "Show account icon", "default": true },
    { "type": "checkbox", "id": "show_cart", "label": "Show cart icon", "default": true },

    { "type": "header", "content": "Position" },
    { "type": "checkbox", "id": "sticky", "label": "Stick to top on scroll", "default": true },
    { "type": "checkbox", "id": "full_width", "label": "Full width (edge to edge)", "default": true },
    { "type": "range", "id": "top_offset", "label": "Offset from top", "min": 0, "max": 48, "step": 2, "unit": "px", "default": 16 },
    { "type": "range", "id": "max_width", "label": "Max width (when not full width)", "min": 800, "max": 1600, "step": 20, "unit": "px", "default": 1280 },

    { "type": "header", "content": "Size & spacing" },
    { "type": "range", "id": "pill_height", "label": "Bar height", "min": 48, "max": 88, "step": 2, "unit": "px", "default": 64 },
    { "type": "range", "id": "logo_size", "label": "Logo / mark size", "min": 16, "max": 44, "step": 2, "unit": "px", "default": 26 },
    { "type": "range", "id": "text_size", "label": "Menu text size", "min": 11, "max": 18, "step": 1, "unit": "px", "default": 13 },
    { "type": "range", "id": "menu_gap", "label": "Gap between items", "min": 12, "max": 64, "step": 2, "unit": "px", "default": 34 },
    { "type": "range", "id": "side_padding", "label": "Inner side padding", "min": 6, "max": 28, "step": 2, "unit": "px", "default": 12 },

    { "type": "header", "content": "Glass & colors" },
    { "type": "range", "id": "blur", "label": "Glass blur", "min": 0, "max": 40, "step": 2, "unit": "px", "default": 18 },
    { "type": "color", "id": "glass_tint", "label": "Glass tint", "default": "#15151580" },
    { "type": "color", "id": "bubble_tint", "label": "Bubble tint", "default": "#ffffff14" },
    { "type": "color", "id": "border_color", "label": "Border / edge", "default": "#ffffff24" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#f3f3f3" },
    { "type": "color", "id": "accent_color", "label": "Accent (red)", "default": "#560B1E" },

    { "type": "header", "content": "Appearance" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" }
  ],
  "presets": [
    { "name": "Bubble nav (glass)" }
  ]
}
{% endschema %}
