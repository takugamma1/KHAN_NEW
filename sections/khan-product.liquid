{% liquid
  assign s = section.settings
  assign p = product
  if p == blank
    assign p = s.product_fallback
  endif
  assign cur = p.selected_or_first_available_variant
  assign media_count = p.media.size
  assign insp_alt = s.insp_expanded_heading | default: s.insp_heading

  comment
    Colour option (Цвят / Color): drives the gallery filter + colour switcher.
  endcomment
  assign color_oidx = -1
  assign color_opt = blank
  if p != blank
    for opt in p.options_with_values
      assign oname = opt.name | downcase | strip
      if oname == 'цвят' or oname == 'color' or oname == 'colour'
        assign color_opt = opt
        assign color_oidx = forloop.index0
      endif
    endfor
  endif
  assign cur_color = ''
  if color_oidx > -1
    assign cur_color = cur.options[color_oidx]
  endif
%}

<div
  id="KhanProduct-{{ section.id }}"
  class="khan-product color-{{ s.color_scheme }}{% if s.text_grain %} khan-product--grain{% endif %}{% if s.hide_bottom_mobile %} khan-product--hide-bottom-m{% endif %}{% if s.enable_animations %} khan-product--anim{% endif %}"
  data-color-oidx="{{ color_oidx }}"
  data-filter-colors="{% if s.filter_media_by_color and color_oidx > -1 %}true{% else %}false{% endif %}"
  data-max-photos="{{ s.max_photos | default: 12 }}"
  style="
    --kp-bg: {{ s.bg_color }};
    --kp-text: {{ s.text_color }};
    --kp-accent: {{ s.accent_color }};
    --kp-muted: {{ s.muted_color }};
    --kp-title-size: {{ s.title_size }}px;
    --kp-maxw: {{ s.max_width }}px;
    --kp-pt: {{ s.padding_top }}px;
    --kp-pb: {{ s.padding_bottom }}px;
    --kp-bottom-h: {{ s.bottom_height }}px;
    --kp-bottom-shift: {{ s.bottom_shift | default: 0 }}px;
    --kp-grain: url('{{ 'khan-grain.png' | asset_url }}');
  "
  data-khan-product
>
  {%- if s.show_deco -%}
    <span class="khan-product__corner" aria-hidden="true">{{ s.corner_text }}</span>
    <img class="khan-product__deco-ast" src="{{ 'asterisk.png' | asset_url }}" alt="" width="258" height="320" loading="lazy">
    <span class="khan-product__cross khan-product__cross--1" aria-hidden="true"></span>
    <span class="khan-product__cross khan-product__cross--2" aria-hidden="true"></span>
  {%- endif -%}

  <div class="khan-product__inner">
    {%- if p != blank -%}
      <div class="khan-product__grid">

        {%- comment -%}
          ===== gallery =====
          Each image gets a colour: variant image -> variant colour; else colour name in
          alt text; else (with grouping on) it inherits the previous photo's colour —
          galleries ordered per colour need no tagging at all. Still-untagged = shown always.
        {%- endcomment -%}
        {%- liquid
          assign media_colors = ''
          assign last_color = 'all'
          if color_oidx > -1
            for media in p.media limit: 12
              assign mcolor = 'all'
              for v in p.variants
                if v.featured_media != blank and v.featured_media.id == media.id
                  assign mcolor = v.options[color_oidx] | downcase
                  break
                endif
              endfor
              if mcolor == 'all'
                assign malt = media.alt | downcase
                for val in color_opt.values
                  assign lval = val | downcase
                  if malt contains lval
                    assign mcolor = lval
                    break
                  endif
                endfor
              endif
              if mcolor == 'all' and s.group_untagged and last_color != 'all'
                assign mcolor = last_color
              endif
              if mcolor != 'all'
                assign last_color = mcolor
              endif
              assign media_colors = media_colors | append: mcolor | append: '~~'
            endfor
          endif
          assign media_colors_arr = media_colors | split: '~~'
        -%}
        <div class="khan-product__thumbs" data-rev style="--rev: 0">
          {%- for media in p.media limit: 12 -%}
            {%- assign mcolor = media_colors_arr[forloop.index0] | default: 'all' -%}
            <button type="button" class="khan-product__thumb{% if forloop.first %} is-active{% endif %}" data-i="{{ forloop.index }}" data-color="{{ mcolor | escape }}" data-full="{{ media | image_url: width: 1600 }}" aria-label="View image {{ forloop.index }}">
              {{ media | image_url: width: 220 | image_tag: loading: 'lazy', widths: '110, 220', alt: '' }}
            </button>
          {%- endfor -%}
        </div>

        <div class="khan-product__stage" data-rev style="--rev: 1">
          <span class="khan-product__ring" aria-hidden="true"></span>
          <div class="khan-product__main">
            {%- if p.featured_media != blank -%}
              <img data-main-image src="{{ p.featured_media | image_url: width: 1600 }}" alt="{{ p.featured_media.alt | default: p.title }}" width="{{ p.featured_media.width }}" height="{{ p.featured_media.height }}" loading="eager">
              {%- comment -%} Mobile: the image is a finger-following snap carousel of the visible photos {%- endcomment -%}
              <div class="khan-product__slider" data-kp-slider aria-label="{{ p.title | escape }}">
                {%- for media in p.media limit: 12 -%}
                  {%- assign mcolor = media_colors_arr[forloop.index0] | default: 'all' -%}
                  <div class="khan-product__slide" data-color="{{ mcolor | escape }}">
                    {{ media | image_url: width: 1200 | image_tag: loading: 'lazy', widths: '600, 900, 1200', sizes: '100vw', alt: media.alt | default: p.title }}
                  </div>
                {%- endfor -%}
              </div>
              <span class="khan-product__slide-count" data-kp-slidecount aria-hidden="true"></span>
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'khan-product__ph' }}
            {%- endif -%}
          </div>
        </div>

        {%- comment -%} ===== info / buy ===== {%- endcomment -%}
        <div class="khan-product__info">
          <p class="khan-product__count" data-rev style="--rev: 2"><span data-counter>01</span> / <span data-counter-total>{% if media_count < 10 %}0{% endif %}{{ media_count | default: 1 }}</span></p>

          <h1 class="khan-product__title" data-rev style="--rev: 3">{{ p.title | default: 'Product title' }}</h1>
          {%- if s.tagline != blank -%}<p class="khan-product__tagline" data-rev style="--rev: 4">{{ s.tagline }}</p>{%- endif -%}
          <span class="khan-product__rule" aria-hidden="true"></span>

          {%- if s.show_color_picker and color_oidx > -1 and color_opt.values.size > 1 -%}
            <div class="khan-product__colors" data-color-picker data-rev style="--rev: 5">
              <p class="khan-product__colors-label">{{ color_opt.name }} <span class="khan-product__colors-name" data-color-name>{{ cur_color }}</span></p>
              <div class="khan-product__colors-row" role="group" aria-label="{{ color_opt.name | escape }}">
                {%- for val in color_opt.values -%}
                  <button type="button" class="khan-product__color" data-kp-color="{{ val | escape }}" aria-pressed="{% if cur_color == val %}true{% else %}false{% endif %}">
                    <span>{{ val }}</span>
                  </button>
                {%- endfor -%}
              </div>
            </div>
          {%- endif -%}

          {%- if s.description != blank -%}
            <div class="khan-product__desc" data-rev style="--rev: 6">{{ s.description }}</div>
          {%- elsif p.description != blank -%}
            <div class="khan-product__desc" data-rev style="--rev: 6">{{ p.description }}</div>
          {%- endif -%}

          {%- if s.show_inspiration and s.insp_heading != blank -%}
            <details class="khan-product__insp" data-rev style="--rev: 7"{% if s.insp_open %} open{% endif %}>
              <summary class="khan-product__insp-summary">
                <span class="khan-product__insp-head">
                  <span class="khan-product__insp-title">{{ s.insp_heading }}</span>
                  <span class="khan-product__insp-toggle">
                    <span class="khan-product__insp-lbl khan-product__insp-lbl--show">{{ s.insp_toggle_label | default: 'See inspiration' }}</span>
                    <span class="khan-product__insp-lbl khan-product__insp-lbl--hide">{{ s.insp_hide_label | default: 'Hide' }}</span>
                    <span class="khan-product__insp-caret" aria-hidden="true"></span>
                  </span>
                </span>
                {%- if s.insp_intro != blank -%}<span class="khan-product__insp-intro">{{ s.insp_intro | newline_to_br }}</span>{%- endif -%}
              </summary>
              <div class="khan-product__insp-reveal">
                {%- if s.insp_expanded_text != blank -%}<div class="khan-product__insp-extext">{{ s.insp_expanded_text }}</div>{%- endif -%}
                {%- if s.insp_expanded_heading != blank -%}<p class="khan-product__insp-exhead">{{ s.insp_expanded_heading }}</p>{%- endif -%}
                {%- if s.insp_image != blank -%}
                  {{ s.insp_image | image_url: width: 1200 | image_tag: class: 'khan-product__insp-img', loading: 'lazy', widths: '400, 700, 1000, 1200', sizes: '(max-width: 749px) 88vw, 38vw', alt: insp_alt }}
                {%- endif -%}
              </div>
            </details>
          {%- endif -%}

          {%- assign feats = section.blocks | where: 'type', 'feature' -%}
          {%- if feats.size > 0 -%}
            <div class="khan-product__feats" data-rev style="--rev: 8">
              {%- for block in feats -%}
                <div class="khan-product__feat" {{ block.shopify_attributes }}>
                  {%- if block.settings.icon != blank -%}
                    <img class="khan-product__feat-icon" src="{{ block.settings.icon | image_url: width: 120 }}" alt="" width="40" height="40" loading="lazy">
                  {%- endif -%}
                  <span class="khan-product__feat-label">{{ block.settings.label }}</span>
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}

          {%- if s.show_buy -%}
          {%- form 'product', p, id: 'khan-pf', class: 'khan-product__form', novalidate: 'novalidate' -%}
            <input type="hidden" name="id" value="{{ cur.id }}" data-variant-input>

            {%- if p.variants.size > 1 -%}
              <p class="khan-product__size-label">Size</p>
              <div class="khan-product__sizes" role="group" aria-label="Size">
                {%- for v in p.variants -%}
                  <button
                    type="button"
                    class="khan-product__size{% if v.id == cur.id %} is-selected{% endif %}{% unless v.available %} is-soldout{% endunless %}"
                    data-variant="{{ v.id }}"
                    data-price="{{ v.price | money }}"
                    data-available="{{ v.available }}"
                  >{{ v.title }}</button>
                {%- endfor -%}
              </div>
            {%- endif -%}

            {%- if s.size_guide_link != blank -%}
              <a class="khan-product__guide" href="{{ s.size_guide_link }}">Size guide</a>
            {%- endif -%}

            <p class="khan-product__price"><span data-price>{{ cur.price | money }}</span></p>

            <button type="submit" name="add" class="khan-product__atc" data-atc {% unless cur.available %}disabled{% endunless %}>
              <span data-atc-text>{% if cur.available %}Add to cart{% else %}Sold out{% endif %}</span><span class="khan-product__atc-plus" aria-hidden="true">+</span>
            </button>
            <button type="button" class="khan-product__buynow" data-buynow {% unless cur.available %}disabled{% endunless %}>
              <span>Buy now</span><span aria-hidden="true">→</span>
            </button>
          {%- endform -%}
          {%- endif -%}

          {%- assign info_tabs = section.blocks | where: 'type', 'tab' -%}
          {%- if info_tabs.size > 0 -%}
            <div class="khan-product__tabs" data-rev style="--rev: 9">
              {%- for block in info_tabs -%}
                <details class="khan-product__tab"{% if block.settings.open %} open{% endif %} {{ block.shopify_attributes }}>
                  <summary class="khan-product__tab-head">
                    {%- if block.settings.icon != blank -%}<img class="khan-product__tab-icon" src="{{ block.settings.icon | image_url: width: 60 }}" alt="" width="18" height="18" loading="lazy">{%- endif -%}
                    <span class="khan-product__tab-title">{{ block.settings.heading }}</span>
                    <span class="khan-product__tab-sign" aria-hidden="true"></span>
                  </summary>
                  {%- if block.settings.body != blank or block.settings.table != blank -%}
                  <div class="khan-product__tab-body">
                    {%- if block.settings.body != blank -%}<div class="khan-product__tab-text">{{ block.settings.body }}</div>{%- endif -%}
                    {%- if block.settings.table != blank -%}
                      {%- assign tab_rows = block.settings.table | strip | newline_to_br | split: '<br />' -%}
                      <table class="khan-product__tab-table">
                        {%- assign header_done = false -%}
                        {%- for row in tab_rows -%}
                          {%- assign cells = row | strip | split: '|' -%}
                          {%- if row != blank and cells.size > 0 -%}
                            <tr>
                              {%- for c in cells -%}
                                {%- if header_done -%}<td>{{ c | strip }}</td>{%- else -%}<th>{{ c | strip }}</th>{%- endif -%}
                              {%- endfor -%}
                            </tr>
                            {%- assign header_done = true -%}
                          {%- endif -%}
                        {%- endfor -%}
                      </table>
                    {%- endif -%}
                  </div>
                  {%- endif -%}
                </details>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      </div>
    {%- else -%}
      <p class="khan-product__empty">Add this section to a product page (or pick a fallback product in the section settings) to preview it.</p>
    {%- endif -%}
  </div>

  {%- if s.bottom_image != blank -%}
    <div class="khan-product__bottom" aria-hidden="true">
      {{ s.bottom_image | image_url: width: 2600 | image_tag: class: 'khan-product__bottom-img', loading: 'lazy', widths: '800, 1200, 1600, 2000, 2600', sizes: '100vw', alt: '' }}
    </div>
  {%- endif -%}
</div>

<script>
  (function () {
    var root = document.getElementById('KhanProduct-{{ section.id }}');
    if (!root) return;

    // entrance reveal (CSS only hides once this class lands, so no-JS stays visible)
    var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (root.classList.contains('khan-product--anim') && !reduce && 'IntersectionObserver' in window) {
      root.classList.add('kp-anim-ready');
      new IntersectionObserver(function (es, io) {
        es.forEach(function (e) { if (e.isIntersecting) { root.classList.add('kp-in'); io.disconnect(); } });
      }, { threshold: 0.12 }).observe(root);
    }

    // gallery: crossfade swaps + colour filtering
    var main = root.querySelector('[data-main-image]');
    var counter = root.querySelector('[data-counter]');
    var counterTotal = root.querySelector('[data-counter-total]');
    var thumbs = [].slice.call(root.querySelectorAll('.khan-product__thumb'));
    function pad(n) { return n < 10 ? '0' + n : '' + n; }

    function swapMain(src) {
      if (!main || !src || main.src === src) return;
      if (reduce) { main.src = src; return; }
      main.classList.add('is-fading');
      window.setTimeout(function () {
        var done = function () { main.classList.remove('is-fading'); };
        main.onload = done;
        main.src = src;
        if (main.complete) done();
      }, 190);
    }

    function visibleThumbs() {
      return thumbs.filter(function (t) { return !t.classList.contains('is-off'); });
    }
    function updateCounter(activeThumb) {
      var vis = visibleThumbs();
      if (counterTotal) counterTotal.textContent = pad(vis.length || 1);
      if (counter) counter.textContent = pad(Math.max(1, vis.indexOf(activeThumb) + 1));
    }
    function activate(t) {
      swapMain(t.getAttribute('data-full'));
      thumbs.forEach(function (x) { x.classList.remove('is-active'); });
      t.classList.add('is-active');
      updateCounter(t);
    }
    thumbs.forEach(function (t) { t.addEventListener('click', function () { activate(t); }); });

    // mobile slider: the image itself is a finger-following snap carousel
    var slider = root.querySelector('[data-kp-slider]');
    var slides = slider ? [].slice.call(slider.children) : [];
    var slidePill = root.querySelector('[data-kp-slidecount]');
    function visibleSlides() {
      return slides.filter(function (x) { return !x.classList.contains('is-off'); });
    }
    function updateSlidePill() {
      if (!slidePill || !slider) return;
      var vis = visibleSlides();
      if (vis.length < 2) { slidePill.textContent = ''; return; }
      var w = slider.clientWidth || 1;
      var i = Math.min(vis.length - 1, Math.max(0, Math.round(slider.scrollLeft / w)));
      slidePill.textContent = pad(i + 1) + ' / ' + pad(vis.length);
    }
    if (slider) {
      var pillTick = null;
      slider.addEventListener('scroll', function () {
        if (pillTick) return;
        pillTick = window.setTimeout(function () { pillTick = null; updateSlidePill(); }, 80);
      }, { passive: true });
    }

    // filter photos (thumbs + slides mirror each other by index): colour + max cap
    var maxPhotos = parseInt(root.getAttribute('data-max-photos'), 10) || 99;
    function applyFilter(lval) {
      var shown = 0;
      thumbs.forEach(function (t, i) {
        var c = t.getAttribute('data-color');
        var ok = lval == null || c === 'all' || c === lval;
        if (ok && shown >= maxPhotos) ok = false;
        if (ok) shown++;
        t.classList.toggle('is-off', !ok);
        if (slides[i]) slides[i].classList.toggle('is-off', !ok);
      });
      if (slider) slider.scrollTo({ left: 0 });
      updateSlidePill();
    }

    // colour filtering: hide photos that belong to other colours
    var filterOn = root.getAttribute('data-filter-colors') === 'true';
    var colorOidx = parseInt(root.getAttribute('data-color-oidx'), 10);
    var colorName = root.querySelector('[data-color-name]');
    var syncing = false;

    function applyColor(val, syncSticky) {
      var lval = (val || '').toLowerCase();
      root.querySelectorAll('[data-kp-color]').forEach(function (b) {
        b.setAttribute('aria-pressed', b.getAttribute('data-kp-color') === val ? 'true' : 'false');
      });
      if (colorName) colorName.textContent = val;
      if (filterOn) {
        applyFilter(lval);
        var vis = visibleThumbs();
        var active = root.querySelector('.khan-product__thumb.is-active');
        if (vis.length && (!active || active.classList.contains('is-off'))) {
          // prefer a photo of the newly selected colour over shared ones
          var exact = vis.filter(function (t) { return t.getAttribute('data-color') === lval; });
          activate(exact[0] || vis[0]);
        } else {
          updateCounter(active || vis[0]);
        }
      }
      if (syncSticky && colorOidx > -1 && !syncing) {
        syncing = true;
        document.querySelectorAll('[data-khan-scart-opt][data-oi="' + colorOidx + '"]').forEach(function (b) {
          if (b.getAttribute('data-val') === val && b.getAttribute('aria-pressed') !== 'true') b.click();
        });
        syncing = false;
      }
    }
    root.querySelectorAll('[data-kp-color]').forEach(function (b) {
      b.addEventListener('click', function () { applyColor(b.getAttribute('data-kp-color'), true); });
    });
    // picking a colour in the sticky cart filters the gallery too
    if (colorOidx > -1) {
      document.addEventListener('click', function (e) {
        if (syncing) return;
        var b = e.target.closest && e.target.closest('[data-khan-scart-opt][data-oi="' + colorOidx + '"]');
        if (b) { syncing = true; applyColor(b.getAttribute('data-val'), false); syncing = false; }
      });
    }
    // initial filter to the selected variant's colour (or just the photo cap)
    var pressed = root.querySelector('[data-kp-color][aria-pressed="true"]');
    if (filterOn && pressed) applyColor(pressed.getAttribute('data-kp-color'), false);
    else applyFilter(null);

    // variants
    var input = root.querySelector('[data-variant-input]');
    var priceEl = root.querySelector('[data-price]');
    var atc = root.querySelector('[data-atc]');
    var atcText = root.querySelector('[data-atc-text]');
    var buynow = root.querySelector('[data-buynow]');
    root.querySelectorAll('.khan-product__size').forEach(function (b) {
      b.addEventListener('click', function () {
        root.querySelectorAll('.khan-product__size').forEach(function (x) { x.classList.remove('is-selected'); });
        b.classList.add('is-selected');
        if (input) input.value = b.getAttribute('data-variant');
        if (priceEl) priceEl.textContent = b.getAttribute('data-price');
        var avail = b.getAttribute('data-available') === 'true';
        if (atc) { atc.disabled = !avail; if (atcText) atcText.textContent = avail ? 'Add to cart' : 'Sold out'; }
        if (buynow) buynow.disabled = !avail;
      });
    });

    // buy now -> add then go to checkout
    if (buynow && input) {
      buynow.addEventListener('click', function () {
        buynow.disabled = true;
        fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: input.value, quantity: 1 })
        }).then(function () { window.location.href = '/checkout'; })
          .catch(function () { buynow.disabled = false; });
      });
    }

    // smooth open/close for the inspiration box + info tabs (native <details> just pops)
    var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    function animateDetails(d) {
      var summary = d.querySelector(':scope > summary');
      var body = summary && summary.nextElementSibling;
      if (!summary || !body) return;
      var OPEN = 340, CLOSE = 280;
      summary.addEventListener('click', function (e) {
        e.preventDefault();
        if (d.dataset.busy) return;
        d.dataset.busy = '1';
        body.style.overflow = 'hidden';
        if (d.open) {
          var from = body.scrollHeight;
          body.style.height = from + 'px'; body.style.opacity = '1';
          void body.offsetHeight; // reflow
          body.style.transition = 'height ' + CLOSE + 'ms cubic-bezier(.4,0,.2,1), opacity ' + CLOSE + 'ms ease';
          body.style.height = '0px'; body.style.opacity = '0';
          window.setTimeout(function () {
            d.open = false;
            body.removeAttribute('style');
            delete d.dataset.busy;
          }, CLOSE);
        } else {
          d.open = true;
          var to = body.scrollHeight;
          body.style.height = '0px'; body.style.opacity = '0';
          void body.offsetHeight; // reflow
          body.style.transition = 'height ' + OPEN + 'ms cubic-bezier(.4,0,.2,1), opacity ' + OPEN + 'ms ease';
          body.style.height = to + 'px'; body.style.opacity = '1';
          window.setTimeout(function () {
            body.removeAttribute('style');
            delete d.dataset.busy;
            // if the opened drawer now runs past the screen, bring it into view
            var r = d.getBoundingClientRect();
            if (r.bottom > window.innerHeight + 2) {
              var fits = r.height <= window.innerHeight - 90;
              d.scrollIntoView({ behavior: 'smooth', block: fits ? 'nearest' : 'start' });
            }
          }, OPEN);
        }
      });
    }
    if (!reduce) {
      root.querySelectorAll('.khan-product__insp, .khan-product__tab').forEach(animateDetails);
    }
  })();
</script>

{% stylesheet %}
  .khan-product {
    position: relative;
    background: var(--kp-bg, #f4f1ea);
    padding-block: var(--kp-pt, 56px) var(--kp-pb, 200px);
    padding-inline: clamp(20px, 4vw, 64px);
    overflow: hidden;
    isolation: isolate;
  }
  .khan-product__inner { position: relative; z-index: 2; max-width: min(var(--kp-maxw, 1820px), 100%); margin-inline: auto; }

  .khan-product__grid {
    display: grid;
    grid-template-columns: 96px minmax(0, 1.25fr) minmax(0, 0.85fr);
    gap: clamp(24px, 3vw, 56px);
    align-items: center;
  }

  /* mono helper */
  .khan-product__count, .khan-product__tagline, .khan-product__desc, .khan-product__feat-label,
  .khan-product__size-label, .khan-product__size, .khan-product__guide, .khan-product__price,
  .khan-product__atc, .khan-product__buynow, .khan-product__corner {
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
  }

  /* ---- thumbs ---- */
  .khan-product__thumbs { display: flex; flex-direction: column; gap: 14px; }
  .khan-product__thumb { padding: 0; border: 1px solid rgb(0 0 0 / 0.14); background: #fff; cursor: pointer; aspect-ratio: 1; overflow: hidden; }
  .khan-product__thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .khan-product__thumb.is-active { border-color: var(--kp-accent, #560B1E); }

  /* ---- stage ---- */
  .khan-product__stage { position: relative; display: flex; align-items: center; justify-content: center; }
  .khan-product__ring {
    position: absolute; width: min(86%, 620px); aspect-ratio: 1; border-radius: 50%;
    border: 1px dashed rgb(0 0 0 / 0.22); pointer-events: none;
  }
  .khan-product__ring::after {
    content: ""; position: absolute; inset: 8%; border-radius: 50%; border: 1px solid rgb(216 35 42 / 0.18);
  }
  .khan-product__main { position: relative; z-index: 1; width: 100%; }
  .khan-product__main img, .khan-product__ph { width: 100%; height: auto; display: block; object-fit: contain; max-height: 78svh; }

  /* ---- info ---- */
  .khan-product__count { margin: 0 0 18px; font-size: 14px; letter-spacing: 0.2em; color: var(--kp-accent, #560B1E); }
  .khan-product__title {
    margin: 0; font-family: 'Nexa', var(--font-heading--family, sans-serif); font-weight: 900;
    font-size: min(var(--kp-title-size, 64px), 7vw); line-height: 0.92; letter-spacing: -0.01em;
    text-transform: uppercase; color: var(--kp-text, #111);
  }
  .khan-product__tagline { margin: 12px 0 0; font-size: 14px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--kp-accent, #560B1E); }
  .khan-product__rule { display: block; height: 1px; background: rgb(0 0 0 / 0.2); margin: 22px 0; }
  .khan-product__desc { font-size: 14px; line-height: 1.7; letter-spacing: 0.02em; text-transform: uppercase; color: var(--kp-text, #1a1a1a); }
  .khan-product__desc p { margin: 0 0 0.4em; }

  .khan-product__feats { display: flex; flex-wrap: wrap; gap: 18px 28px; margin: 28px 0; }
  .khan-product__feat { display: flex; flex-direction: column; align-items: center; gap: 8px; text-align: center; }
  .khan-product__feat-icon { width: 20px; height: 20px; object-fit: contain; }
  .khan-product__feat-label { font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--kp-muted, #555); max-width: 90px; }

  /* ---- size + buy ---- */
  .khan-product__size-label { margin: 8px 0 12px; font-size: 13px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--kp-muted, #555); }
  .khan-product__sizes { display: flex; border: 1px solid rgb(0 0 0 / 0.16); width: fit-content; max-width: 100%; flex-wrap: wrap; }
  .khan-product__size { min-width: 56px; padding: 13px 14px; background: transparent; border: 0; border-right: 1px solid rgb(0 0 0 / 0.16); cursor: pointer; font-size: 13px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--kp-text, #111); }
  .khan-product__size:last-child { border-right: 0; }
  .khan-product__size.is-selected { background: #111; color: #fff; }
  .khan-product__size.is-soldout { opacity: 0.4; text-decoration: line-through; }

  .khan-product__guide { display: inline-block; margin: 16px 0 0; font-size: 12px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--kp-text, #111); }
  .khan-product__price { margin: 18px 0 14px; font-size: 18px; letter-spacing: 0.06em; color: var(--kp-text, #111); }

  .khan-product__atc, .khan-product__buynow {
    position: relative; display: flex; align-items: center; justify-content: center; width: 100%;
    padding: 18px; font-size: 14px; letter-spacing: 0.22em; text-transform: uppercase; cursor: pointer;
  }
  .khan-product__atc { background: #111; color: #fff; border: 0; }
  .khan-product__atc:hover { background: #000; }
  .khan-product__atc-plus { position: absolute; right: 18px; color: var(--kp-accent, #560B1E); }
  .khan-product__buynow { margin-top: 12px; background: transparent; color: var(--kp-text, #111); border: 1px solid rgb(0 0 0 / 0.3); gap: 14px; }
  .khan-product__buynow:hover { border-color: #111; }
  .khan-product__atc[disabled], .khan-product__buynow[disabled] { opacity: 0.45; cursor: not-allowed; }

  /* ---- bottom overlay image (bleeds up over the section's lower edge) ---- */
  .khan-product__bottom { position: absolute; left: 0; right: 0; bottom: 0; z-index: 3; pointer-events: none; line-height: 0; transform: translateY(var(--kp-bottom-shift, 0)); }
  .khan-product__bottom-img { display: block; width: 100%; height: auto; max-height: var(--kp-bottom-h, 360px); object-fit: cover; object-position: bottom center; }

  /* ---- decorations ---- */
  .khan-product__corner { position: absolute; left: 28px; bottom: calc(var(--kp-bottom-h, 360px) + 16px); z-index: 2; font-size: 11px; line-height: 1.5; letter-spacing: 0.16em; text-transform: uppercase; color: var(--kp-muted, #888); white-space: pre-line; }
  .khan-product__deco-ast { position: absolute; right: 4%; top: 26%; width: 22px; height: 22px; object-fit: contain; z-index: 2; }
  .khan-product__cross { position: absolute; z-index: 1; width: 16px; height: 16px; }
  .khan-product__cross::before, .khan-product__cross::after { content: ""; position: absolute; background: var(--kp-accent, #560B1E); opacity: 0.6; }
  .khan-product__cross::before { left: 50%; top: 0; bottom: 0; width: 1px; transform: translateX(-50%); }
  .khan-product__cross::after { top: 50%; left: 0; right: 0; height: 1px; transform: translateY(-50%); }
  .khan-product__cross--1 { left: 6%; top: 10%; }
  .khan-product__cross--2 { right: 30%; bottom: calc(var(--kp-bottom-h, 360px) + 8%); }

  /* ---- grain ---- */
  .khan-product--grain :is(.khan-product__title, .khan-product__tagline, .khan-product__desc, .khan-product__count, .khan-product__feat-label) {
    -webkit-mask-image: var(--kp-grain); mask-image: var(--kp-grain);
    -webkit-mask-size: 170px 170px; mask-size: 170px 170px;
  }

  /* drawers leave room for a sticky header when auto-scrolled to the top */
  .khan-product__insp, .khan-product__tab { scroll-margin-top: 90px; }

  /* ---- gallery animations + colour filtering ---- */
  [data-main-image] { transition: opacity 0.3s ease, transform 0.3s ease; }
  [data-main-image].is-fading { opacity: 0; transform: scale(0.985); }
  .khan-product__thumb { transition: opacity 0.25s ease, transform 0.25s ease, border-color 0.15s ease; }
  .khan-product__thumb.is-off { display: none; }

  /* ---- mobile photo slider (finger-following snap carousel) ---- */
  .khan-product__slider { display: none; }
  .khan-product__slide.is-off { display: none; }
  .khan-product__slide-count { display: none; }

  /* ---- colour switcher ---- */
  .khan-product__colors { margin: 2px 0 20px; }
  .khan-product__colors-label {
    margin: 0 0 10px;
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: 13px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--kp-muted, #555);
  }
  .khan-product__colors-name { color: var(--kp-accent, #d8232a); }
  .khan-product__colors-row { display: flex; flex-wrap: wrap; gap: 8px; }
  .khan-product__color {
    padding: 11px 16px;
    background: transparent;
    border: 1px solid rgb(0 0 0 / 0.16);
    color: var(--kp-text, #111);
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: 13px; letter-spacing: 0.1em; text-transform: uppercase;
    cursor: pointer;
    transition: background 0.18s ease, color 0.18s ease, border-color 0.18s ease, transform 0.18s ease;
  }
  .khan-product__color:hover { border-color: var(--kp-text, #111); transform: translateY(-1px); }
  .khan-product__color[aria-pressed="true"] { background: #111; color: #fff; border-color: #111; }

  /* ---- entrance reveal (only hides once JS confirms it will animate) ---- */
  .khan-product--anim.kp-anim-ready [data-rev] {
    opacity: 0;
    transform: translateY(18px);
    transition: opacity 0.6s ease, transform 0.6s cubic-bezier(0.22, 0.61, 0.36, 1);
    transition-delay: calc(var(--rev, 0) * 70ms);
  }
  .khan-product--anim.kp-anim-ready.kp-in [data-rev] { opacity: 1; transform: none; }

  /* ---- inspiration disclosure (dark panel) ---- */
  .khan-product__insp { margin: 22px 0 4px; background: #0d0d0d; color: #f1f1f1; border: 1px solid rgb(255 255 255 / 0.08); border-radius: 14px; overflow: hidden; }
  .khan-product__insp-summary { list-style: none; cursor: pointer; display: block; padding: 18px 20px; }
  .khan-product__insp-summary::-webkit-details-marker { display: none; }
  .khan-product__insp-head { display: flex; align-items: center; justify-content: space-between; gap: 14px; }
  .khan-product__insp-title { font-family: ui-monospace, "SFMono-Regular", Menlo, monospace; font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase; color: #cfcfcf; }
  .khan-product__insp-toggle { display: inline-flex; align-items: center; gap: 8px; border: 1px solid rgb(255 255 255 / 0.28); border-radius: 8px; padding: 8px 13px; font-family: ui-monospace, monospace; font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: #fff; white-space: nowrap; transition: border-color 0.2s ease, background 0.2s ease; }
  .khan-product__insp-summary:hover .khan-product__insp-toggle { border-color: var(--kp-accent, #560B1E); }
  .khan-product__insp-lbl--hide { display: none; }
  .khan-product__insp[open] .khan-product__insp-lbl--show { display: none; }
  .khan-product__insp[open] .khan-product__insp-lbl--hide { display: inline; }
  .khan-product__insp-caret { width: 7px; height: 7px; border-right: 1.5px solid currentColor; border-bottom: 1.5px solid currentColor; transform: rotate(45deg); transition: transform 0.25s ease; }
  .khan-product__insp[open] .khan-product__insp-caret { transform: rotate(-135deg); }
  .khan-product__insp-intro { display: block; margin-top: 14px; font-family: ui-monospace, monospace; font-size: 12.5px; line-height: 1.6; letter-spacing: 0.02em; color: #b6b6b6; text-transform: none; }
  .khan-product__insp-intro p { margin: 0; }
  .khan-product__insp-reveal { padding: 0 20px 22px; box-sizing: border-box; }
  .khan-product__insp-extext { font-family: ui-monospace, monospace; font-size: 12.5px; line-height: 1.6; color: #b6b6b6; }
  .khan-product__insp-extext p { margin: 0 0 8px; }
  .khan-product__insp-exhead { margin: 16px 0 12px; padding-top: 16px; border-top: 1px solid rgb(255 255 255 / 0.12); font-family: 'Nexa', var(--font-heading--family, sans-serif); font-weight: 900; font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; color: #fff; }
  .khan-product__insp-img { display: block; width: 100%; height: auto; border: 1px solid rgb(255 255 255 / 0.14); border-radius: 8px; background: #fff; }

  /* ---- info tabs (accordions) ---- */
  .khan-product__tabs { margin-top: 28px; border-top: 1px solid rgb(0 0 0 / 0.14); }
  .khan-product__tab { border-bottom: 1px solid rgb(0 0 0 / 0.14); }
  .khan-product__tab-head { list-style: none; cursor: pointer; display: flex; align-items: center; gap: 12px; padding: 18px 2px; font-family: ui-monospace, monospace; font-size: 13px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--kp-text, #111); }
  .khan-product__tab-head::-webkit-details-marker { display: none; }
  .khan-product__tab-icon { width: 18px; height: 18px; object-fit: contain; flex: 0 0 auto; }
  .khan-product__tab-title { flex: 1 1 auto; }
  .khan-product__tab-sign { position: relative; width: 13px; height: 13px; flex: 0 0 auto; transition: transform 0.25s ease; }
  .khan-product__tab-sign::before, .khan-product__tab-sign::after { content: ""; position: absolute; background: var(--kp-text, #111); }
  .khan-product__tab-sign::before { left: 0; right: 0; top: 50%; height: 1.5px; transform: translateY(-50%); }
  .khan-product__tab-sign::after { top: 0; bottom: 0; left: 50%; width: 1.5px; transform: translateX(-50%); }
  .khan-product__tab[open] .khan-product__tab-sign { transform: rotate(45deg); }
  .khan-product__tab-body { padding: 0 2px 22px; box-sizing: border-box; overflow-x: auto; -webkit-overflow-scrolling: touch; }
  .khan-product__tab-text { font-family: ui-monospace, monospace; font-size: 13px; line-height: 1.7; letter-spacing: 0.02em; color: var(--kp-muted, #555); }
  .khan-product__tab-text p { margin: 0 0 8px; }
  .khan-product__tab-text p:last-child { margin-bottom: 0; }
  .khan-product__tab-table { width: 100%; min-width: max-content; border-collapse: collapse; margin-top: 6px; font-family: ui-monospace, monospace; font-size: 12.5px; }
  .khan-product__tab-table th, .khan-product__tab-table td { text-align: left; padding: 9px 8px; border-bottom: 1px solid rgb(0 0 0 / 0.1); letter-spacing: 0.04em; }
  .khan-product__tab-table th { color: var(--kp-text, #111); text-transform: uppercase; font-size: 11px; letter-spacing: 0.1em; border-bottom-color: rgb(0 0 0 / 0.24); }
  .khan-product__tab-table td { color: var(--kp-muted, #666); }
  .khan-product__tab-table tr:last-child th, .khan-product__tab-table tr:last-child td { border-bottom: 0; }

  /* ---- responsive ---- */
  @media screen and (max-width: 1100px) {
    .khan-product__grid { grid-template-columns: 80px minmax(0, 1fr); }
    .khan-product__info { grid-column: 1 / -1; }
  }
  @media screen and (max-width: 749px) {
    .khan-product { padding-bottom: 140px; }
    .khan-product__grid { grid-template-columns: 1fr; }
    /* thumbnails hide on mobile — the image becomes a finger-following snap carousel */
    .khan-product__thumbs { display: none; }
    .khan-product__main [data-main-image] { display: none; }
    .khan-product__slider {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      width: 100%;
    }
    .khan-product__slider::-webkit-scrollbar { display: none; }
    .khan-product__slide { flex: 0 0 100%; scroll-snap-align: center; scroll-snap-stop: always; }
    .khan-product__slide img { width: 100%; height: auto; object-fit: contain; max-height: 72svh; display: block; }
    .khan-product__slide-count {
      display: block; position: absolute; right: 10px; top: 10px; z-index: 2;
      padding: 6px 10px; border-radius: 999px;
      background: rgb(0 0 0 / 0.55); color: #fff;
      font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
      font-size: 11px; letter-spacing: 0.14em;
      pointer-events: none;
    }
    .khan-product__slide-count:empty { display: none; }
    .khan-product__corner, .khan-product__deco-ast { display: none; }
    /* avoid a second product image stacked under the hero on phones */
    .khan-product--hide-bottom-m { padding-bottom: 48px; }
    .khan-product--hide-bottom-m .khan-product__bottom { display: none; }
    .khan-product__insp-summary { padding: 16px; }
    .khan-product__insp-reveal { padding: 0 16px 18px; }
    .khan-product__insp-head { flex-wrap: wrap; gap: 10px; min-width: 0; }
    .khan-product__insp-toggle { white-space: normal; max-width: 100%; }
    .khan-product__tab-table th, .khan-product__tab-table td { padding: 8px 6px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Product hero",
  "tag": "section",
  "class": "khan-product-wrapper section-wrapper",
  "settings": [
    { "type": "header", "content": "Product" },
    { "type": "paragraph", "content": "Uses the current product on a product page. On other pages, pick a fallback to preview." },
    { "type": "product", "id": "product_fallback", "label": "Fallback product (preview)" },
    { "type": "checkbox", "id": "show_buy", "label": "Show price, size & buy buttons", "default": true, "info": "Turn off when a sticky add-to-cart provides the buy UI." },

    { "type": "header", "content": "Colours & gallery" },
    { "type": "checkbox", "id": "show_color_picker", "label": "Show colour switcher", "default": true, "info": "Lets visitors switch colour from the hero; stays in sync with the sticky add-to-cart." },
    { "type": "checkbox", "id": "filter_media_by_color", "label": "Only show photos of the selected colour", "default": true },
    { "type": "checkbox", "id": "group_untagged", "label": "Group untagged photos with the previous colour", "default": true, "info": "Order the gallery per colour (black photos, then red photos…) and untagged photos follow the colour before them — no tagging needed." },
    { "type": "range", "id": "max_photos", "label": "Max photos shown per colour", "min": 1, "max": 12, "step": 1, "default": 12 },
    { "type": "paragraph", "content": "To tag a photo explicitly: set it as that variant's image, or put the colour name in the photo's alt text (e.g. \"Черно\"). Untagged photos before any colour photo show for every colour." },
    { "type": "checkbox", "id": "enable_animations", "label": "Entrance animations", "default": true, "info": "Content fades in as the section appears. Image changes always crossfade." },
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "Built different. Made to last." },
    { "type": "richtext", "id": "description", "label": "Description override", "info": "Leave empty to use the product description." },
    { "type": "url", "id": "size_guide_link", "label": "Size guide link" },

    { "type": "header", "content": "Inspiration disclosure" },
    { "type": "checkbox", "id": "show_inspiration", "label": "Show inspiration box", "default": true },
    { "type": "checkbox", "id": "insp_open", "label": "Open by default", "default": false },
    { "type": "text", "id": "insp_heading", "label": "Heading", "default": "Носено в бурята" },
    { "type": "textarea", "id": "insp_intro", "label": "Intro (always visible)", "default": "Тежък 400gsm органичен памук с печат, вдъхновен от древни тракийски символи. За тези, които живеят на улицата и не се извиняват." },
    { "type": "text", "id": "insp_toggle_label", "label": "Show label", "default": "Виж вдъхновението" },
    { "type": "text", "id": "insp_hide_label", "label": "Hide label", "default": "Скрий" },
    { "type": "richtext", "id": "insp_expanded_text", "label": "Expanded text", "default": "<p>За направата на този суитшърт са използвани дизайни, преработени от български шарки на носии и българската азбука глаголица, преправени от наш дизайнер.</p>" },
    { "type": "text", "id": "insp_expanded_heading", "label": "Expanded heading", "default": "Глаголица – оригиналната българска азбука" },
    { "type": "image_picker", "id": "insp_image", "label": "Inspiration image", "info": "Upload the Glagolitic alphabet (or any inspiration image)." },

    { "type": "header", "content": "Bottom overlay image" },
    { "type": "paragraph", "content": "Bleeds up over the lower edge so the section blends into the next instead of a hard cut." },
    { "type": "image_picker", "id": "bottom_image", "label": "Image" },
    { "type": "range", "id": "bottom_height", "label": "Overlay max height", "min": 60, "max": 700, "step": 10, "unit": "px", "default": 360 },
    { "type": "range", "id": "bottom_shift", "label": "Push image down", "min": 0, "max": 300, "step": 10, "unit": "px", "default": 0, "info": "Slides the image below the section edge so less of it stays visible." },
    { "type": "checkbox", "id": "hide_bottom_mobile", "label": "Hide on mobile (avoids a 2nd product image)", "default": true },

    { "type": "header", "content": "Decoration" },
    { "type": "checkbox", "id": "show_deco", "label": "Show ring, crosshairs & corner text", "default": true },
    { "type": "textarea", "id": "corner_text", "label": "Corner text", "default": "K // 26\nApparel div.\nBuilt for now." },

    { "type": "header", "content": "Style" },
    { "type": "checkbox", "id": "text_grain", "label": "Grain on text", "default": true },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#f4f1ea" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#111111" },
    { "type": "color", "id": "muted_color", "label": "Muted color", "default": "#666666" },
    { "type": "color", "id": "accent_color", "label": "Accent (red) color", "default": "#560B1E" },
    { "type": "range", "id": "title_size", "label": "Title size", "min": 32, "max": 110, "step": 2, "unit": "px", "default": 64 },
    { "type": "range", "id": "max_width", "label": "Max width", "min": 1200, "max": 1900, "step": 20, "unit": "px", "default": 1820 },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 56 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 400, "step": 10, "unit": "px", "default": 200 },

    { "type": "header", "content": "Appearance" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature icon",
      "settings": [
        { "type": "image_picker", "id": "icon", "label": "Icon" },
        { "type": "text", "id": "label", "label": "Label", "default": "Performance fit" }
      ]
    },
    {
      "type": "tab",
      "name": "Info tab",
      "settings": [
        { "type": "image_picker", "id": "icon", "label": "Icon (optional)" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Описание" },
        { "type": "richtext", "id": "body", "label": "Text" },
        { "type": "textarea", "id": "table", "label": "Size table (optional)", "info": "One row per line; separate cells with | . The first row is the header." },
        { "type": "checkbox", "id": "open", "label": "Open by default", "default": false }
      ]
    }
  ],
  "max_blocks": 20,
  "enabled_on": { "templates": ["product"] },
  "presets": [
    {
      "name": "Product hero",
      "category": "t:categories.products",
