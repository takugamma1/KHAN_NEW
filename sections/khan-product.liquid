{% liquid
  assign s = section.settings
  assign p = product
  if p == blank
    assign p = s.product_fallback
  endif
  assign cur = p.selected_or_first_available_variant
  assign media_count = p.media.size
  assign insp_alt = s.insp_expanded_heading | default: s.insp_heading
%}

<div
  id="KhanProduct-{{ section.id }}"
  class="khan-product color-{{ s.color_scheme }}{% if s.text_grain %} khan-product--grain{% endif %}{% if s.hide_bottom_mobile %} khan-product--hide-bottom-m{% endif %}"
  style="
    --kp-bg: {{ s.bg_color }};
    --kp-text: {{ s.text_color }};
    --kp-accent: {{ s.accent_color }};
    --kp-muted: {{ s.muted_color }};
    --kp-title-size: {{ s.title_size }}px;
    --kp-maxw: {{ s.max_width }}px;
    --kp-pt: {{ s.padding_top }}px;
    --kp-pb: {{ s.padding_bottom }}px;
    --kp-bottom-h: {{ s.bottom_height }}px;
    --kp-grain: url('{{ 'khan-grain.png' | asset_url }}');
  "
  data-khan-product
>
  {%- if s.show_deco -%}
    <span class="khan-product__corner" aria-hidden="true">{{ s.corner_text }}</span>
    <img class="khan-product__deco-ast" src="{{ 'asterisk.png' | asset_url }}" alt="" width="258" height="320" loading="lazy">
    <span class="khan-product__cross khan-product__cross--1" aria-hidden="true"></span>
    <span class="khan-product__cross khan-product__cross--2" aria-hidden="true"></span>
  {%- endif -%}

  <div class="khan-product__inner">
    {%- if p != blank -%}
      <div class="khan-product__grid">

        {%- comment -%} ===== gallery ===== {%- endcomment -%}
        <div class="khan-product__thumbs">
          {%- for media in p.media limit: 6 -%}
            <button type="button" class="khan-product__thumb{% if forloop.first %} is-active{% endif %}" data-i="{{ forloop.index }}" data-full="{{ media | image_url: width: 1600 }}" aria-label="View image {{ forloop.index }}">
              {{ media | image_url: width: 220 | image_tag: loading: 'lazy', widths: '110, 220', alt: '' }}
            </button>
          {%- endfor -%}
        </div>

        <div class="khan-product__stage">
          <span class="khan-product__ring" aria-hidden="true"></span>
          <div class="khan-product__main">
            {%- if p.featured_media != blank -%}
              <img data-main-image src="{{ p.featured_media | image_url: width: 1600 }}" alt="{{ p.featured_media.alt | default: p.title }}" width="{{ p.featured_media.width }}" height="{{ p.featured_media.height }}" loading="eager">
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'khan-product__ph' }}
            {%- endif -%}
          </div>
        </div>

        {%- comment -%} ===== info / buy ===== {%- endcomment -%}
        <div class="khan-product__info">
          <p class="khan-product__count"><span data-counter>01</span> / {% if media_count < 10 %}0{% endif %}{{ media_count | default: 1 }}</p>

          <h1 class="khan-product__title">{{ p.title | default: 'Product title' }}</h1>
          {%- if s.tagline != blank -%}<p class="khan-product__tagline">{{ s.tagline }}</p>{%- endif -%}
          <span class="khan-product__rule" aria-hidden="true"></span>

          {%- if s.description != blank -%}
            <div class="khan-product__desc">{{ s.description }}</div>
          {%- elsif p.description != blank -%}
            <div class="khan-product__desc">{{ p.description }}</div>
          {%- endif -%}

          {%- if s.show_inspiration and s.insp_heading != blank -%}
            <details class="khan-product__insp"{% if s.insp_open %} open{% endif %}>
              <summary class="khan-product__insp-summary">
                <span class="khan-product__insp-head">
                  <span class="khan-product__insp-title">{{ s.insp_heading }}</span>
                  <span class="khan-product__insp-toggle">
                    <span class="khan-product__insp-lbl khan-product__insp-lbl--show">{{ s.insp_toggle_label | default: 'See inspiration' }}</span>
                    <span class="khan-product__insp-lbl khan-product__insp-lbl--hide">{{ s.insp_hide_label | default: 'Hide' }}</span>
                    <span class="khan-product__insp-caret" aria-hidden="true"></span>
                  </span>
                </span>
                {%- if s.insp_intro != blank -%}<span class="khan-product__insp-intro">{{ s.insp_intro | newline_to_br }}</span>{%- endif -%}
              </summary>
              <div class="khan-product__insp-reveal">
                {%- if s.insp_expanded_text != blank -%}<div class="khan-product__insp-extext">{{ s.insp_expanded_text }}</div>{%- endif -%}
                {%- if s.insp_expanded_heading != blank -%}<p class="khan-product__insp-exhead">{{ s.insp_expanded_heading }}</p>{%- endif -%}
                {%- if s.insp_image != blank -%}
                  {{ s.insp_image | image_url: width: 1200 | image_tag: class: 'khan-product__insp-img', loading: 'lazy', widths: '400, 700, 1000, 1200', sizes: '(max-width: 749px) 88vw, 38vw', alt: insp_alt }}
                {%- endif -%}
              </div>
            </details>
          {%- endif -%}

          {%- assign feats = section.blocks | where: 'type', 'feature' -%}
          {%- if feats.size > 0 -%}
            <div class="khan-product__feats">
              {%- for block in feats -%}
                <div class="khan-product__feat" {{ block.shopify_attributes }}>
                  {%- if block.settings.icon != blank -%}
                    <img class="khan-product__feat-icon" src="{{ block.settings.icon | image_url: width: 120 }}" alt="" width="40" height="40" loading="lazy">
                  {%- endif -%}
                  <span class="khan-product__feat-label">{{ block.settings.label }}</span>
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}

          {%- form 'product', p, id: 'khan-pf', class: 'khan-product__form', novalidate: 'novalidate' -%}
            <input type="hidden" name="id" value="{{ cur.id }}" data-variant-input>

            {%- if p.variants.size > 1 -%}
              <p class="khan-product__size-label">Size</p>
              <div class="khan-product__sizes" role="group" aria-label="Size">
                {%- for v in p.variants -%}
                  <button
                    type="button"
                    class="khan-product__size{% if v.id == cur.id %} is-selected{% endif %}{% unless v.available %} is-soldout{% endunless %}"
                    data-variant="{{ v.id }}"
                    data-price="{{ v.price | money }}"
                    data-available="{{ v.available }}"
                  >{{ v.title }}</button>
                {%- endfor -%}
              </div>
            {%- endif -%}

            {%- if s.size_guide_link != blank -%}
              <a class="khan-product__guide" href="{{ s.size_guide_link }}">Size guide</a>
            {%- endif -%}

            <p class="khan-product__price"><span data-price>{{ cur.price | money }}</span></p>

            <button type="submit" name="add" class="khan-product__atc" data-atc {% unless cur.available %}disabled{% endunless %}>
              <span data-atc-text>{% if cur.available %}Add to cart{% else %}Sold out{% endif %}</span><span class="khan-product__atc-plus" aria-hidden="true">+</span>
            </button>
            <button type="button" class="khan-product__buynow" data-buynow {% unless cur.available %}disabled{% endunless %}>
              <span>Buy now</span><span aria-hidden="true">→</span>
            </button>
          {%- endform -%}

          {%- assign info_tabs = section.blocks | where: 'type', 'tab' -%}
          {%- if info_tabs.size > 0 -%}
            <div class="khan-product__tabs">
              {%- for block in info_tabs -%}
                <details class="khan-product__tab"{% if block.settings.open %} open{% endif %} {{ block.shopify_attributes }}>
                  <summary class="khan-product__tab-head">
                    {%- if block.settings.icon != blank -%}<img class="khan-product__tab-icon" src="{{ block.settings.icon | image_url: width: 60 }}" alt="" width="18" height="18" loading="lazy">{%- endif -%}
                    <span class="khan-product__tab-title">{{ block.settings.heading }}</span>
                    <span class="khan-product__tab-sign" aria-hidden="true"></span>
                  </summary>
                  {%- if block.settings.body != blank or block.settings.table != blank -%}
                  <div class="khan-product__tab-body">
                    {%- if block.settings.body != blank -%}<div class="khan-product__tab-text">{{ block.settings.body }}</div>{%- endif -%}
                    {%- if block.settings.table != blank -%}
                      {%- assign tab_rows = block.settings.table | strip | newline_to_br | split: '<br />' -%}
                      <table class="khan-product__tab-table">
                        {%- assign header_done = false -%}
                        {%- for row in tab_rows -%}
                          {%- assign cells = row | strip | split: '|' -%}
                          {%- if row != blank and cells.size > 0 -%}
                            <tr>
                              {%- for c in cells -%}
                                {%- if header_done -%}<td>{{ c | strip }}</td>{%- else -%}<th>{{ c | strip }}</th>{%- endif -%}
                              {%- endfor -%}
                            </tr>
                            {%- assign header_done = true -%}
                          {%- endif -%}
                        {%- endfor -%}
                      </table>
                    {%- endif -%}
                  </div>
                  {%- endif -%}
                </details>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      </div>
    {%- else -%}
      <p class="khan-product__empty">Add this section to a product page (or pick a fallback product in the section settings) to preview it.</p>
    {%- endif -%}
  </div>

  {%- if s.bottom_image != blank -%}
    <div class="khan-product__bottom" aria-hidden="true">
      {{ s.bottom_image | image_url: width: 2600 | image_tag: class: 'khan-product__bottom-img', loading: 'lazy', widths: '800, 1200, 1600, 2000, 2600', sizes: '100vw', alt: '' }}
    </div>
  {%- endif -%}
</div>

<script>
  (function () {
    var root = document.getElementById('KhanProduct-{{ section.id }}');
    if (!root) return;

    // gallery
    var main = root.querySelector('[data-main-image]');
    var counter = root.querySelector('[data-counter]');
    function pad(n) { return n < 10 ? '0' + n : '' + n; }
    root.querySelectorAll('.khan-product__thumb').forEach(function (t) {
      t.addEventListener('click', function () {
        var full = t.getAttribute('data-full');
        if (main && full) main.src = full;
        root.querySelectorAll('.khan-product__thumb').forEach(function (x) { x.classList.remove('is-active'); });
        t.classList.add('is-active');
        if (counter) counter.textContent = pad(parseInt(t.getAttribute('data-i'), 10));
      });
    });

    // variants
    var input = root.querySelector('[data-variant-input]');
    var priceEl = root.querySelector('[data-price]');
    var atc = root.querySelector('[data-atc]');
    var atcText = root.querySelector('[data-atc-text]');
    var buynow = root.querySelector('[data-buynow]');
    root.querySelectorAll('.khan-product__size').forEach(function (b) {
      b.addEventListener('click', function () {
        root.querySelectorAll('.khan-product__size').forEach(function (x) { x.classList.remove('is-selected'); });
        b.classList.add('is-selected');
        if (input) input.value = b.getAttribute('data-variant');
        if (priceEl) priceEl.textContent = b.getAttribute('data-price');
        var avail = b.getAttribute('data-available') === 'true';
        if (atc) { atc.disabled = !avail; if (atcText) atcText.textContent = avail ? 'Add to cart' : 'Sold out'; }
        if (buynow) buynow.disabled = !avail;
      });
    });

    // buy now -> add then go to checkout
    if (buynow && input) {
      buynow.addEventListener('click', function () {
        buynow.disabled = true;
        fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: input.value, quantity: 1 })
        }).then(function () { window.location.href = '/checkout'; })
          .catch(function () { buynow.disabled = false; });
      });
    }
  })();
</script>

{% stylesheet %}
  .khan-product {
    position: relative;
    background: var(--kp-bg, #f4f1ea);
    padding-block: var(--kp-pt, 56px) var(--kp-pb, 200px);
    padding-inline: clamp(20px, 4vw, 64px);
    overflow: hidden;
    isolation: isolate;
  }
  .khan-product__inner { position: relative; z-index: 2; max-width: min(var(--kp-maxw, 1820px), 100%); margin-inline: auto; }

  .khan-product__grid {
    display: grid;
    grid-template-columns: 96px minmax(0, 1.25fr) minmax(0, 0.85fr);
    gap: clamp(24px, 3vw, 56px);
    align-items: center;
  }

  /* mono helper */
  .khan-product__count, .khan-product__tagline, .khan-product__desc, .khan-product__feat-label,
  .khan-product__size-label, .khan-product__size, .khan-product__guide, .khan-product__price,
  .khan-product__atc, .khan-product__buynow, .khan-product__corner {
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
  }

  /* ---- thumbs ---- */
  .khan-product__thumbs { display: flex; flex-direction: column; gap: 14px; }
  .khan-product__thumb { padding: 0; border: 1px solid rgb(0 0 0 / 0.14); background: #fff; cursor: pointer; aspect-ratio: 1; overflow: hidden; }
  .khan-product__thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .khan-product__thumb.is-active { border-color: var(--kp-accent, #d8232a); }

  /* ---- stage ---- */
  .khan-product__stage { position: relative; display: flex; align-items: center; justify-content: center; }
  .khan-product__ring {
    position: absolute; width: min(86%, 620px); aspect-ratio: 1; border-radius: 50%;
    border: 1px dashed rgb(0 0 0 / 0.22); pointer-events: none;
  }
  .khan-product__ring::after {
    content: ""; position: absolute; inset: 8%; border-radius: 50%; border: 1px solid rgb(216 35 42 / 0.18);
  }
  .khan-product__main { position: relative; z-index: 1; width: 100%; }
  .khan-product__main img, .khan-product__ph { width: 100%; height: auto; display: block; object-fit: contain; max-height: 78svh; }

  /* ---- info ---- */
  .khan-product__count { margin: 0 0 18px; font-size: 14px; letter-spacing: 0.2em; color: var(--kp-accent, #d8232a); }
  .khan-product__title {
    margin: 0; font-family: 'Nexa', var(--font-heading--family, sans-serif); font-weight: 900;
    font-size: min(var(--kp-title-size, 64px), 7vw); line-height: 0.92; letter-spacing: -0.01em;
    text-transform: uppercase; color: var(--kp-text, #111);
  }
  .khan-product__tagline { margin: 12px 0 0; font-size: 14px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--kp-accent, #d8232a); }
  .khan-product__rule { display: block; height: 1px; background: rgb(0 0 0 / 0.2); margin: 22px 0; }
  .khan-product__desc { font-size: 14px; line-height: 1.7; letter-spacing: 0.02em; text-transform: uppercase; color: var(--kp-text, #1a1a1a); }
  .khan-product__desc p { margin: 0 0 0.4em; }

  .khan-product__feats { display: flex; flex-wrap: wrap; gap: 18px 28px; margin: 28px 0; }
  .khan-product__feat { display: flex; flex-direction: column; align-items: center; gap: 8px; text-align: center; }
  .khan-product__feat-icon { width: 40px; height: 40px; object-fit: contain; }
  .khan-product__feat-label { font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--kp-muted, #555); max-width: 90px; }

  /* ---- size + buy ---- */
  .khan-product__size-label { margin: 8px 0 12px; font-size: 13px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--kp-muted, #555); }
  .khan-product__sizes { display: flex; border: 1px solid rgb(0 0 0 / 0.16); width: fit-content; max-width: 100%; flex-wrap: wrap; }
  .khan-product__size { min-width: 56px; padding: 13px 14px; background: transparent; border: 0; border-right: 1px solid rgb(0 0 0 / 0.16); cursor: pointer; font-size: 13px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--kp-text, #111); }
  .khan-product__size:last-child { border-right: 0; }
  .khan-product__size.is-selected { background: #111; color: #fff; }
  .khan-product__size.is-soldout { opacity: 0.4; text-decoration: line-through; }

  .khan-product__guide { display: inline-block; margin: 16px 0 0; font-size: 12px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--kp-text, #111); }
  .khan-product__price { margin: 18px 0 14px; font-size: 18px; letter-spacing: 0.06em; color: var(--kp-text, #111); }

  .khan-product__atc, .khan-product__buynow {
    position: relative; display: flex; align-items: center; justify-content: center; width: 100%;
    padding: 18px; font-size: 14px; letter-spacing: 0.22em; text-transform: uppercase; cursor: pointer;
  }
  .khan-product__atc { background: #111; color: #fff; border: 0; }
  .khan-product__atc:hover { background: #000; }
  .khan-product__atc-plus { position: absolute; right: 18px; color: var(--kp-accent, #d8232a); }
  .khan-product__buynow { margin-top: 12px; background: transparent; color: var(--kp-text, #111); border: 1px solid rgb(0 0 0 / 0.3); gap: 14px; }
  .khan-product__buynow:hover { border-color: #111; }
  .khan-product__atc[disabled], .khan-product__buynow[disabled] { opacity: 0.45; cursor: not-allowed; }

  /* ---- bottom overlay image (bleeds up over the section's lower edge) ---- */
  .khan-product__bottom { position: absolute; left: 0; right: 0; bottom: 0; z-index: 3; pointer-events: none; line-height: 0; }
  .khan-product__bottom-img { display: block; width: 100%; height: auto; max-height: var(--kp-bottom-h, 360px); object-fit: cover; object-position: bottom center; }

  /* ---- decorations ---- */
  .khan-product__corner { position: absolute; left: 28px; bottom: calc(var(--kp-bottom-h, 360px) + 16px); z-index: 2; font-size: 11px; line-height: 1.5; letter-spacing: 0.16em; text-transform: uppercase; color: var(--kp-muted, #888); white-space: pre-line; }
  .khan-product__deco-ast { position: absolute; right: 4%; top: 26%; width: 22px; height: 22px; object-fit: contain; z-index: 2; }
  .khan-product__cross { position: absolute; z-index: 1; width: 16px; height: 16px; }
  .khan-product__cross::before, .khan-product__cross::after { content: ""; position: absolute; background: var(--kp-accent, #d8232a); opacity: 0.6; }
  .khan-product__cross::before { left: 50%; top: 0; bottom: 0; width: 1px; transform: translateX(-50%); }
  .khan-product__cross::after { top: 50%; left: 0; right: 0; height: 1px; transform: translateY(-50%); }
  .khan-product__cross--1 { left: 6%; top: 10%; }
  .khan-product__cross--2 { right: 30%; bottom: calc(var(--kp-bottom-h, 360px) + 8%); }

  /* ---- grain ---- */
  .khan-product--grain :is(.khan-product__title, .khan-product__tagline, .khan-product__desc, .khan-product__count, .khan-product__feat-label) {
    -webkit-mask-image: var(--kp-grain); mask-image: var(--kp-grain);
    -webkit-mask-size: 170px 170px; mask-size: 170px 170px;
  }

  /* ---- inspiration disclosure (dark panel) ---- */
  .khan-product__insp { margin: 22px 0 4px; background: #0d0d0d; color: #f1f1f1; border: 1px solid rgb(255 255 255 / 0.08); border-radius: 14px; overflow: hidden; }
  .khan-product__insp-summary { list-style: none; cursor: pointer; display: block; padding: 18px 20px; }
  .khan-product__insp-summary::-webkit-details-marker { display: none; }
  .khan-product__insp-head { display: flex; align-items: center; justify-content: space-between; gap: 14px; }
  .khan-product__insp-title { font-family: ui-monospace, "SFMono-Regular", Menlo, monospace; font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase; color: #cfcfcf; }
  .khan-product__insp-toggle { display: inline-flex; align-items: center; gap: 8px; border: 1px solid rgb(255 255 255 / 0.28); border-radius: 8px; padding: 8px 13px; font-family: ui-monospace, monospace; font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: #fff; white-space: nowrap; transition: border-color 0.2s ease, background 0.2s ease; }
  .khan-product__insp-summary:hover .khan-product__insp-toggle { border-color: var(--kp-accent, #d8232a); }
  .khan-product__insp-lbl--hide { display: none; }
  .khan-product__insp[open] .khan-product__insp-lbl--show { display: none; }
  .khan-product__insp[open] .khan-product__insp-lbl--hide { display: inline; }
  .khan-product__insp-caret { width: 7px; height: 7px; border-right: 1.5px solid currentColor; border-bottom: 1.5px solid currentColor; transform: rotate(45deg); transition: transform 0.25s ease; }
  .khan-product__insp[open] .khan-product__insp-caret { transform: rotate(-135deg); }
  .khan-product__insp-intro { display: block; margin-top: 14px; font-family: ui-monospace, monospace; font-size: 12.5px; line-height: 1.6; letter-spacing: 0.02em; color: #b6b6b6; text-transform: none; }
  .khan-product__insp-intro p { margin: 0; }
  .khan-product__insp-reveal { padding: 0 20px 22px; }
  .khan-product__insp-extext { font-family: ui-monospace, monospace; font-size: 12.5px; line-height: 1.6; color: #b6b6b6; }
  .khan-product__insp-extext p { margin: 0 0 8px; }
  .khan-product__insp-exhead { margin: 16px 0 12px; padding-top: 16px; border-top: 1px solid rgb(255 255 255 / 0.12); font-family: 'Nexa', var(--font-heading--family, sans-serif); font-weight: 900; font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; color: #fff; }
  .khan-product__insp-img { display: block; width: 100%; height: auto; border: 1px solid rgb(255 255 255 / 0.14); border-radius: 8px; background: #fff; }

  /* ---- info tabs (accordions) ---- */
  .khan-product__tabs { margin-top: 28px; border-top: 1px solid rgb(0 0 0 / 0.14); }
  .khan-product__tab { border-bottom: 1px solid rgb(0 0 0 / 0.14); }
  .khan-product__tab-head { list-style: none; cursor: pointer; display: flex; align-items: center; gap: 12px; padding: 18px 2px; font-family: ui-monospace, monospace; font-size: 13px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--kp-text, #111); }
  .khan-product__tab-head::-webkit-details-marker { display: none; }
  .khan-product__tab-icon { width: 18px; height: 18px; object-fit: contain; flex: 0 0 auto; }
  .khan-product__tab-title { flex: 1 1 auto; }
  .khan-product__tab-sign { position: relative; width: 13px; height: 13px; flex: 0 0 auto; transition: transform 0.25s ease; }
  .khan-product__tab-sign::before, .khan-product__tab-sign::after { content: ""; position: absolute; background: var(--kp-text, #111); }
  .khan-product__tab-sign::before { left: 0; right: 0; top: 50%; height: 1.5px; transform: translateY(-50%); }
  .khan-product__tab-sign::after { top: 0; bottom: 0; left: 50%; width: 1.5px; transform: translateX(-50%); }
  .khan-product__tab[open] .khan-product__tab-sign { transform: rotate(45deg); }
  .khan-product__tab-body { padding: 0 2px 22px; overflow-x: auto; -webkit-overflow-scrolling: touch; }
  .khan-product__tab-text { font-family: ui-monospace, monospace; font-size: 13px; line-height: 1.7; letter-spacing: 0.02em; color: var(--kp-muted, #555); }
  .khan-product__tab-text p { margin: 0 0 8px; }
  .khan-product__tab-text p:last-child { margin-bottom: 0; }
  .khan-product__tab-table { width: 100%; min-width: max-content; border-collapse: collapse; margin-top: 6px; font-family: ui-monospace, monospace; font-size: 12.5px; }
  .khan-product__tab-table th, .khan-product__tab-table td { text-align: left; padding: 9px 8px; border-bottom: 1px solid rgb(0 0 0 / 0.1); letter-spacing: 0.04em; }
  .khan-product__tab-table th { color: var(--kp-text, #111); text-transform: uppercase; font-size: 11px; letter-spacing: 0.1em; border-bottom-color: rgb(0 0 0 / 0.24); }
  .khan-product__tab-table td { color: var(--kp-muted, #666); }
  .khan-product__tab-table tr:last-child th, .khan-product__tab-table tr:last-child td { border-bottom: 0; }

  /* ---- responsive ---- */
  @media screen and (max-width: 1100px) {
    .khan-product__grid { grid-template-columns: 80px minmax(0, 1fr); }
    .khan-product__info { grid-column: 1 / -1; }
  }
  @media screen and (max-width: 749px) {
    .khan-product { padding-bottom: 140px; }
    .khan-product__grid { grid-template-columns: 1fr; }
    .khan-product__thumbs { flex-direction: row; order: 2; }
    .khan-product__corner, .khan-product__deco-ast { display: none; }
    /* avoid a second product image stacked under the hero on phones */
    .khan-product--hide-bottom-m { padding-bottom: 48px; }
    .khan-product--hide-bottom-m .khan-product__bottom { display: none; }
    .khan-product__insp-summary { padding: 16px; }
    .khan-product__insp-reveal { padding: 0 16px 18px; }
    .khan-product__insp-head { flex-wrap: wrap; gap: 10px; min-width: 0; }
    .khan-product__insp-toggle { white-space: normal; max-width: 100%; }
    .khan-product__tab-table th, .khan-product__tab-table td { padding: 8px 6px; }
  }
{% endstylesheet %}

{% schema %}
