{% liquid
  assign s = section.settings
%}

<div
  id="KhanFaq-{{ section.id }}"
  class="khan-faq color-{{ s.color_scheme }}"
  style="
    --faq-bg: {{ s.bg_color }};
    --faq-text: {{ s.text_color }};
    --faq-muted: {{ s.muted_color }};
    --faq-accent: {{ s.accent_color }};
    --faq-maxw: {{ s.max_width }}px;
    --faq-pt: {{ s.padding_top }}px;
    --faq-pb: {{ s.padding_bottom }}px;
    --faq-q-size: {{ s.question_size }}px;
    --faq-a-size: {{ s.answer_size }}px;
  "
  data-khan-faq
>
  <div class="khan-faq__inner">
    {%- if s.eyebrow != blank -%}
      <p class="khan-faq__eyebrow">{{ s.eyebrow }}</p>
    {%- endif -%}
    {%- if s.heading != blank -%}
      <h1 class="khan-faq__heading">{{ s.heading }}</h1>
    {%- endif -%}
    {%- if s.intro != blank -%}
      <div class="khan-faq__intro">{{ s.intro }}</div>
    {%- endif -%}

    <div class="khan-faq__list">
      {%- for block in section.blocks -%}
        <details class="khan-faq__item" style="--faq-i: {{ forloop.index0 }};" {{ block.shopify_attributes }}>
          <summary class="khan-faq__q">
            <span class="khan-faq__num">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
            <span class="khan-faq__q-text">{{ block.settings.question }}</span>
            <span class="khan-faq__toggle" aria-hidden="true"></span>
          </summary>
          <div class="khan-faq__a-wrap">
            <div class="khan-faq__a">{{ block.settings.answer }}</div>
          </div>
        </details>
      {%- endfor -%}
    </div>
  </div>
</div>

<script>
  (function () {
    var root = document.getElementById('KhanFaq-{{ section.id }}');
    if (!root) return;

    // smooth open/close: animate the answer wrapper's grid row
    root.querySelectorAll('.khan-faq__item').forEach(function (item) {
      var summary = item.querySelector('.khan-faq__q');
      summary.addEventListener('click', function (e) {
        e.preventDefault();
        if (item.open) {
          item.classList.remove('is-open');
          window.setTimeout(function () { item.open = false; }, 320);
        } else {
          item.open = true;
          window.requestAnimationFrame(function () { item.classList.add('is-open'); });
        }
      });
    });

    // staggered reveal on scroll
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches || !('IntersectionObserver' in window)) {
      root.classList.add('khan-faq--in');
      return;
    }
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (en) {
        if (en.isIntersecting) { root.classList.add('khan-faq--in'); io.disconnect(); }
      });
    }, { threshold: 0 });
    io.observe(root);
    window.setTimeout(function () {
      var r = root.getBoundingClientRect();
      if (r.top < window.innerHeight && r.bottom > 0) root.classList.add('khan-faq--in');
    }, 1500);
    document.addEventListener('shopify:section:select', function (e) {
      if (e.detail && e.detail.sectionId === '{{ section.id }}') root.classList.add('khan-faq--in');
    });
  })();
</script>

{% stylesheet %}
  .khan-faq {
    background: var(--faq-bg, #ffffff);
    padding: var(--faq-pt, 140px) clamp(20px, 5vw, 64px) var(--faq-pb, 96px);
  }
  .khan-faq__inner { max-width: var(--faq-maxw, 880px); margin-inline: auto; }

  .khan-faq__eyebrow {
    margin: 0 0 14px;
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: 12px; letter-spacing: 0.24em; text-transform: uppercase;
    color: var(--faq-accent, #560B1E);
  }
  .khan-faq__heading {
    margin: 0 0 16px;
    font-family: 'Nexa', var(--font-heading--family, sans-serif); font-weight: 900;
    font-size: clamp(32px, 5vw, 56px); line-height: 0.96; letter-spacing: -0.01em;
    text-transform: uppercase; color: var(--faq-text, #111);
  }
  .khan-faq__intro {
    margin: 0 0 34px; max-width: 56ch;
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: 13px; line-height: 1.7; letter-spacing: 0.04em; color: var(--faq-muted, #6f6f6f);
  }

  .khan-faq__list { border-top: 1px solid rgb(0 0 0 / 0.14); }

  .khan-faq__item {
    border-bottom: 1px solid rgb(0 0 0 / 0.14);
    /* reveal animation */
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 0.7s cubic-bezier(0.2, 0.7, 0.2, 1), transform 0.7s cubic-bezier(0.2, 0.7, 0.2, 1);
    transition-delay: calc(var(--faq-i, 0) * 90ms);
  }
  .khan-faq--in .khan-faq__item { opacity: 1; transform: none; }

  .khan-faq__q {
    list-style: none;
    display: flex;
    align-items: center;
    gap: clamp(14px, 2.4vw, 26px);
    padding: clamp(18px, 2.6vw, 26px) 2px;
    cursor: pointer;
    -webkit-user-select: none; user-select: none;
  }
  .khan-faq__q::-webkit-details-marker { display: none; }

  .khan-faq__num {
    flex: 0 0 auto;
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: 11px; letter-spacing: 0.2em;
    color: var(--faq-accent, #560B1E);
  }
  .khan-faq__num::after { content: " /"; opacity: 0.6; }
  .khan-faq__q-text {
    flex: 1 1 auto; min-width: 0;
    font-family: 'Nexa', var(--font-heading--family, sans-serif); font-weight: 900;
    font-size: var(--faq-q-size, 17px); letter-spacing: 0.04em; text-transform: uppercase;
    color: var(--faq-text, #111);
    transition: color 0.2s ease;
  }
  .khan-faq__q:hover .khan-faq__q-text { color: var(--faq-accent, #560B1E); }

  /* plus that rotates into a minus */
  .khan-faq__toggle { position: relative; flex: 0 0 auto; width: 16px; height: 16px; }
  .khan-faq__toggle::before,
  .khan-faq__toggle::after {
    content: ""; position: absolute; background: var(--faq-accent, #560B1E);
    transition: transform 0.32s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .khan-faq__toggle::before { left: 50%; top: 0; bottom: 0; width: 2px; transform: translateX(-50%); }
  .khan-faq__toggle::after { top: 50%; left: 0; right: 0; height: 2px; transform: translateY(-50%); }
  .khan-faq__item.is-open .khan-faq__toggle::before { transform: translateX(-50%) rotate(90deg) scaleY(0); }
  .khan-faq__item.is-open .khan-faq__toggle::after { transform: translateY(-50%) rotate(180deg); }

  /* smooth height animation via grid rows */
  .khan-faq__a-wrap {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.34s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .khan-faq__item.is-open .khan-faq__a-wrap { grid-template-rows: 1fr; }
  .khan-faq__a {
    overflow: hidden;
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: var(--faq-a-size, 13px); line-height: 1.75; letter-spacing: 0.04em;
    color: var(--faq-muted, #6f6f6f);
    max-width: 68ch;
  }
  .khan-faq__item.is-open .khan-faq__a { padding-bottom: clamp(18px, 2.6vw, 26px); }
  .khan-faq__a :is(p, ul, ol) { margin: 0 0 10px; padding-left: 0; }
  .khan-faq__a :is(ul, ol) { padding-left: 18px; }
  .khan-faq__a :is(strong, b) { color: var(--faq-text, #111); }
  .khan-faq__a a { color: var(--faq-accent, #560B1E); }

  @media (prefers-reduced-motion: reduce) {
    .khan-faq__item { opacity: 1 !important; transform: none !important; transition: none !important; }
    .khan-faq__a-wrap { transition: none !important; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "class": "khan-faq-wrapper section-wrapper",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "FAQ" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Често задавани въпроси." },
    { "type": "richtext", "id": "intro", "label": "Intro" },

    { "type": "header", "content": "Sizes" },
    { "type": "range", "id": "question_size", "label": "Question size", "min": 13, "max": 26, "step": 1, "unit": "px", "default": 17 },
    { "type": "range", "id": "answer_size", "label": "Answer size", "min": 11, "max": 18, "step": 1, "unit": "px", "default": 13 },
    { "type": "range", "id": "max_width", "label": "Max width", "min": 560, "max": 1200, "step": 20, "unit": "px", "default": 880 },

    { "type": "header", "content": "Colors & spacing" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#111111" },
    { "type": "color", "id": "muted_color", "label": "Muted text", "default": "#6f6f6f" },
    { "type": "color", "id": "accent_color", "label": "Accent", "default": "#560B1E" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 240, "step": 4, "unit": "px", "default": 140 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 240, "step": 4, "unit": "px", "default": 96 },

    { "type": "header", "content": "Appearance" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Question",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "Кога ще получа поръчката си?" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Изпращаме до 1 работен ден. Доставката отнема 1–3 работни дни с куриер.</p>" }
      ]
    }
  ],
  "max_blocks": 30,
  "presets": [
    {
      "name": "FAQ",
      "category": "t:categories.storytelling",
      "blocks": [
        { "type": "item", "settings": { "question": "Кога ще получа поръчката си?", "answer": "<p>Изпращаме до 1 работен ден. Доставката отнема 1–3 работни дни с куриер до адрес или офис.</p>" } },
        { "type": "item", "settings": { "question": "Мога ли да върна или заменя продукт?", "answer": "<p>Да — имаш 14 дни право на връщане. Дрехите трябва да са неносени, с етикети. Хранителни добавки се приемат само с неразпечатана опаковка.</p>" } },
        { "type": "item", "settings": { "question": "Как да избера правилния размер?", "answer": "<p>Виж таблицата с размери на всяка продуктова страница. Ако си между два размера, препоръчваме по-големия.</p>" } },
        { "type": "item", "settings": { "question": "Как да приемам pre-workout продукта?", "answer": "<p>Една доза (един скуп) с 300–400 мл вода, 20–30 минути преди тренировка. Не превишавай препоръчителната дневна доза.</p>" } }
      ]
    }
  ]
}
{% endschema %}
