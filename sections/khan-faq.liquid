{% liquid
  assign s = section.settings
%}

<div
  id="KhanFaq-{{ section.id }}"
  class="khan-faq color-{{ s.color_scheme }}{% unless s.show_shadow %} khan-faq--flat{% endunless %}"
  style="
    --faq-bg: {{ s.bg_color }};
    --faq-text: {{ s.text_color }};
    --faq-muted: {{ s.muted_color }};
    --faq-accent: {{ s.accent_color }};
    --faq-bar-bg: {{ s.bar_bg | default: '#ffffff' }};
    --faq-open-text: {{ s.open_text | default: '#ffffff' }};
    --faq-panel-bg: {{ s.panel_bg | default: '#ffffff' }};
    --faq-skew: {{ s.skew | default: -8 }}deg;
    --faq-gap: {{ s.gap | default: 18 }}px;
    --faq-maxw: {{ s.max_width }}px;
    --faq-pt: {{ s.padding_top }}px;
    --faq-pb: {{ s.padding_bottom }}px;
    --faq-q-size: {{ s.question_size }}px;
    --faq-a-size: {{ s.answer_size }}px;
  "
  data-khan-faq
  data-close-others="{% if s.close_others %}true{% else %}false{% endif %}"
>
  <div class="khan-faq__inner">
    {%- if s.eyebrow != blank -%}
      <p class="khan-faq__eyebrow">{{ s.eyebrow }}</p>
    {%- endif -%}
    {%- if s.heading != blank -%}
      <h1 class="khan-faq__heading">{{ s.heading }}</h1>
    {%- endif -%}
    {%- if s.intro != blank -%}
      <div class="khan-faq__intro">{{ s.intro }}</div>
    {%- endif -%}

    <div class="khan-faq__list">
      {%- for block in section.blocks -%}
        <details class="khan-faq__item" style="--faq-i: {{ forloop.index0 }};"{% if block.settings.open %} open{% endif %} {{ block.shopify_attributes }}>
          <summary class="khan-faq__q">
            <span class="khan-faq__bar">
              <span class="khan-faq__bar-inner">
                <span class="khan-faq__q-text">{{ block.settings.question }}</span>
                <span class="khan-faq__caret" aria-hidden="true"></span>
              </span>
            </span>
          </summary>
          <div class="khan-faq__a-wrap">
            <div class="khan-faq__a">{{ block.settings.answer }}</div>
          </div>
        </details>
      {%- endfor -%}
    </div>
  </div>
</div>

<script>
  (function () {
    var root = document.getElementById('KhanFaq-{{ section.id }}');
    if (!root) return;
    var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var closeOthers = root.getAttribute('data-close-others') === 'true';
    var items = [].slice.call(root.querySelectorAll('.khan-faq__item'));

    var OPEN = 340, CLOSE = 260;
    items.forEach(function (d) {
      var summary = d.querySelector(':scope > summary');
      var body = summary && summary.nextElementSibling;
      if (!summary || !body) return;

      function closeD() {
        if (d.dataset.busy || !d.open) return;
        d.dataset.busy = '1';
        var mt = window.getComputedStyle(body).marginTop;
        body.style.overflow = 'hidden';
        body.style.height = body.scrollHeight + 'px'; body.style.opacity = '1'; body.style.marginTop = mt;
        void body.offsetHeight;
        body.style.transition = 'height ' + CLOSE + 'ms cubic-bezier(.4,0,.2,1), opacity ' + CLOSE + 'ms ease, margin-top ' + CLOSE + 'ms cubic-bezier(.4,0,.2,1)';
        body.style.height = '0px'; body.style.opacity = '0'; body.style.marginTop = '0px';
        window.setTimeout(function () {
          d.open = false;
          body.removeAttribute('style');
          delete d.dataset.busy;
        }, CLOSE);
      }
      function openD() {
        if (d.dataset.busy || d.open) return;
        d.dataset.busy = '1';
        d.open = true;
        var mt = window.getComputedStyle(body).marginTop;
        body.style.overflow = 'hidden';
        var to = body.scrollHeight;
        body.style.height = '0px'; body.style.opacity = '0'; body.style.marginTop = '0px';
        void body.offsetHeight;
        body.style.transition = 'height ' + OPEN + 'ms cubic-bezier(.4,0,.2,1), opacity ' + OPEN + 'ms ease, margin-top ' + OPEN + 'ms cubic-bezier(.4,0,.2,1)';
        body.style.height = to + 'px'; body.style.opacity = '1'; body.style.marginTop = mt;
        window.setTimeout(function () {
          body.removeAttribute('style');
          delete d.dataset.busy;
          var r = d.getBoundingClientRect();
          if (r.bottom > window.innerHeight + 2) {
            var fits = r.height <= window.innerHeight - 90;
            d.scrollIntoView({ behavior: 'smooth', block: fits ? 'nearest' : 'start' });
          }
        }, OPEN);
      }
      d.__khanFaqClose = closeD;

      summary.addEventListener('click', function (e) {
        e.preventDefault();
        if (reduce) {
          if (!d.open && closeOthers) items.forEach(function (o) { if (o !== d) o.open = false; });
          d.open = !d.open;
          return;
        }
        if (d.dataset.busy) return;
        if (d.open) { closeD(); return; }
        if (closeOthers) items.forEach(function (o) { if (o !== d && o.open && o.__khanFaqClose) o.__khanFaqClose(); });
        openD();
      });
    });

    // staggered reveal on scroll
    if (reduce || !('IntersectionObserver' in window)) {
      root.classList.add('khan-faq--in');
      return;
    }
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (en) {
        if (en.isIntersecting) { root.classList.add('khan-faq--in'); io.disconnect(); }
      });
    }, { threshold: 0 });
    io.observe(root);
    window.setTimeout(function () {
      var r = root.getBoundingClientRect();
      if (r.top < window.innerHeight && r.bottom > 0) root.classList.add('khan-faq--in');
    }, 1500);
    document.addEventListener('shopify:section:select', function (e) {
      if (e.detail && e.detail.sectionId === '{{ section.id }}') root.classList.add('khan-faq--in');
    });
  })();
</script>

{% stylesheet %}
  .khan-faq {
    background: var(--faq-bg, #efefec);
    padding: var(--faq-pt, 96px) clamp(16px, 5vw, 64px) var(--faq-pb, 96px);
    overflow-x: hidden; /* the skewed bars poke slightly past the column */
  }
  .khan-faq__inner { max-width: var(--faq-maxw, 1100px); margin-inline: auto; }

  .khan-faq__eyebrow {
    margin: 0 0 14px;
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: 12px; letter-spacing: 0.24em; text-transform: uppercase;
    color: var(--faq-accent, #560B1E);
  }
  .khan-faq__heading {
    margin: 0 0 16px;
    font-family: 'Nexa', var(--font-heading--family, sans-serif); font-weight: 900;
    font-size: clamp(32px, 5vw, 56px); line-height: 0.96; letter-spacing: -0.01em;
    text-transform: uppercase; color: var(--faq-text, #111);
  }
  .khan-faq__intro {
    margin: 0 0 34px; max-width: 56ch;
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: 13px; line-height: 1.7; letter-spacing: 0.04em; color: var(--faq-muted, #6f6f6f);
  }

  .khan-faq__item { margin-bottom: var(--faq-gap, 18px); }
  .khan-faq__q { list-style: none; cursor: pointer; display: block; }
  .khan-faq__q::-webkit-details-marker { display: none; }

  /* the slashed bar */
  .khan-faq__bar {
    display: block;
    transform: skewX(var(--faq-skew, -8deg));
    background: var(--faq-bar-bg, #ffffff);
    color: var(--faq-text, #111111);
    box-shadow: 0 8px 22px rgb(0 0 0 / 0.09);
    padding: 17px clamp(18px, 3vw, 34px);
    margin-inline: 12px;
    transition: background 0.25s ease, color 0.25s ease, box-shadow 0.25s ease;
  }
  .khan-faq--flat .khan-faq__bar { box-shadow: none; border: 1px solid rgb(0 0 0 / 0.1); }
  .khan-faq__bar-inner {
    display: flex; align-items: center; justify-content: space-between; gap: 16px;
    transform: skewX(calc(-1 * var(--faq-skew, -8deg)));
  }
  .khan-faq__q-text {
    font-family: 'Nexa', var(--font-heading--family, sans-serif); font-weight: 900;
    font-size: var(--faq-q-size, 17px); letter-spacing: 0.06em; text-transform: uppercase;
    line-height: 1.15;
  }
  .khan-faq__caret {
    flex: 0 0 auto; width: 10px; height: 10px;
    border-right: 2.5px solid currentColor; border-bottom: 2.5px solid currentColor;
    transform: rotate(45deg); margin-top: -4px;
    transition: transform 0.3s ease, margin 0.3s ease;
  }
  .khan-faq__q:hover .khan-faq__bar { box-shadow: 0 10px 26px rgb(0 0 0 / 0.15); }

  /* open: accent bar, flipped caret */
  .khan-faq__item[open] > .khan-faq__q .khan-faq__bar {
    background: var(--faq-accent, #9A1F33);
    color: var(--faq-open-text, #ffffff);
  }
  .khan-faq__item[open] > .khan-faq__q .khan-faq__caret { transform: rotate(225deg); margin-top: 4px; }

  /* answer panel */
  .khan-faq__a-wrap {
    background: var(--faq-panel-bg, #ffffff);
    margin: 10px 12px 0;
    box-sizing: border-box;
  }
  .khan-faq__a {
    padding: clamp(20px, 3vw, 36px) clamp(18px, 3.4vw, 40px);
    color: var(--faq-muted, #444);
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: var(--faq-a-size, 14px); line-height: 1.7; letter-spacing: 0.02em;
  }
  .khan-faq__a :is(h2, h3, h4) {
    margin: 1.4em 0 0.5em;
    font-family: 'Nexa', var(--font-heading--family, sans-serif); font-weight: 900;
    font-size: clamp(17px, 1.8vw, 24px); letter-spacing: 0.04em; text-transform: uppercase;
    color: var(--faq-text, #111);
  }
  .khan-faq__a :is(h2, h3, h4):first-child { margin-top: 0; }
  .khan-faq__a p { margin: 0 0 0.9em; }
  .khan-faq__a p:last-child { margin-bottom: 0; }
  .khan-faq__a strong { color: var(--faq-text, #111); }

  /* staggered entrance */
  .khan-faq__item {
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 0.7s cubic-bezier(0.2, 0.7, 0.2, 1), transform 0.7s cubic-bezier(0.2, 0.7, 0.2, 1);
    transition-delay: calc(var(--faq-i, 0) * 90ms);
  }
  .khan-faq--in .khan-faq__item { opacity: 1; transform: none; }

  @media screen and (max-width: 749px) {
    .khan-faq__bar { padding: 14px 18px; margin-inline: 7px; }
    .khan-faq__a-wrap { margin-inline: 7px; }
    .khan-faq__q-text { font-size: calc(var(--faq-q-size, 17px) * 0.92); }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "class": "khan-faq-wrapper section-wrapper",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "header", "content": "Header" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "richtext", "id": "intro", "label": "Intro", "info": "Shown under the heading." },

    { "type": "header", "content": "Behaviour" },
    { "type": "checkbox", "id": "close_others", "label": "Only one open at a time", "default": true },

    { "type": "header", "content": "Slashed bars" },
    { "type": "range", "id": "skew", "label": "Slash angle", "min": -20, "max": 20, "step": 1, "unit": "°", "default": -8 },
    { "type": "checkbox", "id": "show_shadow", "label": "Bar shadow", "default": true },
    { "type": "range", "id": "gap", "label": "Gap between bars", "min": 8, "max": 40, "step": 2, "unit": "px", "default": 18 },

    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color", "label": "Section background", "default": "#efefec" },
    { "type": "color", "id": "bar_bg", "label": "Bar background", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Bar & heading text", "default": "#111111" },
    { "type": "color", "id": "accent_color", "label": "Open bar / accent", "default": "#9A1F33" },
    { "type": "color", "id": "open_text", "label": "Open bar text", "default": "#ffffff" },
    { "type": "color", "id": "panel_bg", "label": "Answer background", "default": "#ffffff" },
    { "type": "color", "id": "muted_color", "label": "Answer text", "default": "#444444" },

    { "type": "header", "content": "Sizes & spacing" },
    { "type": "range", "id": "question_size", "label": "Bar title size", "min": 13, "max": 28, "step": 1, "unit": "px", "default": 17 },
    { "type": "range", "id": "answer_size", "label": "Answer size", "min": 11, "max": 20, "step": 1, "unit": "px", "default": 14 },
    { "type": "range", "id": "max_width", "label": "Max width", "min": 700, "max": 1600, "step": 20, "unit": "px", "default": 1100 },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 96 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 96 },

    { "type": "header", "content": "Appearance" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Bar",
      "settings": [
        { "type": "text", "id": "question", "label": "Bar title", "default": "Въпрос" },
        { "type": "richtext", "id": "answer", "label": "Content", "default": "<p>Отговор.</p>", "info": "Use headings inside for Q&A style (several questions inside one bar)." },
        { "type": "checkbox", "id": "open", "label": "Open by default", "default": false }
      ]
    }
  ],
  "max_blocks": 20,
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        { "type": "item", "settings": { "question": "Описание", "answer": "<p>Прецизно дозиран пре-уъркаут за чиста, безкомпромисна енергия — остър фокус, по-големи помпи и нула краш. Без пълнители, без компромиси.</p>" } },
        { "type": "item", "settings": { "question": "Как се използва?", "answer": "<h3>Как да използвам KHAN Pre-Workout?</h3><p>Разбъркай една (1) до две (2) дози с 300–400мл вода около 20–30 минути преди тренировка. Така тялото усвоява оптимално всички активни съставки.</p><p>Препоръчваме на нови потребители да започнат с половин доза, за да проверят поносимостта си. Не превишавай препоръчителната дневна доза.</p>" } },
        { "type": "item", "settings": { "question": "Колко кофеин съдържа?", "answer": "<p>Една (1) доза съдържа 180мг кофеин, а две (2) дози — 360мг.</p><p><strong>Внимание:</strong> продуктът е с високо съдържание на кофеин и не е подходящ за деца, бременни и кърмещи жени.</p>" } },
        { "type": "item", "settings": { "question": "Дисклеймър", "answer": "<p>Хранителните добавки не заместват разнообразното хранене и здравословния начин на живот. Съхранявай на сухо и хладно място, далеч от деца.</p>" } }
      ]
    }
  ]
}
{% endschema %}
