{% liquid
  assign s = section.settings
%}

{%- if s.hide_footer -%}<style>footer { display: none !important; }</style>{%- endif -%}
{%- if s.hide_header -%}<style>#header-group, .khan-nav-wrapper { display: none !important; }</style>{%- endif -%}

<div
  id="KhanHub-{{ section.id }}"
  class="khan-hub color-{{ s.color_scheme }}"
  style="
    --hub-bg: {{ s.bg_color }};
    --hub-text: {{ s.text_color }};
    --hub-muted: {{ s.muted_color }};
    --hub-accent: {{ s.accent_color }};
    --hub-btn-bg: {{ s.button_bg }};
    --hub-btn-text: {{ s.button_text }};
    --hub-btn-border: {{ s.button_border }};
    --hub-cols: {{ s.columns }};
    --hub-maxw: {{ s.max_width }}px;
    --hub-prog-track: {{ s.progress_track }};
    --hub-prog-fill: {{ s.progress_fill }};
    --hub-prog-h: {{ s.progress_height }}px;
  "
>
  <div class="khan-hub__inner">
    {%- if s.logo != blank -%}
      <img class="khan-hub__logo" src="{{ s.logo | image_url: width: 600 }}" alt="" width="{{ s.logo.width }}" height="{{ s.logo.height }}">
    {%- endif -%}
    {%- if s.title != blank -%}<h1 class="khan-hub__title">{{ s.title }}</h1>{%- endif -%}
    {%- if s.subtitle != blank -%}<p class="khan-hub__subtitle">{{ s.subtitle }}</p>{%- endif -%}

    <div class="khan-hub__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'link' -%}
          <a class="khan-hub__btn" href="{{ block.settings.url | default: '#' }}" {{ block.shopify_attributes }}>
            <span class="khan-hub__btn-label">{{ block.settings.label }}</span>
            {%- if block.settings.sublabel != blank -%}<span class="khan-hub__btn-sub">{{ block.settings.sublabel }}</span>{%- endif -%}
            {%- if block.settings.show_progress -%}
              <span class="khan-hub__btn-prog">
                <span class="khan-hub__btn-prog-track"><span class="khan-hub__btn-prog-fill" style="width: {{ block.settings.progress }}%;"></span></span>
                <span class="khan-hub__btn-prog-pct">{{ block.settings.progress }}%</span>
              </span>
            {%- endif -%}
            <span class="khan-hub__btn-arrow" aria-hidden="true">→</span>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if s.footnote != blank -%}<p class="khan-hub__foot">{{ s.footnote }}</p>{%- endif -%}
  </div>
</div>

{% stylesheet %}
  .khan-hub {
    min-height: 100svh;
    background: var(--hub-bg, #ffffff);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(40px, 8vw, 96px) clamp(20px, 5vw, 64px);
  }
  .khan-hub__inner { width: 100%; max-width: min(var(--hub-maxw, 880px), 100%); text-align: center; }

  .khan-hub__logo { width: 180px; max-width: 60%; height: auto; display: block; margin: 0 auto 28px; }
  .khan-hub__title {
    margin: 0; font-family: 'Nexa', var(--font-heading--family, sans-serif); font-weight: 900;
    font-size: min(48px, 9vw); line-height: 1; letter-spacing: -0.01em; text-transform: uppercase; color: var(--hub-text, #111);
  }
  .khan-hub__subtitle {
    margin: 14px 0 0; font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: 14px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--hub-muted, #777);
  }

  .khan-hub__grid {
    display: grid;
    grid-template-columns: repeat(var(--hub-cols, 2), minmax(0, 1fr));
    gap: 16px;
    margin-top: clamp(32px, 5vw, 56px);
  }

  .khan-hub__btn {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 4px;
    padding: 22px 56px 22px 24px;
    background: var(--hub-btn-bg, #111);
    color: var(--hub-btn-text, #fff);
    border: 1px solid var(--hub-btn-border, transparent);
    text-decoration: none;
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    text-align: left;
    transition: transform 0.15s ease, background 0.15s ease;
  }
  .khan-hub__btn:hover { transform: translateY(-2px); }
  .khan-hub__btn-label { font-size: 16px; letter-spacing: 0.14em; text-transform: uppercase; }
  .khan-hub__btn-sub { font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; opacity: 0.6; }
  .khan-hub__btn-arrow { position: absolute; right: 22px; top: 50%; transform: translateY(-50%); color: var(--hub-accent, #560B1E); font-size: 20px; }

  .khan-hub__btn-prog { display: flex; align-items: center; gap: 10px; width: 100%; margin-top: 12px; }
  .khan-hub__btn-prog-track { flex: 1; height: var(--hub-prog-h, 4px); background: var(--hub-prog-track, #2a2a2a); border-radius: 999px; overflow: hidden; }
  .khan-hub__btn-prog-fill { display: block; height: 100%; width: 0; background: var(--hub-prog-fill, var(--hub-accent, #560B1E)); border-radius: 999px; transition: width 0.5s ease; }
  .khan-hub__btn-prog-pct { font-size: 11px; letter-spacing: 0.06em; opacity: 0.75; min-width: 36px; text-align: right; font-variant-numeric: tabular-nums; }

  .khan-hub__foot {
    margin: clamp(28px, 4vw, 44px) 0 0;
    font-family: ui-monospace, monospace; font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--hub-muted, #999);
  }

  @media screen and (max-width: 600px) {
    .khan-hub__grid { grid-template-columns: 1fr; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Preview hub",
  "tag": "section",
  "class": "khan-hub-wrapper",
  "settings": [
    { "type": "header", "content": "Header" },
    { "type": "image_picker", "id": "logo", "label": "Logo" },
    { "type": "text", "id": "title", "label": "Title", "default": "Khan — preview" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Select a page to review" },
    { "type": "text", "id": "footnote", "label": "Footnote", "default": "Work in progress — for review only." },

    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "columns", "label": "Buttons per row", "min": 1, "max": 4, "step": 1, "default": 2 },
    { "type": "range", "id": "max_width", "label": "Max width", "min": 480, "max": 1200, "step": 20, "unit": "px", "default": 880 },

    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Title color", "default": "#111111" },
    { "type": "color", "id": "muted_color", "label": "Muted text", "default": "#777777" },
    { "type": "color", "id": "accent_color", "label": "Accent (arrow)", "default": "#560B1E" },
    { "type": "color", "id": "button_bg", "label": "Button background", "default": "#111111" },
    { "type": "color", "id": "button_text", "label": "Button text", "default": "#ffffff" },
    { "type": "color", "id": "button_border", "label": "Button border", "default": "#00000000" },

    { "type": "header", "content": "Progress bars" },
    { "type": "color", "id": "progress_track", "label": "Track color", "default": "#2a2a2a" },
    { "type": "color", "id": "progress_fill", "label": "Fill color", "default": "#560B1E" },
    { "type": "range", "id": "progress_height", "label": "Bar thickness", "min": 2, "max": 12, "step": 1, "unit": "px", "default": 4 },

    { "type": "header", "content": "Appearance" },
    { "type": "checkbox", "id": "hide_header", "label": "Hide header / nav on this page", "default": true },
    { "type": "checkbox", "id": "hide_footer", "label": "Hide theme footer on this page", "default": true },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" }
  ],
  "blocks": [
    {
      "type": "link",
      "name": "Button",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Page" },
        { "type": "text", "id": "sublabel", "label": "Sub-label" },
        { "type": "url", "id": "url", "label": "Link" },
        { "type": "checkbox", "id": "show_progress", "label": "Show progress bar", "default": true },
        { "type": "range", "id": "progress", "label": "Progress", "min": 0, "max": 100, "step": 1, "unit": "%", "default": 0 }
      ]
    }
  ],
  "max_blocks": 16,
  "presets": [
    {
      "name": "Preview hub",
      "blocks": [
        { "type": "link", "settings": { "label": "Home", "sublabel": "Landing", "url": "/", "progress": 100 } },
        { "type": "link", "settings": { "label": "Collection", "sublabel": "Shop grid", "url": "/collections/all", "progress": 75 } },
        { "type": "link", "settings": { "label": "Product", "sublabel": "Product page", "progress": 40 } },
        { "type": "link", "settings": { "label": "About", "sublabel": "Our story", "url": "/pages/about", "progress": 90 } }
      ]
    }
  ]
}
{% endschema %}
