{% liquid
  assign has_video = false
  if section.settings.video != blank
    assign has_video = true
  endif

  assign fetch_priority = 'auto'
  if section.index == 1
    assign fetch_priority = 'high'
  endif
%}

<div
  id="VideoBanner-{{ section.id }}"
  class="
    video-banner color-{{ section.settings.color_scheme }}
    {% if section.settings.bring_to_front %}video-banner--front{% endif %}
    {% if section.settings.custom_mobile_offset %}video-banner--custom-mobile-offset{% endif %}
  "
  style="
    {% if section.settings.section_height == 'custom' %}
      --video-banner-min-height: {{ section.settings.section_height_custom }}svh;
    {% elsif section.settings.section_height == 'full-screen' %}
      --video-banner-min-height: 100svh;
    {% else %}
      --video-banner-min-height: var(--section-height-{{ section.settings.section_height }});
    {% endif %}
    --video-offset-top: {{ section.settings.offset_top }}px;
    --video-offset-bottom: {{ section.settings.offset_bottom }}px;
    --video-offset-top-mobile: {{ section.settings.offset_top_mobile }}px;
    --video-offset-bottom-mobile: {{ section.settings.offset_bottom_mobile }}px;
    --video-banner-align-x: {{ section.settings.horizontal_alignment }};
    --video-banner-align-y: {{ section.settings.vertical_alignment }};
  "
  {% if request.visual_preview_mode %}
    data-shopify-visual-preview
  {% endif %}
>
  {%- comment -%} Background video (autoplay, muted, loop) {%- endcomment -%}
  <div class="video-banner__media" data-testid="video-banner-media">
    {%- if has_video -%}
      {{
        section.settings.video
        | video_tag:
          poster: nil,
          autoplay: section.settings.autoplay,
          loop: section.settings.loop,
          controls: section.settings.show_controls,
          muted: true,
          class: 'video-banner__media-item',
          data-testid: 'video-banner-video'
      }}
    {%- elsif section.settings.poster != blank -%}
      {{
        section.settings.poster
        | image_url: width: 3840
        | image_tag:
          width: section.settings.poster.width,
          widths: '832, 1200, 1600, 1920, 2560, 3840',
          height: section.settings.poster.height,
          alt: section.settings.poster.alt,
          class: 'video-banner__media-item',
          sizes: '100vw',
          fetchpriority: fetch_priority
      }}
    {%- elsif request.design_mode -%}
      {%- comment -%} Editor-only placeholder so an empty section is obvious. Live stays black. {%- endcomment -%}
      {{ 'hero-apparel-1' | placeholder_svg_tag: 'video-banner__media-item' }}
    {%- endif -%}
  </div>

  {%- if section.settings.toggle_overlay -%}
    {% render 'overlay', settings: section.settings, layer: 'var(--layer-flat)' %}
  {%- endif -%}

  {%- comment -%} Optional content (text, button, etc.) {%- endcomment -%}
  <div class="video-banner__content" data-testid="video-banner-content">
    {% content_for 'blocks' %}
  </div>
</div>

{% stylesheet %}
  .video-banner {
    position: relative;
    z-index: var(--layer-flat, 1);
    min-height: var(--video-banner-min-height);
    overflow: hidden;
    display: flex;
    align-items: var(--video-banner-align-y, center);
    justify-content: var(--video-banner-align-x, center);
    background-color: #000;

    /* Negative pulls the section up into the one above (connect seam),
       positive pushes it down. */
    margin-block-start: var(--video-offset-top, 0px);
    margin-block-end: var(--video-offset-bottom, 0px);
  }

  /* Sit on top of neighbouring sections when offsets cause overlap. */
  .video-banner--front {
    z-index: var(--layer-raised, 2);
  }

  .video-banner[data-shopify-visual-preview] {
    min-height: 600px;
  }

  .video-banner__media {
    position: absolute;
    inset: 0;
    z-index: var(--layer-base, 0);
  }

  .video-banner__media-item,
  .video-banner__media img,
  .video-banner__media svg,
  .video-banner__media video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    display: block;
  }

  .video-banner__content {
    position: relative;
    z-index: var(--layer-raised, 2);
    display: flex;
    flex-direction: column;
    align-items: var(--video-banner-align-x, center);
    gap: 12px;
    padding: 24px;
    pointer-events: none;
  }

  .video-banner__content :is(a, button, input, textarea, select, details, summary) {
    pointer-events: auto;
  }

  @media screen and (max-width: 749px) {
    .video-banner--custom-mobile-offset {
      margin-block-start: var(--video-offset-top-mobile, 0px);
      margin-block-end: var(--video-offset-bottom-mobile, 0px);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Video banner",
  "tag": "section",
  "class": "video-banner-wrapper section-wrapper",
  "blocks": [
    { "type": "@theme" },
    { "type": "text" },
    { "type": "button" },
    { "type": "logo" },
    { "type": "group" }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Background video"
    },
    {
      "type": "image_picker",
      "id": "poster",
      "label": "Poster image",
      "info": "Shown before the video loads, or if no video is set."
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": true,
      "info": "Autoplay requires the video to be muted (it is)."
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_controls",
      "label": "Show controls",
      "default": false
    },
    {
      "type": "header",
      "content": "Position / offset",
      "info": "Use negative values to pull the section higher (overlap the section above and connect the seam). Positive values push it lower."
    },
    {
      "type": "range",
      "id": "offset_top",
      "label": "Top offset",
      "min": -600,
      "max": 600,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "offset_bottom",
      "label": "Bottom offset",
      "min": -600,
      "max": 600,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "checkbox",
      "id": "bring_to_front",
      "label": "Bring to front when overlapping",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "custom_mobile_offset",
      "label": "Use different offsets on mobile",
      "default": false
    },
    {
      "type": "range",
      "id": "offset_top_mobile",
      "label": "Top offset (mobile)",
      "min": -600,
      "max": 600,
      "step": 2,
      "unit": "px",
      "default": 0,
      "visible_if": "{{ section.settings.custom_mobile_offset }}"
    },
    {
      "type": "range",
      "id": "offset_bottom_mobile",
      "label": "Bottom offset (mobile)",
      "min": -600,
      "max": 600,
      "step": 2,
      "unit": "px",
      "default": 0,
      "visible_if": "{{ section.settings.custom_mobile_offset }}"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_height",
      "label": "Height",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" },
        { "value": "full-screen", "label": "Full screen" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "large"
    },
    {
      "type": "range",
      "id": "section_height_custom",
      "label": "Custom height",
      "min": 20,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 60,
      "visible_if": "{{ section.settings.section_height == 'custom' }}"
    },
    {
      "type": "select",
      "id": "horizontal_alignment",
      "label": "Content horizontal",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "Content vertical",
      "options": [
        { "value": "flex-start", "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Bottom" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "toggle_overlay",
      "label": "Tint video",
      "default": false
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Tint color",
      "alpha": true,
      "default": "#00000040",
      "visible_if": "{{ section.settings.toggle_overlay }}"
    },
    {
      "type": "select",
      "id": "overlay_style",
      "label": "Tint style",
      "options": [
        { "value": "solid", "label": "Solid" },
        { "value": "gradient", "label": "Gradient" }
      ],
      "default": "solid",
      "visible_if": "{{ section.settings.toggle_overlay }}"
    },
    {
      "type": "select",
      "id": "gradient_direction",
      "label": "Gradient direction",
      "options": [
        { "value": "to top", "label": "Up" },
        { "value": "to bottom", "label": "Down" }
      ],
      "default": "to top",
      "visible_if": "{{ section.settings.toggle_overlay and section.settings.overlay_style == 'gradient' }}"
    }
  ],
  "presets": [
    {
      "name": "Video banner",
      "category": "t:categories.banners"
    }
  ]
}
{% endschema %}
