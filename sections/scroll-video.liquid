{%- comment -%}
  Scroll-scrubbed video (replaces the 251-frame canvas sequence).
  One MP4 encoded with every frame a keyframe (-g 1) so currentTime seeks
  land instantly. The file is prefetched into a Blob first (loading bar),
  after which every seek is local — no network range-requests mid-scroll.
  Desktop uses the 16:9 master; phones get a portrait center-crop file.
{%- endcomment -%}

{%- liquid
  assign s = section.settings
  assign vid_url = ''
  if s.video_url != blank
    assign vid_url = s.video_url
  elsif s.video_file != blank
    assign vid_url = s.video_file | asset_url
  endif
  assign vid_url_m = ''
  if s.video_url_mobile != blank
    assign vid_url_m = s.video_url_mobile
  elsif s.video_file_mobile != blank
    assign vid_url_m = s.video_file_mobile | asset_url
  endif
-%}

<div
  id="ScrollVid-{{ section.id }}"
  class="scroll-vid"
  data-scroll-vid
  data-src="{{ vid_url }}"
  data-src-mobile="{{ vid_url_m }}"
  style="--vid-distance: {{ s.scroll_distance }}px; --vid-bg: {{ s.bg_color }};"
>
  <div class="scroll-vid__sticky">
    <video
      class="scroll-vid__video"
      data-vid
      muted
      playsinline
      preload="metadata"
      aria-hidden="true"
      tabindex="-1"
    ></video>

    <div class="scroll-vid__loader" data-vid-loader aria-hidden="true">
      <span class="scroll-vid__loader-mark">*</span>
      <span class="scroll-vid__loader-bar"><i data-vid-loader-fill></i></span>
      <span class="scroll-vid__loader-pct" data-vid-loader-pct>0%</span>
    </div>

    {%- if s.show_hint -%}
      <div class="scroll-vid__hint" data-vid-hint aria-hidden="true">
        <span class="scroll-vid__hint-text scroll-vid__hint-text--d">{{ s.hint_text | default: 'Скролни надолу' }}</span>
        <span class="scroll-vid__hint-text scroll-vid__hint-text--m">{{ s.hint_text_mobile | default: 'Скролни нагоре' }}</span>
        <span class="scroll-vid__hint-chevs" aria-hidden="true"><i></i><i></i><i></i></span>
      </div>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .scroll-vid {
    position: relative;
    height: calc(100vh + var(--vid-distance, 6000px));
    background: var(--vid-bg, #ffffff);
  }
  .scroll-vid__sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    height: 100svh;
    overflow: hidden;
    background: var(--vid-bg, #ffffff);
  }
  .scroll-vid__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0;
    transition: opacity 0.45s ease;
    pointer-events: none;
  }
  .scroll-vid__video.is-ready { opacity: 1; }

  /* ---- loader: asterisk + thin bar, same language as the frame version ---- */
  .scroll-vid__loader {
    position: absolute;
    left: 50%; top: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    z-index: 2;
    transition: opacity 0.4s ease;
  }
  .scroll-vid__loader.is-done { opacity: 0; pointer-events: none; }
  .scroll-vid__loader-mark {
    font-family: 'Nexa', var(--font-heading--family, sans-serif);
    font-weight: 900;
    font-size: 44px;
    line-height: 0.6;
    color: #9A1F33;
  }
  .scroll-vid__loader-bar {
    width: 148px; height: 2px;
    background: rgb(0 0 0 / 0.12);
    overflow: hidden;
    border-radius: 2px;
  }
  .scroll-vid__loader-bar i {
    display: block;
    width: 0%;
    height: 100%;
    background: #9A1F33;
    transition: width 0.2s ease;
  }
  .scroll-vid__loader-pct {
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: 11px;
    letter-spacing: 0.22em;
    color: rgb(0 0 0 / 0.45);
  }

  /* ---- scroll hint: dark glass pill (shared design with the frame version) ---- */
  .scroll-vid__hint {
    position: absolute;
    left: 50%;
    bottom: clamp(26px, 6vh, 56px);
    transform: translateX(-50%) translateY(8px);
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    padding: 14px 22px;
    border-radius: 999px;
    color: #fff;
    background: rgb(12 12 12 / 0.62);
    border: 1px solid rgb(255 255 255 / 0.14);
    -webkit-backdrop-filter: blur(14px) saturate(160%);
            backdrop-filter: blur(14px) saturate(160%);
    box-shadow: 0 14px 40px rgb(0 0 0 / 0.28), inset 0 1px 0 rgb(255 255 255 / 0.2);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  .scroll-vid__hint.is-on { opacity: 1; transform: translateX(-50%) translateY(0); }
  .scroll-vid__hint.is-on.is-off { opacity: 0; transform: translateX(-50%) translateY(8px); }
  .scroll-vid__hint-text {
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: 12px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .scroll-vid__hint-chevs { display: flex; flex-direction: column; align-items: center; gap: 3px; height: 22px; }
  .scroll-vid__hint-chevs i {
    width: 9px; height: 9px;
    border-right: 2px solid currentColor;
    border-bottom: 2px solid currentColor;
    transform: rotate(45deg);
    opacity: 0.25;
    animation: vid-chev 1.5s ease-in-out infinite;
  }
  .scroll-vid__hint-chevs i:nth-child(2) { animation-delay: 0.2s; margin-top: -5px; }
  .scroll-vid__hint-chevs i:nth-child(3) { animation-delay: 0.4s; margin-top: -5px; }
  @keyframes vid-chev {
    0%, 60%, 100% { opacity: 0.25; transform: rotate(45deg) translate(0, 0); }
    30% { opacity: 1; transform: rotate(45deg) translate(2px, 2px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .scroll-vid__hint { transition: opacity 0.2s ease; }
    .scroll-vid__hint-chevs i { animation: none; opacity: 0.8; }
  }
  .scroll-vid__hint-text--m { display: none; }
  @media screen and (max-width: 749px) {
    .scroll-vid__hint { padding: 12px 18px; bottom: clamp(20px, 5vh, 40px); }
    .scroll-vid__hint-text { font-size: 11px; letter-spacing: 0.2em; }
    .scroll-vid__hint-text--d { display: none; }
    .scroll-vid__hint-text--m { display: block; }
    /* phones: you swipe UP — flip the chevrons to match */
    .scroll-vid__hint-chevs { transform: rotate(180deg); }
  }
{% endstylesheet %}

<script>
  (function () {
    function init(root) {
      if (!root || root.__scrollVidReady) return;
      root.__scrollVidReady = true;

      var video = root.querySelector('[data-vid]');
      var loader = root.querySelector('[data-vid-loader]');
      var loaderFill = root.querySelector('[data-vid-loader-fill]');
      var loaderPct = root.querySelector('[data-vid-loader-pct]');
      var hint = root.querySelector('[data-vid-hint]');
      if (!video) return;

      // phones get the portrait-crop file when one is provided
      var src = root.getAttribute('data-src') || '';
      var srcM = root.getAttribute('data-src-mobile') || '';
      if (srcM && window.matchMedia('(max-width: 749px)').matches) src = srcM;
      if (!src) return;

      var duration = 0;
      var ready = false;
      var targetT = 0, currentT = 0;
      var seekBusy = false, seekWanted = false;
      var EASE = 0.22;               // eased catch-up: wheel jumps glide through frames
      var EPS = 1 / 60;              // don't bother the decoder for sub-frame moves

      function setLoader(p) {
        if (loaderFill) loaderFill.style.width = Math.round(p * 100) + '%';
        if (loaderPct) loaderPct.textContent = Math.round(p * 100) + '%';
      }

      // ---- fetch the whole file into a Blob: after this, seeks never hit the network ----
      function loadVideo() {
        if (!window.fetch || !window.ReadableStream) { video.src = src; return; }
        fetch(src)
          .then(function (res) {
            if (!res.ok || !res.body) throw new Error('http ' + res.status);
            var total = parseInt(res.headers.get('Content-Length') || '0', 10);
            var got = 0, chunks = [];
            var reader = res.body.getReader();
            function pump() {
              return reader.read().then(function (r) {
                if (r.done) return chunks;
                chunks.push(r.value);
                got += r.value.byteLength;
                if (total) setLoader(got / total);
                return pump();
              });
            }
            return pump().then(function (parts) {
              return new Blob(parts, { type: 'video/mp4' });
            });
          })
          .then(function (blob) {
            setLoader(1);
            video.src = URL.createObjectURL(blob);
          })
          .catch(function () { video.src = src; }); // CORS/network fallback: stream directly
      }

      video.addEventListener('loadedmetadata', function () {
        duration = video.duration || 0;
        // iOS won't paint frames until the video has "played" once — prime the
        // decoder with a muted play/pause the user never sees
        var p = video.play();
        if (p && p.then) {
          p.then(function () { video.pause(); markReady(); })
           .catch(function () { markReady(); }); // autoplay blocked: seeks still work on most browsers
        } else {
          video.pause(); markReady();
        }
      });

      function markReady() {
        if (ready) return;
        ready = true;
        try { video.currentTime = 0; } catch (err) {}
        video.classList.add('is-ready');
        if (loader) loader.classList.add('is-done');
        if (hint) { hint.classList.add('is-on'); updateHint(); }
        update();
      }

      // ---- seek gate: one in-flight seek at a time, latest target wins ----
      video.addEventListener('seeked', function () {
        seekBusy = false;
        if (seekWanted) { seekWanted = false; applySeek(); }
      });
      function applySeek() {
        if (seekBusy) { seekWanted = true; return; }
        seekBusy = true;
        try {
          video.currentTime = currentT;
        } catch (err) { seekBusy = false; }
      }

      function progress() {
        var rect = root.getBoundingClientRect();
        var scrollable = rect.height - window.innerHeight;
        if (scrollable <= 0) return 0;
        var p = -rect.top / scrollable;
        return p < 0 ? 0 : (p > 1 ? 1 : p);
      }

      function updateHint() {
        if (!hint) return;
        var p = progress();
        if (p > 0.03) hint.classList.add('is-off');
        else if (p < 0.01) hint.classList.remove('is-off');
      }

      var rafLive = false;
      function tick() {
        rafLive = false;
        if (!ready || !duration) return;
        var d = targetT - currentT;
        if (Math.abs(d) > EPS) {
          currentT += d * EASE;
          if (Math.abs(targetT - currentT) < EPS) currentT = targetT;
          applySeek();
          schedule();
        } else if (currentT !== targetT) {
          currentT = targetT;
          applySeek();
        }
      }
      function schedule() {
        if (!rafLive) { rafLive = true; requestAnimationFrame(tick); }
      }

      function update() {
        if (!duration) return;
        // land exactly on the last frame, not past it
        targetT = progress() * Math.max(duration - 0.04, 0);
        updateHint();
        schedule();
      }

      window.addEventListener('scroll', update, { passive: true });
      window.addEventListener('resize', update);

      // don't start the download until the section is near the viewport
      if ('IntersectionObserver' in window) {
        var io = new IntersectionObserver(function (entries) {
          for (var i = 0; i < entries.length; i++) {
            if (entries[i].isIntersecting) { io.disconnect(); loadVideo(); return; }
          }
        }, { rootMargin: '100% 0px' });
        io.observe(root);
      } else {
        loadVideo();
      }
    }

    function initAll(scope) {
      var list = (scope || document).querySelectorAll('[data-scroll-vid]');
      for (var i = 0; i < list.length; i++) init(list[i]);
    }
    if (document.readyState !== 'loading') initAll();
    else document.addEventListener('DOMContentLoaded', function () { initAll(); });
    document.addEventListener('shopify:section:load', function (e) { initAll(e.target); });
  })();
</script>

{% schema %}
{
  "name": "Scroll video",
  "tag": "section",
  "class": "scroll-vid-wrapper",
  "settings": [
    { "type": "header", "content": "Video" },
    { "type": "text", "id": "video_file", "label": "Video file in assets (desktop)", "info": "Filename only, e.g. khan-seq-desktop.mp4 — encoded with every frame a keyframe (-g 1) for instant scrubbing." },
    { "type": "text", "id": "video_file_mobile", "label": "Video file in assets (mobile)", "info": "Portrait-crop variant for phones, e.g. khan-seq-mobile.mp4. Leave empty to reuse the desktop file." },
    { "type": "text", "id": "video_url", "label": "External video URL (desktop)", "info": "Overrides the asset file — use for a file hosted in Content → Files." },
    { "type": "text", "id": "video_url_mobile", "label": "External video URL (mobile)" },

    { "type": "header", "content": "Scroll" },
    { "type": "range", "id": "scroll_distance", "label": "Scroll distance", "min": 2000, "max": 9500, "step": 500, "unit": "px", "default": 6000 },

    { "type": "header", "content": "Hint" },
    { "type": "checkbox", "id": "show_hint", "label": "Show scroll hint", "default": true },
    { "type": "text", "id": "hint_text", "label": "Hint text (desktop)", "default": "Скролни надолу" },
    { "type": "text", "id": "hint_text_mobile", "label": "Hint text (mobile)", "default": "Скролни нагоре" },

    { "type": "header", "content": "Style" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#ffffff" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme" }
  ],
  "presets": [
    { "name": "Scroll video" }
  ]
}
{% endschema %}
