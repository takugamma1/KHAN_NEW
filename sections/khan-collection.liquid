{% liquid
  assign s = section.settings
%}

<div
  id="KhanColl-{{ section.id }}"
  class="
    khan-coll color-{{ s.color_scheme }}
    khan-coll--anim-{{ s.anim_style }}
    {% if s.text_grain %}khan-coll--grain{% endif %}
  "
  style="
    --coll-bg: {{ s.bg_color }};
    --coll-heading: {{ s.heading_color }};
    --coll-heading-accent: {{ s.accent_color }};
    --coll-text: {{ s.text_color }};
    --coll-card-bg: {{ s.card_bg }};
    --coll-card-border-w: {{ s.card_border_width }}px;
    --coll-label: {{ s.label_color }};
    --coll-btn-bg: {{ s.button_bg }};
    --coll-btn-text: {{ s.button_text }};
    --coll-frame: {{ s.frame_color }};
    --coll-heading-size: {{ s.heading_size }}px;
    --coll-sub-size: {{ s.subheading_size }}px;
    --coll-maxw: {{ s.max_width }}px;
    --coll-gap: {{ s.column_gap }}px;
    --coll-pt: {{ s.padding_top }}px;
    --coll-pb: {{ s.padding_bottom }}px;
    --coll-dur: {{ s.anim_duration }}ms;
    --coll-stagger: {{ s.anim_stagger }}ms;
    --coll-swatch: {{ s.swatch_size }}px;
    --coll-grain: url('{{ 'khan-grain.png' | asset_url }}');
    --coll-fav: {{ s.fav_color | default: '#3B0211' }};
  "
  data-khan-coll
>
  <div class="khan-coll__inner">
    <header class="khan-coll__head">
      {%- if s.heading != blank -%}<div class="khan-coll__heading">{{ s.heading }}</div>{%- endif -%}
      {%- if s.subheading != blank -%}
        <p class="khan-coll__sub"><span class="khan-coll__plus">+</span>{{ s.subheading }}<span class="khan-coll__plus">+</span></p>
      {%- endif -%}
    </header>

    <div class="khan-coll__grid">
      {%- for block in section.blocks -%}
        {%- liquid
          assign p = block.settings.product
          assign img = block.settings.image
          if img == blank and p != blank
            assign img = p.featured_image
          endif
          assign label = block.settings.label
          if label == blank and p != blank
            assign label = p.title
          endif
          assign url = block.settings.button_link
          if url == blank and p != blank
            assign url = p.url
          endif
        -%}
        <article class="khan-coll__card" style="--card-i: {{ forloop.index0 }};" {{ block.shopify_attributes }}>

          <div class="khan-coll__card-media">
            {%- if url != blank -%}
              <a class="khan-coll__card-link" href="{{ url }}" aria-label="{{ label | default: 'Product' | escape }}">
            {%- endif -%}
            {%- if img != blank -%}
              {{ img | image_url: width: 1200 | image_tag: loading: 'eager', widths: '400, 600, 800, 1200', class: 'khan-coll__card-img', alt: label }}
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'khan-coll__card-img khan-coll__card-img--placeholder' }}
            {%- endif -%}
            {%- if url != blank -%}
              </a>
            {%- endif -%}

            {%- if s.show_edition -%}
              {%- liquid
                assign edition_text = block.settings.edition_text
                if edition_text == blank and p != blank
                  assign qty = 0
                  assign tracked = false
                  for v in p.variants
                    if v.inventory_management != blank
                      assign tracked = true
                      assign qty = qty | plus: v.inventory_quantity
                    endif
                  endfor
                  if tracked
                    assign qty_str = qty | at_least: 0 | prepend: '00' | slice: -3, 3
                    assign edition_text = qty_str | append: '/' | append: s.edition_total
                  endif
                endif
              -%}
              {%- if edition_text != blank -%}
                <span class="khan-coll__edition">
                  <span class="khan-coll__edition-kicker">Edition</span>
                  <strong class="khan-coll__edition-num">{{ edition_text }}</strong>
                </span>
              {%- endif -%}
            {%- endif -%}

            {%- if s.show_fav -%}
              <svg class="khan-coll__fav" viewBox="0 0 70 84" aria-hidden="true" focusable="false">
                <path d="M0 0H70V57.12L35 84 0 57.12Z" fill="var(--coll-fav, #3B0211)"/>
                <path d="M35 30.5l2.42 8.58L46 41.5l-8.58 2.42L35 52.5l-2.42-8.58L24 41.5l8.58-2.42Z" fill="#ffffff" opacity="0.65"/>
              </svg>
            {%- endif -%}
          </div>

          {%- if section.settings.show_swatches -%}
            {%- assign has_bubbles = false -%}
            {%- if block.settings.bubble_1 != blank or block.settings.bubble_2 != blank or block.settings.bubble_3 != blank or block.settings.bubble_4 != blank or block.settings.bubble_5 != blank -%}
              {%- assign has_bubbles = true -%}
            {%- endif -%}
            {%- if has_bubbles -%}
              <div class="khan-coll__swatches" aria-hidden="true">
                {%- if block.settings.bubble_1 != blank -%}<span class="khan-coll__swatch">{{ block.settings.bubble_1 | image_url: width: 120 | image_tag: alt: '', loading: 'lazy' }}</span>{%- endif -%}
                {%- if block.settings.bubble_2 != blank -%}<span class="khan-coll__swatch">{{ block.settings.bubble_2 | image_url: width: 120 | image_tag: alt: '', loading: 'lazy' }}</span>{%- endif -%}
                {%- if block.settings.bubble_3 != blank -%}<span class="khan-coll__swatch">{{ block.settings.bubble_3 | image_url: width: 120 | image_tag: alt: '', loading: 'lazy' }}</span>{%- endif -%}
                {%- if block.settings.bubble_4 != blank -%}<span class="khan-coll__swatch">{{ block.settings.bubble_4 | image_url: width: 120 | image_tag: alt: '', loading: 'lazy' }}</span>{%- endif -%}
                {%- if block.settings.bubble_5 != blank -%}<span class="khan-coll__swatch">{{ block.settings.bubble_5 | image_url: width: 120 | image_tag: alt: '', loading: 'lazy' }}</span>{%- endif -%}
              </div>
            {%- endif -%}
          {%- endif -%}

          {%- if url != blank or block.settings.button_label != blank -%}
            <a class="khan-coll__btn" {% if url != blank %}href="{{ url }}"{% endif %}>
              <span>{{ block.settings.button_label | default: 'Shop now' }}</span>
            </a>
          {%- endif -%}
        </article>
      {%- endfor -%}
    </div>
  </div>
</div>

<script>
  (function () {
    var root = document.getElementById('KhanColl-{{ section.id }}');
    if (!root) return;
    var reveal = function () { root.classList.add('khan-coll--in'); };
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) { reveal(); return; }
    if (!('IntersectionObserver' in window)) { reveal(); return; }
    {%- comment -%}
      threshold 0: on mobile the stacked grid makes this section taller than
      the viewport, so a percentage threshold can never be reached — fire as
      soon as any part of it enters the screen instead.
    {%- endcomment -%}
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) { reveal(); io.disconnect(); }
      });
    }, { threshold: 0, rootMargin: '0px 0px -40px 0px' });
    io.observe(root);
    {%- comment -%} safety net: products must never stay invisible {%- endcomment -%}
    window.setTimeout(function () {
      var r = root.getBoundingClientRect();
      if (r.top < window.innerHeight && r.bottom > 0) reveal();
    }, 1500);
    document.addEventListener('shopify:section:select', function (e) {
      if (e.detail && e.detail.sectionId === '{{ section.id }}') reveal();
    });
  })();
</script>

{% stylesheet %}
  .khan-coll {
    position: relative;
    background: var(--coll-bg, #f4f1ea);
    padding-block: var(--coll-pt, 96px) var(--coll-pb, 96px);
    padding-inline: clamp(20px, 5vw, 64px);
    overflow: hidden;
  }

  .khan-coll__inner {
    max-width: min(var(--coll-maxw, 1700px), 100%);
    margin-inline: auto;
  }

  /* ---- header ---- */
  .khan-coll__head {
    text-align: center;
    margin-bottom: clamp(32px, 5vw, 64px);
  }

  .khan-coll__heading {
    margin: 0;
    font-family: 'Nexa', var(--font-heading--family, sans-serif);
    font-weight: 900;
    font-size: min(var(--coll-heading-size, 72px), 12vw);
    line-height: 1;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    color: var(--coll-heading, #560B1E);
  }
  .khan-coll__heading p { margin: 0; }
  .khan-coll__heading :is(strong, b) { color: var(--coll-heading-accent, #111); font-weight: inherit; }

  .khan-coll__sub {
    display: inline-flex;
    align-items: center;
    gap: 18px;
    margin: 14px 0 0;
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: var(--coll-sub-size, 13px);
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--coll-label, #1a1a1a);
  }
  .khan-coll__plus { color: var(--coll-heading-accent, #560B1E); }

  /* ---- grid ---- */
  .khan-coll__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--coll-gap, 28px);
  }

  /* ---- card ---- */
  .khan-coll__card {
    position: relative;
    display: flex;
    flex-direction: column;
    --coll-card-pad: clamp(18px, 2vw, 28px);
    padding: var(--coll-card-pad);
    border: var(--coll-card-border-w, 1px) solid var(--coll-frame, rgb(0 0 0 / 0.16));
    background: var(--coll-card-bg, transparent);
  }

  .khan-coll__card-media {
    position: relative;
    flex: 1 1 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 1 / 1.15;
    margin: 0 0 18px;
  }
  .khan-coll__card-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
  }
  .khan-coll__card-img { width: 100%; height: 100%; object-fit: contain; object-position: center; display: block; }

  /* ---- card badges ---- */
  .khan-coll__edition {
    position: absolute;
    top: calc(-1 * var(--coll-card-pad));
    left: calc(-1 * var(--coll-card-pad));
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 3px;
    min-width: 92px;
    padding: 13px 16px 11px;
    background: #ffffff;
    color: #0a0a0a;
    clip-path: polygon(14px 0, 100% 0, 100% 100%, 0 100%, 0 14px);
    pointer-events: none;
  }
  .khan-coll__edition::before {
    content: "";
    position: absolute;
    top: 8px;
    left: 8px;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #0a0a0a;
  }
  .khan-coll__edition-kicker {
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: 9px;
    letter-spacing: 0.34em;
    text-transform: uppercase;
    font-weight: 700;
  }
  .khan-coll__edition-num {
    font-family: 'Nexa', var(--font-heading--family, sans-serif);
    font-weight: 900;
    font-size: 17px;
    line-height: 1;
    letter-spacing: 0.04em;
  }
  .khan-coll__fav {
    position: absolute;
    top: calc(-1 * var(--coll-card-pad));
    right: calc(16px - var(--coll-card-pad));
    z-index: 1;
    width: 42px;
    height: auto;
    pointer-events: none;
  }

  .khan-coll__btn {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-inline: clamp(20px, 12%, 64px);
    padding: 16px 40px;
    background: var(--coll-btn-bg, #111);
    color: var(--coll-btn-text, #fff);
    text-decoration: none;
    font-family: 'Nexa', var(--font-heading--family, sans-serif);
    font-weight: 900;
    font-size: 14px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-align: center;
    clip-path: polygon(12px 0, 100% 0, calc(100% - 12px) 100%, 0 100%);
  }
  .khan-coll__btn::before {
    content: "";
    position: absolute;
    inset: 0;
    background: #000;
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .khan-coll__btn:hover::before { transform: scaleX(1); }
  .khan-coll__btn > span { position: relative; z-index: 1; }

  /* ---- variant bubbles (showcase only) ---- */
  .khan-coll__swatches {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
    margin: 0 0 18px;
  }
  .khan-coll__swatch {
    flex: 0 0 auto;
    width: var(--coll-swatch, 30px);
    height: var(--coll-swatch, 30px);
    border-radius: 50%;
    overflow: hidden;
    border: 1.5px solid var(--coll-frame, rgb(0 0 0 / 0.22));
    background: #fff;
  }
  .khan-coll__swatch img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ---- grain on content (not the background) ---- */
  .khan-coll--grain :is(.khan-coll__heading, .khan-coll__sub) {
    -webkit-mask-image: var(--coll-grain);
    mask-image: var(--coll-grain);
    -webkit-mask-size: 170px 170px;
    mask-size: 170px 170px;
  }

  /* ---- reveal animation (scroll-triggered, staggered) ---- */
  .khan-coll__card {
    opacity: 0;
    transition:
      opacity var(--coll-dur, 1100ms) cubic-bezier(0.2, 0.7, 0.2, 1),
      transform var(--coll-dur, 1100ms) cubic-bezier(0.2, 0.7, 0.2, 1),
      clip-path var(--coll-dur, 1100ms) cubic-bezier(0.2, 0.7, 0.2, 1);
    transition-delay: calc(var(--card-i, 0) * var(--coll-stagger, 180ms));
    will-change: opacity, transform, clip-path;
  }
  .khan-coll--anim-wipe .khan-coll__card { transform: translateY(22px); clip-path: inset(0 0 100% 0); }
  .khan-coll--anim-rise .khan-coll__card { transform: translateY(36px); }
  .khan-coll--anim-scale .khan-coll__card { transform: scale(0.92); }

  .khan-coll--in .khan-coll__card {
    opacity: 1;
    transform: none;
    clip-path: inset(0 0 0 0);
  }

  /* ---- responsive ---- */
  @media screen and (max-width: 990px) {
    .khan-coll__grid { grid-template-columns: 1fr; max-width: 520px; margin-inline: auto; }
  }

  @media (prefers-reduced-motion: reduce) {
    .khan-coll__card { opacity: 1 !important; transform: none !important; clip-path: none !important; transition: none !important; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Collection grid",
  "tag": "section",
  "class": "khan-coll-wrapper section-wrapper",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "header", "content": "Heading" },
    { "type": "paragraph", "content": "Bold text uses the accent color (the period in COLLECTION.)." },
    { "type": "richtext", "id": "heading", "label": "Heading", "default": "<p>Collection<strong>.</strong></p>" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Built different. Made to last." },
    { "type": "range", "id": "heading_size", "label": "Heading size", "min": 32, "max": 120, "step": 2, "unit": "px", "default": 72 },
    { "type": "range", "id": "subheading_size", "label": "Subheading size", "min": 10, "max": 20, "step": 1, "unit": "px", "default": 13 },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#560B1E" },
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#111111" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#1a1a1a" },

    { "type": "header", "content": "Appearance animation" },
    { "type": "paragraph", "content": "Cards reveal as the section scrolls into view, staggered one after another." },
    {
      "type": "select",
      "id": "anim_style",
      "label": "Reveal style",
      "options": [
        { "value": "wipe", "label": "Wipe up + rise (recommended)" },
        { "value": "rise", "label": "Rise + fade" },
        { "value": "scale", "label": "Scale in" }
      ],
      "default": "wipe"
    },
    { "type": "range", "id": "anim_duration", "label": "Duration", "min": 200, "max": 1500, "step": 50, "unit": "ms", "default": 1100 },
    { "type": "range", "id": "anim_stagger", "label": "Stagger between cards", "min": 0, "max": 400, "step": 20, "unit": "ms", "default": 180 },

    { "type": "header", "content": "Cards" },
    { "type": "paragraph", "content": "Add a Product block per card (up to 3 across; more wrap)." },
    { "type": "checkbox", "id": "text_grain", "label": "Grain on text", "default": true },
    { "type": "color", "id": "card_bg", "label": "Card background", "alpha": true, "default": "#00000000" },
    { "type": "color", "id": "frame_color", "label": "Card border color", "default": "#00000029" },
    { "type": "range", "id": "card_border_width", "label": "Card border width", "min": 0, "max": 6, "step": 1, "unit": "px", "default": 1 },
    { "type": "color", "id": "label_color", "label": "Product title color", "default": "#1a1a1a" },
    { "type": "color", "id": "button_bg", "label": "Button background", "default": "#111111" },
    { "type": "color", "id": "button_text", "label": "Button text", "default": "#ffffff" },
    { "type": "checkbox", "id": "show_swatches", "label": "Show variant bubbles (showcase)", "default": true },
    { "type": "range", "id": "swatch_size", "label": "Bubble size", "min": 18, "max": 56, "step": 2, "unit": "px", "default": 30 },

    { "type": "header", "content": "Card badges" },
    { "type": "checkbox", "id": "show_edition", "label": "Show edition tag (left)", "default": true },
    { "type": "text", "id": "edition_total", "label": "Edition total", "default": "500", "info": "Remaining count comes from product inventory. Override per card in the block settings." },
    { "type": "checkbox", "id": "show_fav", "label": "Show favorites badge (right)", "default": true },
    { "type": "color", "id": "fav_color", "label": "Favorites badge color", "default": "#3B0211" },

    { "type": "header", "content": "Background & spacing" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#f4f1ea" },
    { "type": "range", "id": "max_width", "label": "Max width", "min": 1000, "max": 1900, "step": 20, "unit": "px", "default": 1700 },
    { "type": "range", "id": "column_gap", "label": "Gap between cards", "min": 0, "max": 80, "step": 4, "unit": "px", "default": 28 },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 96 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 96 },

    { "type": "header", "content": "Appearance" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" },
        { "type": "text", "id": "label", "label": "Label override" },
        { "type": "image_picker", "id": "image", "label": "Image override" },
        { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop now" },
        { "type": "url", "id": "button_link", "label": "Button link override" },
        { "type": "text", "id": "edition_text", "label": "Edition tag override", "info": "e.g. 047/500 — leave blank to use live inventory" },
        { "type": "header", "content": "Variant bubbles (showcase)" },
        { "type": "image_picker", "id": "bubble_1", "label": "Bubble 1" },
        { "type": "image_picker", "id": "bubble_2", "label": "Bubble 2" },
        { "type": "image_picker", "id": "bubble_3", "label": "Bubble 3" },
        { "type": "image_picker", "id": "bubble_4", "label": "Bubble 4" },
        { "type": "image_picker", "id": "bubble_5", "label": "Bubble 5" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Collection grid",
      "category": "t:categories.products",
      "blocks": [
        { "type": "product", "settings": { "label": "Performance tee" } },
        { "type": "product", "settings": { "label": "Sleeveless tank" } },
        { "type": "product", "settings": { "label": "Essential set" } }
      ]
    }
  ]
}
{% endschema %}
