{% liquid
  assign s = section.settings
  assign jar = s.jar_image
%}

<div
  id="KhanIHero-{{ section.id }}"
  class="khan-ihero color-{{ s.color_scheme }}{% if s.bg_image_mobile != blank %} khan-ihero--mobimg{% endif %}"
  style="
    --ih-text: {{ s.text_color }};
    --ih-accent: {{ s.accent_color }};
    --ih-muted: {{ s.muted_color }};
    --ih-bg: {{ s.bg_color }};
    --ih-top: {{ s.top_overlay | divided_by: 100.0 }};
    --ih-aster: url('{{ 'asterisk.png' | asset_url }}');
    --ih-minh: {{ s.min_height }}px;
    --ih-maxw: {{ s.max_width }}px;
    --ih-pad-y: {{ s.padding_y }}px;
    --ih-heading: {{ s.heading_size }}px;
    --ih-eyebrow: {{ s.eyebrow_size }}px;
    --ih-contentw: {{ s.content_width }}px;
    --ih-valign: {{ s.content_valign }};
    --ih-offset: {{ s.content_offset }}px;
    --ih-icon: {{ s.icon_size }}px;
    --ih-title: {{ s.title_size }}px;
    --ih-utext: {{ s.text_size }}px;
    --ih-gap: {{ s.usp_gap }}px;
    --ih-corner: {{ s.corner_size }}px;
    --ih-corner-top: {{ s.corner_top | default: 96 }}px;
    --ih-factsw: {{ s.facts_width | default: 480 }}px;
    --ih-facts-blur: {{ s.facts_blur | default: 16 }}px;
    --ih-facts-op: {{ s.facts_opacity | default: 55 | divided_by: 100.0 }};
    --ih-facts-top: {{ s.facts_top | default: 120 }}px;
    --ih-peek: {{ s.peek | default: 64 }}px;
    --ih-tab-bg: {{ s.tab_bg | default: '#0c0c0ceb' }};
  "
  data-khan-ihero
>
  <div class="khan-ihero__bg" aria-hidden="true">
    {%- if s.bg_image != blank -%}
      {{ s.bg_image | image_url: width: 3200 | image_tag: class: 'khan-ihero__bg-img khan-ihero__bg-img--d', loading: 'lazy', widths: '800, 1200, 1600, 2000, 2600, 3200', sizes: '100vw', alt: '' }}
    {%- endif -%}
    {%- if s.bg_image_mobile != blank -%}
      {{ s.bg_image_mobile | image_url: width: 1400 | image_tag: class: 'khan-ihero__bg-img khan-ihero__bg-img--m', loading: 'lazy', widths: '600, 900, 1200, 1400', sizes: '100vw', alt: '' }}
    {%- endif -%}
    <span class="khan-ihero__overlay"></span>
  </div>

  {%- if s.top_left != blank -%}
    <span class="khan-ihero__corner khan-ihero__corner--tl">{{ s.top_left }}</span>
  {%- endif -%}
  {%- if s.top_right != blank -%}
    <span class="khan-ihero__corner khan-ihero__corner--tr">{{ s.top_right }}</span>
  {%- endif -%}

  <div class="khan-ihero__inner">

    <div class="khan-ihero__left">
      {%- if s.eyebrow != blank -%}
        <p class="khan-ihero__eyebrow">{{ s.eyebrow }}</p>
      {%- endif -%}
      {%- if s.heading != blank -%}
        <div class="khan-ihero__heading">{{ s.heading }}</div>
      {%- endif -%}

      {%- if jar != blank -%}
        <div class="khan-ihero__jar">
          {{ jar | image_url: width: 1600 | image_tag: class: 'khan-ihero__jar-img', loading: 'eager', fetchpriority: 'high', widths: '500, 800, 1100, 1400, 1600', sizes: '(max-width: 749px) 80vw, 44vw', alt: product.title | default: shop.name }}
        </div>
      {%- endif -%}

      {%- if s.heading == blank and s.eyebrow == blank and section.blocks.size > 0 -%}
        <div class="khan-ihero__usps">
          {%- for block in section.blocks -%}
            {%- if block.type == 'usp' -%}
              <div class="khan-ihero__usp" {{ block.shopify_attributes }}>
                <span class="khan-ihero__usp-icon">
                  {%- if block.settings.icon != blank -%}
                    {{ block.settings.icon | image_url: width: 120 | image_tag: loading: 'lazy', alt: '' }}
                  {%- else -%}
                    <span class="khan-ihero__usp-asterisk" aria-hidden="true"></span>
                  {%- endif -%}
                </span>
                <div class="khan-ihero__usp-body">
                  {%- if block.settings.title != blank -%}<p class="khan-ihero__usp-title">{{ block.settings.title }}</p>{%- endif -%}
                  {%- if block.settings.text != blank -%}<p class="khan-ihero__usp-text">{{ block.settings.text }}</p>{%- endif -%}
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    {%- if s.show_facts -%}
      {%- comment -%} Mobile backdrop (portaled to <body> alongside the sheet on small screens) {%- endcomment -%}
      <span class="khan-ihero__scrim" data-ifacts-scrim aria-hidden="true"></span>

      {%- comment -%} Mobile: small right-edge bubble — drag left / tap to open the drawer {%- endcomment -%}
      <button class="khan-ihero__facts-tab" type="button" data-ifacts-tab aria-label="{{ s.facts_heading | default: 'Supplement facts' | escape }}">
        <span class="khan-ihero__facts-tab-arrow" aria-hidden="true"></span>
        <span class="khan-ihero__facts-tab-label">{{ s.facts_heading | default: 'Supplement facts' }}</span>
      </button>

      <aside class="khan-ihero__facts" data-ifacts role="dialog" aria-label="{{ s.facts_heading | default: 'Supplement facts' | escape }}" aria-modal="false">
        <button class="khan-ihero__facts-handle" type="button" data-ifacts-handle aria-expanded="false" aria-label="{{ s.facts_heading | default: 'Supplement facts' | escape }}">
          <span class="khan-ihero__facts-grip" aria-hidden="true"></span>
          <span class="khan-ihero__facts-handle-label">{{ s.facts_heading | default: 'Supplement facts' }}</span>
          <span class="khan-ihero__facts-chevron" aria-hidden="true"></span>
        </button>

        {%- if s.legacy_label != blank -%}
          <span class="khan-ihero__facts-legacy" aria-hidden="true">{{ s.legacy_label }}</span>
        {%- endif -%}

        <div class="khan-ihero__facts-card">
          <div class="khan-ihero__facts-scroll">
            {%- if s.facts_heading != blank -%}
              <p class="khan-ihero__facts-title">{{ s.facts_heading }}</p>
            {%- endif -%}

            {%- assign rows = section.blocks | where: 'type', 'fact' -%}
            {%- if rows.size > 0 -%}
              <table class="khan-ihero__facts-table">
                <thead>
                  <tr>
                    <th scope="col"></th>
                    <th scope="col">{{ s.col1_header }}</th>
                    <th scope="col">{{ s.col2_header }}</th>
                  </tr>
                </thead>
                <tbody>
                  {%- for block in rows -%}
                    <tr {{ block.shopify_attributes }}>
                      <th scope="row">{{ block.settings.label }}</th>
                      <td>{{ block.settings.col1 }}</td>
                      <td>{{ block.settings.col2 }}</td>
                    </tr>
                  {%- endfor -%}
                </tbody>
              </table>
            {%- endif -%}

            {%- if s.facts_desc != blank -%}
              <div class="khan-ihero__facts-desc">{{ s.facts_desc }}</div>
            {%- endif -%}
          </div>
        </div>
      </aside>
    {%- endif -%}

  </div>
</div>

<script>
  (function () {
    var root = document.getElementById('KhanIHero-{{ section.id }}');
    if (!root) return;
    var facts = root.querySelector('[data-ifacts]');
    if (!facts) return;
    var scrim = root.querySelector('[data-ifacts-scrim]');
    var handle = facts.querySelector('[data-ifacts-handle]');
    var mq = window.matchMedia('(max-width: 749px)');

    /* ---------- desktop: slide-in marker once the section is on screen ---------- */
    if ('IntersectionObserver' in window) {
      new IntersectionObserver(function (es) {
        es.forEach(function (e) { root.classList.toggle('is-in', e.isIntersecting); });
      }, { threshold: 0.08 }).observe(root);
    } else {
      root.classList.add('is-in');
    }

    /* keep the (fixed) mobile bubble confined to its section — a smooth manual "sticky":
       pinned mid-screen while the section is in view, riding the section's top/bottom
       edges in and out so it scrolls away at the section end (no display toggle, no lag). */
    var rafPending = false;
    function updateTabPos() {
      if (!tab || !mq.matches) return;
      var h = tab.offsetHeight || 120;
      var r = root.getBoundingClientRect();
      var pin = window.innerHeight * 0.5 - h / 2;
      tab.style.top = Math.min(Math.max(pin, r.top), r.bottom - h) + 'px';
    }
    function onScroll() { if (rafPending) return; rafPending = true; requestAnimationFrame(function () { rafPending = false; updateTabPos(); }); }

    /* ---------- mobile: finger-following RIGHT-side drawer ---------- */
    var tab = root.querySelector('[data-ifacts-tab]');
    var anchor = document.createComment('ifacts-anchor');
    var mounted = false, dragging = false, dragEl = null, o = 0;
    var startX = 0, o0 = 0, sheetW = 1, lastX = 0, lastT = 0, vel = 0;
    var VARS = ['--ih-facts-op', '--ih-facts-blur', '--ih-peek', '--ih-accent', '--ih-muted', '--ih-tab-bg'];

    function apply(animate) {
      facts.style.transition = animate ? '' : 'none';
      facts.style.setProperty('--o', o.toFixed(4));
      if (scrim) {
        scrim.style.transition = animate ? '' : 'none';
        scrim.style.opacity = (o * 0.55).toFixed(3);
        scrim.style.pointerEvents = o > 0.02 ? 'auto' : 'none';
      }
      if (tab) {
        tab.style.opacity = (1 - Math.min(1, o * 2)).toFixed(3);
        tab.style.pointerEvents = o > 0.05 ? 'none' : 'auto';
      }
      document.body.classList.toggle('khan-ifacts-open', o > 0.02);
      document.body.classList.toggle('khan-ifacts-locked', o > 0.92);
      if (handle) handle.setAttribute('aria-expanded', o > 0.5 ? 'true' : 'false');
    }
    function setOpenness(v, animate) { o = v < 0 ? 0 : (v > 1 ? 1 : v); apply(animate); }

    function onDown(e) {
      if (!mq.matches) return;
      dragging = true; dragEl = e.currentTarget;
      sheetW = facts.getBoundingClientRect().width || window.innerWidth;
      startX = e.clientX; o0 = o; lastX = e.clientX; lastT = e.timeStamp || 0; vel = 0;
      facts.style.transition = 'none';
      if (dragEl && dragEl.setPointerCapture && e.pointerId != null) { try { dragEl.setPointerCapture(e.pointerId); } catch (_) {} }
    }
    function onMove(e) {
      if (!dragging) return;
      if (e.cancelable) e.preventDefault();
      var x = e.clientX, t = e.timeStamp || 0;
      if (t > lastT) vel = (lastX - x) / (t - lastT); /* +ve = moving left = opening */
      lastX = x; lastT = t;
      setOpenness(o0 + (startX - x) / sheetW, false);
    }
    function onUp() {
      if (!dragging) return;
      dragging = false;
      var target;
      if (vel > 0.4) target = 1;
      else if (vel < -0.4) target = 0;
      else target = o >= 0.4 ? 1 : 0;
      setOpenness(target, true);
    }
    function onTap() { if (!dragging) setOpenness(o > 0.5 ? 0 : 1, true); }

    function enableMobile() {
      if (mounted) return; mounted = true;
      var cs = getComputedStyle(root);
      VARS.forEach(function (v) { var val = cs.getPropertyValue(v); facts.style.setProperty(v, val); if (tab) tab.style.setProperty(v, val); });
      facts.parentNode.insertBefore(anchor, facts);
      document.body.appendChild(facts);
      if (scrim) document.body.appendChild(scrim);
      if (tab) document.body.appendChild(tab);
      root.classList.add('khan-ihero--sheet');
      setOpenness(0, false);
      if (handle) { handle.addEventListener('pointerdown', onDown); handle.addEventListener('click', onTap); }
      if (tab) { tab.addEventListener('pointerdown', onDown); tab.addEventListener('click', onTap); }
      window.addEventListener('pointermove', onMove, { passive: false });
      window.addEventListener('pointerup', onUp);
      window.addEventListener('pointercancel', onUp);
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll);
      if (scrim) scrim.addEventListener('click', closeFromScrim);
      updateTabPos();
    }
    function closeFromScrim() { setOpenness(0, true); }
    function disableMobile() {
      if (!mounted) return; mounted = false;
      if (handle) { handle.removeEventListener('pointerdown', onDown); handle.removeEventListener('click', onTap); }
      if (tab) { tab.removeEventListener('pointerdown', onDown); tab.removeEventListener('click', onTap); }
      window.removeEventListener('pointermove', onMove);
      window.removeEventListener('pointerup', onUp);
      window.removeEventListener('pointercancel', onUp);
      window.removeEventListener('scroll', onScroll);
      window.removeEventListener('resize', onScroll);
      if (tab) tab.style.top = '';
      if (scrim) scrim.removeEventListener('click', closeFromScrim);
      var inner = root.querySelector('.khan-ihero__inner');
      if (anchor.parentNode) { anchor.parentNode.insertBefore(facts, anchor); anchor.parentNode.removeChild(anchor); }
      if (scrim && inner) inner.insertBefore(scrim, facts);
      if (tab && inner) inner.insertBefore(tab, facts);
      root.classList.remove('khan-ihero--sheet');
      document.body.classList.remove('khan-ifacts-open');
      document.body.classList.remove('khan-ifacts-locked');
      facts.style.transition = ''; facts.style.removeProperty('--o');
      VARS.forEach(function (v) { facts.style.removeProperty(v); if (tab) tab.style.removeProperty(v); });
      if (scrim) { scrim.style.opacity = ''; scrim.style.pointerEvents = ''; }
      if (tab) { tab.style.opacity = ''; tab.style.pointerEvents = ''; tab.style.display = ''; }
    }
    function evalMode() { if (mq.matches) enableMobile(); else disableMobile(); }
    evalMode();
    if (mq.addEventListener) mq.addEventListener('change', evalMode); else mq.addListener(evalMode);

    document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && mounted && o > 0) setOpenness(0, true); });
  })();
</script>

{% stylesheet %}
  .khan-ihero {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    min-height: var(--ih-minh, 820px);
    background: var(--ih-bg, #f4f4f2);
    display: flex;
    align-items: stretch;
    padding: calc(var(--ih-pad-y, 96px) + 40px) clamp(20px, 5vw, 72px) var(--ih-pad-y, 96px);
  }

  .khan-ihero__bg { position: absolute; inset: 0; z-index: 0; }
  .khan-ihero__bg-img { width: 100%; height: 100%; object-fit: cover; object-position: center; display: block; }
  .khan-ihero__bg-img--m { display: none; }
  @media screen and (max-width: 749px) {
    .khan-ihero--mobimg .khan-ihero__bg-img--d { display: none; }
    .khan-ihero--mobimg .khan-ihero__bg-img--m { display: block; }
  }
  .khan-ihero__overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, rgb(0 0 0 / var(--ih-top, 0)) 0%, rgb(0 0 0 / 0) 52%);
  }

  /* corners */
  .khan-ihero__corner {
    position: absolute; z-index: 2; top: var(--ih-corner-top, 96px);
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: var(--ih-corner, 12px); letter-spacing: 0.2em; text-transform: uppercase;
    white-space: nowrap;
  }
  .khan-ihero__corner--tl { left: clamp(20px, 5vw, 72px); color: var(--ih-muted, #6a6a6a); }
  .khan-ihero__corner--tr { right: clamp(20px, 5vw, 72px); color: var(--ih-accent, #560B1E); }
  .khan-ihero__corner--tr::before { content: "[ "; }
  .khan-ihero__corner--tr::after { content: " ]"; }

  /* layout — jar left, facts right */
  .khan-ihero__inner {
    position: relative; z-index: 1;
    width: 100%; max-width: var(--ih-maxw, 1680px); margin-inline: auto;
    display: flex; align-items: center; justify-content: space-between; gap: clamp(24px, 5vw, 90px);
  }
  .khan-ihero__left { flex: 1 1 auto; min-width: 0; display: flex; flex-direction: column; justify-content: center; }

  /* jar */
  .khan-ihero__jar { width: 100%; display: flex; align-items: center; justify-content: flex-start; }
  .khan-ihero__jar-img { width: min(100%, 640px); height: auto; object-fit: contain; display: block; filter: drop-shadow(0 30px 60px rgb(0 0 0 / 0.35)); }

  /* heading (optional) */
  .khan-ihero__eyebrow {
    margin: 0 0 16px; display: flex; align-items: center; gap: 12px;
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: var(--ih-eyebrow, 13px); letter-spacing: 0.24em; text-transform: uppercase; color: var(--ih-accent, #560B1E);
  }
  .khan-ihero__eyebrow::before { content: ""; width: 30px; height: 2px; background: var(--ih-accent, #560B1E); }
  .khan-ihero__heading {
    font-family: 'Nexa', var(--font-heading--family, sans-serif); font-weight: 900;
    font-size: min(var(--ih-heading, 88px), 11vw); line-height: 0.94; letter-spacing: -0.01em;
    text-transform: uppercase; color: var(--ih-text, #111);
    margin-bottom: clamp(20px, 2.4vw, 36px);
  }
  .khan-ihero__heading :where(p) { margin: 0; }
  .khan-ihero__heading :where(strong) { color: var(--ih-accent, #560B1E); font-weight: 900; }

  /* usps (optional, legacy) */
  .khan-ihero__usps { display: flex; flex-direction: column; gap: var(--ih-gap, 22px); margin-top: 24px; }
  .khan-ihero__usp { display: flex; align-items: center; gap: clamp(14px, 1.4vw, 22px); }
  .khan-ihero__usp-icon { flex: 0 0 auto; width: var(--ih-icon, 28px); height: var(--ih-icon, 28px); color: var(--ih-accent, #560B1E); display: inline-flex; align-items: center; justify-content: center; }
  .khan-ihero__usp-icon img { width: 100%; height: 100%; object-fit: contain; display: block; }
  .khan-ihero__usp-asterisk { width: 100%; height: 100%; background: currentColor; -webkit-mask: var(--ih-aster) center / contain no-repeat; mask: var(--ih-aster) center / contain no-repeat; }
  .khan-ihero__usp-title { margin: 0 0 4px; font-family: ui-monospace, monospace; font-weight: 700; font-size: var(--ih-title, 14px); letter-spacing: 0.14em; text-transform: uppercase; color: var(--ih-accent, #560B1E); }
  .khan-ihero__usp-text { margin: 0; font-family: ui-monospace, monospace; font-size: var(--ih-utext, 13px); line-height: 1.5; letter-spacing: 0.03em; color: var(--ih-text, #111); }

  /* ============ supplement-facts glass panel ============ */
  .khan-ihero__facts { --o: 0; position: relative; }
  .khan-ihero__facts-card {
    position: relative;
    color: #f1f1f1;
    background: rgb(12 12 12 / var(--ih-facts-op, 0.55));
    border: 1px solid rgb(255 255 255 / 0.10);
    border-radius: 22px;
    box-shadow: 0 24px 70px rgb(0 0 0 / 0.45);
    -webkit-backdrop-filter: blur(var(--ih-facts-blur, 16px));
            backdrop-filter: blur(var(--ih-facts-blur, 16px));
    overflow: hidden;
  }
  .khan-ihero__facts-card::before {
    content: ""; position: absolute; inset: 0; pointer-events: none; z-index: 0;
    background: linear-gradient(180deg, rgb(255 255 255 / 0.06) 0%, rgb(255 255 255 / 0) 24%);
  }
  .khan-ihero__facts-scroll { position: relative; z-index: 1; padding: clamp(22px, 2.4vw, 34px); }
  .khan-ihero__facts-title {
    margin: 0 0 18px;
    font-family: 'Nexa', var(--font-heading--family, sans-serif); font-weight: 900;
    font-size: clamp(22px, 2vw, 30px); letter-spacing: 0.02em; text-transform: uppercase; color: #fff;
  }
  .khan-ihero__facts-table { width: 100%; border-collapse: collapse; font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace; }
  .khan-ihero__facts-table th, .khan-ihero__facts-table td {
    text-align: left; padding: 9px 10px; font-size: clamp(12px, 1vw, 14px); letter-spacing: 0.02em;
    border-bottom: 1px solid rgb(255 255 255 / 0.12);
  }
  .khan-ihero__facts-table thead th { color: var(--ih-accent, #560B1E); font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; border-bottom-color: rgb(255 255 255 / 0.28); }
  .khan-ihero__facts-table td { text-align: right; color: #e9e9e9; white-space: nowrap; }
  .khan-ihero__facts-table tbody th { color: #fff; font-weight: 500; }
  .khan-ihero__facts-table tbody tr:last-child th, .khan-ihero__facts-table tbody tr:last-child td { border-bottom: 0; }
  .khan-ihero__facts-desc { margin-top: 18px; font-family: ui-monospace, monospace; font-size: clamp(12px, 0.95vw, 13.5px); line-height: 1.7; letter-spacing: 0.02em; color: var(--ih-muted, #b3b3b3); }
  .khan-ihero__facts-desc :where(p) { margin: 0 0 10px; }
  .khan-ihero__facts-desc :where(p):last-child { margin-bottom: 0; }

  /* vertical LEGACY label (desktop) */
  .khan-ihero__facts-legacy {
    position: absolute; left: -0.42em; top: 50%; z-index: 2;
    transform: translate(-100%, -50%);
    writing-mode: vertical-rl;
    font-family: 'Nexa', var(--font-heading--family, sans-serif); font-weight: 900;
    font-size: clamp(40px, 5vw, 84px); letter-spacing: 0.06em; text-transform: uppercase;
    color: rgb(20 20 20 / 0.9); pointer-events: none; line-height: 1;
  }

  /* mobile handle + tab + scrim are desktop-hidden */
  .khan-ihero__facts-handle { display: none; }
  .khan-ihero__facts-tab { display: none; }
  .khan-ihero__scrim { display: none; }

  /* ---------- desktop: pin + slide-in from the right ---------- */
  @media screen and (min-width: 750px) {
    .khan-ihero__facts {
      flex: 0 0 auto;
      width: var(--ih-factsw, 480px); max-width: 42vw;
      position: sticky; top: var(--ih-facts-top, 120px); align-self: flex-start;
      transform: translateX(115%); opacity: 0;
      transition: transform 0.6s cubic-bezier(0.22, 0.61, 0.36, 1), opacity 0.5s ease;
    }
    .khan-ihero.is-in .khan-ihero__facts { transform: translateX(0); opacity: 1; }
  }

  /* ---------- mobile: finger-following RIGHT-side drawer ---------- */
  @media screen and (max-width: 749px) {
    .khan-ihero__inner { flex-direction: column; align-items: center; gap: 28px; }
    .khan-ihero__jar-img { width: min(82vw, 420px); }
    .khan-ihero__heading { font-size: min(var(--ih-heading, 88px), 15vw); }

    /* full-screen panel that slides in from the right */
    .khan-ihero__facts {
      position: fixed; inset: 0; z-index: 60;
      width: 100vw; height: 100svh;
      display: flex; flex-direction: row;
      transform: translateX(calc((1 - var(--o, 0)) * 100%));
      transition: transform 0.42s cubic-bezier(0.4, 0, 0.2, 1);
      will-change: transform;
    }
    .khan-ihero__facts-legacy { display: none; }

    /* small bubble on the RIGHT edge — drag left / tap to open */
    .khan-ihero__facts-tab {
      display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 10px;
      position: fixed; right: 0; top: 0; z-index: 58; /* top is set by JS to stay within the section */
      width: 46px; min-height: 120px; padding: 16px 0; margin: 0;
      background: var(--ih-tab-bg, rgb(12 12 12 / 0.92));
      -webkit-backdrop-filter: blur(var(--ih-facts-blur, 16px)); backdrop-filter: blur(var(--ih-facts-blur, 16px));
      border: 1px solid rgb(255 255 255 / 0.12); border-right: 0; border-radius: 16px 0 0 16px;
      box-shadow: -10px 0 30px rgb(0 0 0 / 0.35);
      color: #ffffff; cursor: grab; touch-action: none;
      transition: opacity 0.3s ease;
    }
    .khan-ihero__facts-tab:active { cursor: grabbing; }
    .khan-ihero__facts-tab-arrow { width: 10px; height: 10px; border-top: 2px solid currentColor; border-left: 2px solid currentColor; transform: rotate(-45deg); margin-left: 4px; }
    .khan-ihero__facts-tab-label { writing-mode: vertical-rl; transform: rotate(180deg); font-family: ui-monospace, "SFMono-Regular", Menlo, monospace; font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: #ffffff; }

    /* close grip on the panel's LEFT edge — drag right / tap to close */
    .khan-ihero__facts-handle {
      display: flex; align-items: center; justify-content: center;
      position: absolute; left: 0; top: 0; bottom: 0; z-index: 2;
      width: 30px; padding: 0; margin: 0; border: 0; background: transparent;
      color: rgb(255 255 255 / 0.7); cursor: grab; touch-action: none;
    }
    .khan-ihero__facts-handle:active { cursor: grabbing; }
    .khan-ihero__facts-grip { width: 4px; height: 42px; border-radius: 999px; background: rgb(255 255 255 / 0.4); }
    .khan-ihero__facts-handle-label, .khan-ihero__facts-chevron { display: none; }

    .khan-ihero__facts-card {
      flex: 1 1 auto; min-width: 0; height: 100%;
      border-radius: 0; border: 0; box-shadow: none;
      background: rgb(12 12 12 / 0.97);
      display: flex; flex-direction: column;
    }
    .khan-ihero__facts-scroll { overflow-y: auto; -webkit-overflow-scrolling: touch; height: 100%; padding-left: 30px; padding-bottom: 40px; }

    .khan-ihero__scrim {
      display: block; position: fixed; inset: 0; z-index: 59;
      background: #000; opacity: 0; pointer-events: none;
      transition: opacity 0.42s ease;
    }
  }

  /* hide the sticky add-to-cart while the facts sheet is open (independent of the cart's own logic) */
  body.khan-ifacts-open [data-khan-scart] { opacity: 0 !important; transform: translateY(160%) !important; pointer-events: none !important; transition: opacity 0.3s ease, transform 0.3s ease; }
  body.khan-ifacts-locked { overflow: hidden; }

  @media (prefers-reduced-motion: reduce) {
    .khan-ihero__facts { transition: none !important; }
    .khan-ihero__scrim { transition: none !important; }
  }

  /* legacy small-screen corner sizing */
  @media screen and (max-width: 600px) {
    .khan-ihero__corner { font-size: 11px; letter-spacing: 0.14em; }
  }
{% endstylesheet %}

