{% liquid
  assign model = section.settings.rocks_model | default: 'khan-rocks.glb'
%}

<div
  id="Khan3D-{{ section.id }}"
  class="khan3d color-{{ section.settings.color_scheme }}{% if section.settings.enable_shadow %} khan3d--shadow{% endif %}"
  style="
    --khan3d-pin: {{ section.settings.scroll_length }};
    --khan3d-accent: {{ section.settings.accent_color }};
    --rocks-ast-size: {{ section.settings.asterisk_size }}px;
    --rocks-ast-gap: {{ section.settings.asterisk_gap }}px;
    --rocks-ast-inset: {{ section.settings.asterisk_inset }}px;
    --khan3d-heading-size: {{ section.settings.heading_size }}px;
    --khan3d-text-size: {{ section.settings.text_size }}px;
    --khan3d-align: {{ section.settings.content_position }};
  "
  data-khan3d
>
  <div class="khan3d__sticky">
    {%- comment -%} Poster: shown on reduced-motion / no-WebGL; hidden once the scene runs. {%- endcomment -%}
    {%- if section.settings.poster != blank -%}
      {{
        section.settings.poster
        | image_url: width: 2560
        | image_tag:
          class: 'khan3d__poster',
          alt: '',
          widths: '800, 1200, 1600, 1920, 2560',
          height: section.settings.poster.height,
          width: section.settings.poster.width,
          sizes: '100vw',
          loading: 'eager'
      }}
    {%- else -%}
      <div class="khan3d__poster khan3d__poster--placeholder"></div>
    {%- endif -%}

    {%- if section.settings.enable_3d -%}
      <canvas
        class="khan3d__canvas"
        data-khan-hero3d
        data-model="{{ model | asset_url }}"
        data-ember="{{ 'khan-ember.png' | asset_url }}"
        data-particles="{{ section.settings.particle_count }}"
        aria-hidden="true"
      ></canvas>
    {%- endif -%}

    {%- if section.settings.toggle_overlay -%}
      {% render 'overlay', settings: section.settings, layer: 'var(--layer-flat)' %}
    {%- endif -%}

    {%- if section.settings.heading != blank or section.settings.text != blank -%}
      <div
        class="
          khan3d__content
          khan3d__content--{{ section.settings.content_position }}
          {% if section.settings.use_nexa %}khan3d__content--nexa{% endif %}
        "
      >
        {%- if section.settings.heading != blank -%}
          <div class="khan3d__heading">{{ section.settings.heading }}</div>
        {%- endif -%}
        {%- if section.settings.text != blank -%}
          <div class="khan3d__text">{{ section.settings.text }}</div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.settings.show_asterisks -%}
      <div class="khan3d__asterisks">
        {%- for i in (1..section.settings.asterisk_count) -%}
          <img class="khan3d__asterisk" src="{{ 'asterisk.png' | asset_url }}" alt="" loading="lazy" width="258" height="320">
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

{%- comment -%} Libs injected dynamically (no static <script src> → avoids AssetSizeJavaScript and loads only when the scene actually runs). {%- endcomment -%}
<script>
  (function () {
    var id = 'Khan3D-{{ section.id }}';
    var THREE_URL = {{ 'khan-three.min.js' | asset_url | json }};
    var HERO_URL = {{ 'khan-hero3d.js' | asset_url | json }};
    function load(src, cb) {
      var s = document.createElement('script'); s.src = src; s.async = true;
      s.onload = cb; s.onerror = cb; document.head.appendChild(s);
    }
    function boot() {
      var root = document.getElementById(id);
      if (!root || root.__khan3d) return;
      var canvas = root.querySelector('canvas[data-khan-hero3d]');
      if (!canvas || !window.KHANHero3D || !window.THREE) return; // poster holds
      var ctrl = window.KHANHero3D.init(canvas, {
        modelUrl: canvas.getAttribute('data-model'),
        emberSprite: canvas.getAttribute('data-ember'),
        particleCount: parseInt(canvas.getAttribute('data-particles') || '6000', 10)
      });
      if (!ctrl) return;
      root.__khan3d = ctrl;
      root.classList.add('khan3d--webgl');
      var sticky = root.querySelector('.khan3d__sticky');
      function progress() {
        var total = root.offsetHeight - window.innerHeight;
        var top = root.getBoundingClientRect().top;
        return total > 0 ? Math.max(0, Math.min(1, -top / total)) : 0;
      }
      var ticking = false;
      function onScroll() {
        if (ticking) return; ticking = true;
        window.requestAnimationFrame(function () { ctrl.setProgress(progress()); ticking = false; });
      }
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll);
      if ('IntersectionObserver' in window && sticky) {
        new IntersectionObserver(function (es) {
          es.forEach(function (e) { e.isIntersecting ? ctrl.play() : ctrl.pause(); });
        }, { threshold: 0 }).observe(sticky);
      }
      ctrl.setProgress(progress());
    }
    function start() {
      var root = document.getElementById(id);
      if (!root || root.__khan3d) return;
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return; // poster holds
      if (!root.querySelector('canvas[data-khan-hero3d]')) return; // 3D disabled in settings
      if (window.THREE && window.KHANHero3D) { boot(); return; }
      load(THREE_URL, function () { load(HERO_URL, boot); });
    }
    if (document.readyState !== 'loading') start();
    else document.addEventListener('DOMContentLoaded', start);
    document.addEventListener('shopify:section:load', function () { start(); });
  })();
</script>

{% stylesheet %}
  .khan3d {
    position: relative;
    background-color: #000;
    /* Pinned scroll distance: e.g. 260 -> the sticky stage is held for 260svh. */
    min-height: calc(var(--khan3d-pin, 260) * 1svh);
  }

  .khan3d__sticky {
    position: sticky;
    top: 0;
    height: 100svh;
    overflow: hidden;
    display: grid;
    place-items: center;
  }

  .khan3d__canvas,
  .khan3d__poster {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .khan3d__canvas {
    display: block;
    z-index: var(--layer-base, 0);
  }

  .khan3d__poster {
    object-fit: cover;
    object-position: center center;
    z-index: var(--layer-base, 0);
    transition: opacity 0.4s ease;
  }

  .khan3d__poster--placeholder {
    background: radial-gradient(120% 90% at 50% 0%, #1b1517 0%, #000 62%);
  }

  /* Once the scene is live, fade the poster out. */
  .khan3d--webgl .khan3d__poster {
    opacity: 0;
  }

  /* ---- overlay content ---- */
  .khan3d__content {
    position: absolute;
    z-index: var(--layer-heightened, 4);
    max-width: min(92%, 780px);
    padding: clamp(20px, 5vw, 64px);
    display: flex;
    flex-direction: column;
    pointer-events: none;
    text-transform: uppercase;
  }

  .khan3d__content--nexa {
    font-family: 'Nexa', var(--font-body--family, sans-serif);
  }

  .khan3d__content--top-left { inset: 0 auto auto 0; align-items: flex-start; text-align: left; }
  .khan3d__content--top-right { inset: 0 0 auto auto; align-items: flex-end; text-align: right; }
  .khan3d__content--center-left { inset: 50% auto auto 0; transform: translateY(-50%); align-items: flex-start; text-align: left; }
  .khan3d__content--center { inset: 50% auto auto 50%; transform: translate(-50%, -50%); align-items: center; text-align: center; }
  .khan3d__content--bottom-left { inset: auto auto 0 0; align-items: flex-start; text-align: left; }
  .khan3d__content--bottom-right { inset: auto 0 0 auto; align-items: flex-end; text-align: right; }

  .khan3d__heading {
    margin: 0;
    font-weight: 900;
    font-size: var(--khan3d-heading-size, 80px);
    line-height: 0.95;
    color: #fff;
  }

  .khan3d__text {
    margin: 0.6em 0 0;
    font-weight: 100;
    font-size: var(--khan3d-text-size, 20px);
    line-height: 1.3;
    letter-spacing: 0.04em;
    color: #fff;
  }

  .khan3d__heading :is(strong, b),
  .khan3d__text :is(strong, b) {
    color: var(--khan3d-accent, #d8232a);
    font-weight: inherit;
  }

  .khan3d__heading p,
  .khan3d__text p { margin: 0; }

  .khan3d--shadow .khan3d__heading,
  .khan3d--shadow .khan3d__text {
    text-shadow: 0 2px 14px rgba(0, 0, 0, 0.55), 0 1px 3px rgba(0, 0, 0, 0.7);
  }

  /* ---- asterisks, bottom-right ---- */
  .khan3d__asterisks {
    position: absolute;
    z-index: var(--layer-heightened, 4);
    inset: auto var(--rocks-ast-inset, 32px) var(--rocks-ast-inset, 32px) auto;
    display: flex;
    align-items: center;
    gap: var(--rocks-ast-gap, 16px);
    pointer-events: none;
  }

  .khan3d__asterisk {
    display: block;
    width: var(--rocks-ast-size, 44px);
    height: auto;
    flex: 0 0 auto;
  }

  @media screen and (max-width: 749px) {
    .khan3d__heading { font-size: calc(var(--khan3d-heading-size, 80px) * 0.5); }
    .khan3d__text { font-size: calc(var(--khan3d-text-size, 20px) * 0.85); }
    .khan3d__asterisk { width: calc(var(--rocks-ast-size, 44px) * 0.7); }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Rocks 3D hero",
  "tag": "section",
  "class": "khan3d-wrapper section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "3D scene"
    },
    {
      "type": "paragraph",
      "content": "8 floating rocks + ember/smoke particles, driven by scroll while the section is pinned. Loads three.js only where this section is used. Falls back to the poster on reduced-motion or unsupported devices."
    },
    {
      "type": "checkbox",
      "id": "enable_3d",
      "label": "Enable 3D scene",
      "default": true
    },
    {
      "type": "text",
      "id": "rocks_model",
      "label": "Rock model asset filename",
      "default": "khan-rocks.glb"
    },
    {
      "type": "range",
      "id": "scroll_length",
      "label": "Pinned scroll length",
      "min": 120,
      "max": 400,
      "step": 10,
      "unit": "%",
      "default": 260
    },
    {
      "type": "range",
      "id": "particle_count",
      "label": "Particle count (desktop)",
      "min": 0,
      "max": 9000,
      "step": 500,
      "default": 6000,
      "info": "Embers + base smoke. Halved on mobile. 0 = none."
    },
    {
      "type": "image_picker",
      "id": "poster",
      "label": "Poster image (reduced-motion / fallback)"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "paragraph",
      "content": "Bold text becomes the red accent. All text shows in capitals. Uses Nexa."
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Paragraph"
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Position",
      "options": [
        { "value": "top-left", "label": "Top left" },
        { "value": "top-right", "label": "Top right" },
        { "value": "center-left", "label": "Center left" },
        { "value": "center", "label": "Center" },
        { "value": "bottom-left", "label": "Bottom left" },
        { "value": "bottom-right", "label": "Bottom right" }
      ],
      "default": "center-left"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent (red) color",
      "default": "#d8232a"
    },
    {
      "type": "checkbox",
      "id": "use_nexa",
      "label": "Use Nexa font",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_shadow",
      "label": "Text shadow",
      "default": true
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 24,
      "max": 160,
      "step": 2,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Paragraph size",
      "min": 12,
      "max": 48,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Asterisks"
    },
    {
      "type": "checkbox",
      "id": "show_asterisks",
      "label": "Show asterisks",
      "default": true
    },
    {
      "type": "range",
      "id": "asterisk_count",
      "label": "Number of asterisks",
      "min": 1,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "asterisk_size",
      "label": "Asterisk size",
      "min": 16,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 44
    },
    {
      "type": "range",
      "id": "asterisk_gap",
      "label": "Gap between asterisks",
      "min": 0,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "asterisk_inset",
      "label": "Distance from corner",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "toggle_overlay",
      "label": "Tint scene",
      "default": false
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Tint color",
      "alpha": true,
      "default": "#00000040",
      "visible_if": "{{ section.settings.toggle_overlay }}"
    },
    {
      "type": "select",
      "id": "overlay_style",
      "label": "Tint style",
      "options": [
        { "value": "solid", "label": "Solid" },
        { "value": "gradient", "label": "Gradient" }
      ],
      "default": "solid",
      "visible_if": "{{ section.settings.toggle_overlay }}"
    },
    {
      "type": "select",
      "id": "gradient_direction",
      "label": "Gradient direction",
      "options": [
        { "value": "to top", "label": "Up" },
        { "value": "to bottom", "label": "Down" }
      ],
      "default": "to top",
      "visible_if": "{{ section.settings.toggle_overlay and section.settings.overlay_style == 'gradient' }}"
    }
  ],
  "presets": [
    {
      "name": "Rocks 3D hero",
      "category": "t:categories.banners"
    }
  ]
}
{% endschema %}
