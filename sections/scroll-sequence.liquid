{% liquid
  assign fc = section.settings.frame_count | plus: 0
  if fc < 2
    assign fc = 144
  endif
  assign digits = section.settings.frame_digits | plus: 0
  if digits < 1
    assign digits = 4
  endif
  assign prefix = section.settings.frame_prefix
  assign ext = section.settings.frame_extension | default: 'webp'
%}

<div
  id="ScrollSeq-{{ section.id }}"
  class="scroll-seq color-{{ section.settings.color_scheme }}"
  style="
    --ss-distance: {{ section.settings.scroll_distance }}px;
    --ss-bg: {{ section.settings.bg_color }};
    --ss-fit: {{ section.settings.fit }};
    --ss-fit-m: {{ section.settings.fit_mobile | default: 'cover' }};
    --ss-anchor-m: {{ section.settings.anchor_mobile | default: 'center' }};
  "
  data-scroll-seq
>
  <div class="scroll-seq__sticky">
    <canvas class="scroll-seq__canvas" aria-hidden="true"></canvas>
    <div class="scroll-seq__loader" data-loader>
      <span class="scroll-seq__loader-num" data-loader-num>0%</span>
    </div>
    {%- if section.settings.show_hint -%}
      <div class="scroll-seq__hint" data-seq-hint aria-hidden="true">
        <span class="scroll-seq__hint-text scroll-seq__hint-text--d">{{ section.settings.hint_text | default: 'Скролни надолу' }}</span>
        <span class="scroll-seq__hint-text scroll-seq__hint-text--m">{{ section.settings.hint_text_mobile | default: 'Скролни нагоре' }}</span>
        <span class="scroll-seq__hint-chevs" aria-hidden="true"><i></i><i></i><i></i></span>
      </div>
    {%- endif -%}
  </div>
</div>

<script>
  window.SCROLLSEQ = window.SCROLLSEQ || {};
  window.SCROLLSEQ["{{ section.id }}"] = [
    {%- for i in (1..fc) -%}
      {%- assign numstr = i | append: '' -%}
      {%- assign pad = digits | minus: numstr.size -%}
      {%- assign fn = prefix -%}
      {%- if pad > 0 -%}{%- for z in (1..pad) -%}{%- assign fn = fn | append: '0' -%}{%- endfor -%}{%- endif -%}
      {%- assign fn = fn | append: numstr | append: '.' | append: ext -%}
      "{{ fn | asset_url }}"{%- unless forloop.last -%},{% endunless %}
    {%- endfor -%}
  ];
  {%- assign mprefix = section.settings.frame_prefix_mobile | strip -%}
  {%- if mprefix != blank -%}
  window.SCROLLSEQ_M = window.SCROLLSEQ_M || {};
  window.SCROLLSEQ_M["{{ section.id }}"] = [
    {%- for i in (1..fc) -%}
      {%- assign numstr = i | append: '' -%}
      {%- assign pad = digits | minus: numstr.size -%}
      {%- assign fn = mprefix -%}
      {%- if pad > 0 -%}{%- for z in (1..pad) -%}{%- assign fn = fn | append: '0' -%}{%- endfor -%}{%- endif -%}
      {%- assign fn = fn | append: numstr | append: '.' | append: ext -%}
      "{{ fn | asset_url }}"{%- unless forloop.last -%},{% endunless %}
    {%- endfor -%}
  ];
  {%- endif -%}
  {%- assign hdprefix = section.settings.frame_prefix_mobile_hd | strip -%}
  {%- if hdprefix != blank -%}
  window.SCROLLSEQ_HD = window.SCROLLSEQ_HD || {};
  window.SCROLLSEQ_HD["{{ section.id }}"] = [
    {%- for i in (1..fc) -%}
      {%- assign numstr = i | append: '' -%}
      {%- assign pad = digits | minus: numstr.size -%}
      {%- assign fn = hdprefix -%}
      {%- if pad > 0 -%}{%- for z in (1..pad) -%}{%- assign fn = fn | append: '0' -%}{%- endfor -%}{%- endif -%}
      {%- assign fn = fn | append: numstr | append: '.' | append: ext -%}
      "{{ fn | asset_url }}"{%- unless forloop.last -%},{% endunless %}
    {%- endfor -%}
  ];
  {%- endif -%}
</script>

<script>
  (function () {
    var id = "{{ section.id }}";
    var root = document.getElementById('ScrollSeq-' + id);
    if (!root) return;
    var frames = (window.SCROLLSEQ || {})[id] || [];
    var mframes = (window.SCROLLSEQ_M || {})[id] || [];
    var hdframes = [];
    if (mframes.length && window.matchMedia('(max-width: 749px)').matches) {
      frames = mframes;
      hdframes = (window.SCROLLSEQ_HD || {})[id] || [];
    }
    if (!frames.length) return;
    var canvas = root.querySelector('.scroll-seq__canvas');
    var sticky = root.querySelector('.scroll-seq__sticky');
    var loader = root.querySelector('[data-loader]');
    var loaderNum = root.querySelector('[data-loader-num]');
    var hint = root.querySelector('[data-seq-hint]');
    function updateHint() {
      if (!hint || !ready) return;
      var p = frames.length > 1 ? target / (frames.length - 1) : 1;
      if (p > 0.03) hint.classList.add('is-off');
      else if (p < 0.01) hint.classList.remove('is-off');
    }
    var ctx = canvas.getContext('2d');
    var fit = (getComputedStyle(root).getPropertyValue('--ss-fit') || 'cover').trim() || 'cover';
    var fitM = (getComputedStyle(root).getPropertyValue('--ss-fit-m') || 'cover').trim() || 'cover';
    var anchorM = (getComputedStyle(root).getPropertyValue('--ss-anchor-m') || 'center').trim() || 'center';
    var mqMobile = window.matchMedia('(max-width: 749px)');

    // Smooth scrub: ease a float frame toward the scroll target every rAF, so
    // a coarse mouse wheel (big jumps) still animates THROUGH the frames instead
    // of skipping. Reduced motion -> snap (still scrolls/scrubs, just no easing).
    var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var EASE = reduced ? 1 : 0.16;

    var imgs = new Array(frames.length);
    var loaded = 0, ready = false, drawn = -1;
    var target = 0, currentF = 0, rafId = 0, visible = true;

    function targetFrame() {
      var total = root.offsetHeight - window.innerHeight;
      var top = root.getBoundingClientRect().top;
      var p = total > 0 ? Math.max(0, Math.min(1, -top / total)) : 0;
      return p * (frames.length - 1);
    }

    var imgsHD = [];
    function paint(idx) {
      var im = (imgsHD[idx] && imgsHD[idx].naturalWidth) ? imgsHD[idx] : imgs[idx];
      if (!im || !im.naturalWidth) return;
      var cw = canvas.clientWidth, ch = canvas.clientHeight;
      var iw = im.naturalWidth, ih = im.naturalHeight;
      var useFit = mqMobile.matches ? fitM : fit;
      var s = useFit === 'contain' ? Math.min(cw / iw, ch / ih) : Math.max(cw / iw, ch / ih);
      var dw = iw * s, dh = ih * s;
      ctx.clearRect(0, 0, cw, ch);
      var dy = (ch - dh) / 2;
      if (mqMobile.matches) {
        if (anchorM === 'bottom') dy = ch - dh;
        else if (anchorM === 'top') dy = 0;
      }
      ctx.drawImage(im, (cw - dw) / 2, dy, dw, dh);
      drawn = idx;
    }

    function tick() {
      rafId = 0;
      target = targetFrame();
      updateHint();
      var diff = target - currentF;
      if (Math.abs(diff) < 0.01) {            // settled — stop the loop until next scroll
        currentF = target;
        if (Math.round(currentF) !== drawn) paint(Math.round(currentF));
        return;
      }
      currentF += diff * EASE;
      var idx = Math.round(currentF);
      if (idx !== drawn) paint(idx);
      if (visible) rafId = window.requestAnimationFrame(tick);
    }

    function kick() { if (ready && visible && !rafId) rafId = window.requestAnimationFrame(tick); }

    function size() {
      var dpr = Math.min(window.devicePixelRatio || 1, 2);
      var w = sticky.clientWidth || 1, h = sticky.clientHeight || 1;
      canvas.width = w * dpr; canvas.height = h * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      paint(Math.round(currentF));
    }

    // Preload every frame before enabling the scrub.
    for (var i = 0; i < frames.length; i++) {
      (function (idx) {
        var im = new Image();
        im.onload = im.onerror = function () {
          loaded++;
          if (loaderNum) loaderNum.textContent = Math.round(loaded / frames.length * 100) + '%';
          if (loaded >= frames.length) {
            ready = true;
            if (loader) loader.style.display = 'none';
            currentF = target = targetFrame();
            size();
            paint(Math.round(currentF));
            if (hint) { hint.classList.add('is-on'); updateHint(); }
            kick();
            if (hdframes.length) {
              (function streamHD(j) {
                if (j >= hdframes.length) return;
                var hi = new Image();
                hi.onload = function () {
                  imgsHD[j] = hi;
                  if (Math.round(currentF) === j) { drawn = -1; paint(j); }
                  streamHD(j + 1);
                };
                hi.onerror = function () { streamHD(j + 1); };
                hi.src = hdframes[j];
              })(0);
            }
          }
        };
        im.src = frames[idx];
        imgs[idx] = im;
      })(i);
    }

    window.addEventListener('scroll', kick, { passive: true });
    window.addEventListener('resize', function () { size(); kick(); });

    if ('IntersectionObserver' in window) {
      new IntersectionObserver(function (es) {
        es.forEach(function (e) { visible = e.isIntersecting; if (visible) kick(); });
      }, { threshold: 0 }).observe(root);
    }

    size();
    document.addEventListener('shopify:section:load', function (e) {
      if (e.target && e.target.querySelector && e.target.querySelector('#ScrollSeq-' + id)) { size(); kick(); }
    });
  })();
</script>

{% stylesheet %}
  .scroll-seq {
    position: relative;
    height: var(--ss-distance, 6000px);
    background: var(--ss-bg, #000);
  }

  .scroll-seq__sticky {
    position: sticky;
    top: 0;
    height: 100svh;
    overflow: hidden;
    background: var(--ss-bg, #000);
  }

  .scroll-seq__canvas {
    display: block;
    width: 100%;
    height: 100%;
  }

  .scroll-seq__loader {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--ss-bg, #000);
    color: #fff;
    z-index: 2;
  }

  .scroll-seq__loader-num {
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: 14px;
    letter-spacing: 0.2em;
    opacity: 0.85;
  }

  /* ---- scroll hint: dark glass pill, appears after load, hides once scrolling starts ---- */
  .scroll-seq__hint {
    position: absolute;
    left: 50%;
    bottom: clamp(26px, 6vh, 56px);
    transform: translateX(-50%) translateY(8px);
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    padding: 14px 22px;
    border-radius: 999px;
    color: #fff;
    background: rgb(12 12 12 / 0.62);
    border: 1px solid rgb(255 255 255 / 0.14);
    -webkit-backdrop-filter: blur(14px) saturate(160%);
            backdrop-filter: blur(14px) saturate(160%);
    box-shadow: 0 14px 40px rgb(0 0 0 / 0.28), inset 0 1px 0 rgb(255 255 255 / 0.2);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  .scroll-seq__hint.is-on { opacity: 1; transform: translateX(-50%) translateY(0); }
  .scroll-seq__hint.is-on.is-off { opacity: 0; transform: translateX(-50%) translateY(8px); }
  .scroll-seq__hint-text {
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: 12px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .scroll-seq__hint-chevs { display: flex; flex-direction: column; align-items: center; gap: 3px; height: 22px; }
  .scroll-seq__hint-chevs i {
    width: 9px; height: 9px;
    border-right: 2px solid currentColor;
    border-bottom: 2px solid currentColor;
    transform: rotate(45deg);
    opacity: 0.25;
    animation: seq-chev 1.5s ease-in-out infinite;
  }
  .scroll-seq__hint-chevs i:nth-child(2) { animation-delay: 0.2s; margin-top: -5px; }
  .scroll-seq__hint-chevs i:nth-child(3) { animation-delay: 0.4s; margin-top: -5px; }
  @keyframes seq-chev {
    0%, 60%, 100% { opacity: 0.25; transform: rotate(45deg) translate(0, 0); }
    30% { opacity: 1; transform: rotate(45deg) translate(2px, 2px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .scroll-seq__hint { transition: opacity 0.2s ease; }
    .scroll-seq__hint-chevs i { animation: none; opacity: 0.8; }
  }
  .scroll-seq__hint-text--m { display: none; }
  @media screen and (max-width: 749px) {
    .scroll-seq__hint { padding: 12px 18px; bottom: clamp(20px, 5vh, 40px); }
    .scroll-seq__hint-text { font-size: 11px; letter-spacing: 0.2em; }
    .scroll-seq__hint-text--d { display: none; }
    .scroll-seq__hint-text--m { display: block; }
    /* phones: you swipe UP — flip the chevrons to match */
    .scroll-seq__hint-chevs { transform: rotate(180deg); }
  }

{% endstylesheet %}

{% schema %}
{
  "name": "Scroll sequence",
  "tag": "section",
  "class": "scroll-seq-wrapper section-wrapper",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "header", "content": "Frames" },
    { "type": "paragraph", "content": "Frames load from theme assets named <prefix><zero-padded number>.<ext>, e.g. seq-0001.webp … seq-0144.webp. Upload the sequence to assets with matching names." },
    { "type": "text", "id": "frame_prefix", "label": "Filename prefix", "default": "seq-" },
    { "type": "text", "id": "frame_count", "label": "Frame count", "default": "144" },
    { "type": "text", "id": "frame_digits", "label": "Zero-padded digits", "default": "4" },
    { "type": "text", "id": "frame_extension", "label": "File extension", "default": "webp" },
    { "type": "text", "id": "frame_prefix_mobile", "label": "Mobile filename prefix (optional)", "info": "A lighter frame set for phones, same count/digits/extension (e.g. seq2m-). Leave empty to use the main set everywhere." },
    { "type": "text", "id": "frame_prefix_mobile_hd", "label": "Mobile HD prefix (optional)", "info": "High-res portrait set streamed in the background after the fast set loads — frames upgrade to sharp as they arrive (e.g. seq2p-)." },

    { "type": "header", "content": "Scroll hint" },
    { "type": "checkbox", "id": "show_hint", "label": "Show scroll hint", "default": true, "info": "Appears once the frames have loaded; fades away as soon as the visitor scrolls." },
    { "type": "text", "id": "hint_text", "label": "Hint text (desktop)", "default": "Скролни надолу" },
    { "type": "text", "id": "hint_text_mobile", "label": "Hint text (mobile)", "default": "Скролни нагоре" },

    { "type": "header", "content": "Scroll" },
    { "type": "paragraph", "content": "Scroll distance ≈ felt seconds × 1000. 6000px ≈ 6s, ~42px/frame (smooth). Increase = slower, decrease = faster." },
    { "type": "range", "id": "scroll_distance", "label": "Scroll distance", "min": 1000, "max": 9000, "step": 100, "unit": "px", "default": 6000 },

    { "type": "header", "content": "Appearance" },
    {
      "type": "select",
      "id": "fit",
      "label": "Frame fit",
      "options": [
        { "value": "cover", "label": "Cover (fill, may crop)" },
        { "value": "contain", "label": "Contain (no crop)" }
      ],
      "default": "cover"
    },
    {
      "type": "select",
      "id": "fit_mobile",
      "label": "Frame fit — mobile",
      "options": [
        { "value": "contain", "label": "Contain (whole frame visible)" },
        { "value": "cover", "label": "Cover (fill, crops the sides)" }
      ],
      "default": "cover",
      "info": "Cover fills the phone screen (crops the sides); Contain shows the whole frame letterboxed."
    },
    {
      "type": "select",
      "id": "anchor_mobile",
      "label": "Frame position — mobile",
      "options": [
        { "value": "top", "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "bottom", "label": "Bottom" }
      ],
      "default": "center",
      "info": "Where the frame sits on the phone screen when it doesn't fill it."
    },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#000000" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" }
  ],
  "presets": [
    { "name": "Scroll sequence", "category": "t:categories.banners" }
  ]
}
{% endschema %}
