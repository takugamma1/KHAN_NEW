{% liquid
  assign s = section.settings
  if product != blank
    assign tp = product
  elsif s.product_fallback != blank
    assign tp = s.product_fallback
  endif
  if tp != blank
    assign v = tp.selected_or_first_available_variant
  endif
  assign scart_title = s.title | default: tp.title | default: 'Продукт'
  assign scart_disabled = false
  if v == blank or v.available == false
    assign scart_disabled = true
  endif
  if v != blank and v.available == false
    assign scart_btn_label = s.soldout_label
  else
    assign scart_btn_label = s.button_label
  endif

  comment
    Size pills: find the option named "Размер"/"Size"; if the product has a
    single option with multiple variants, use that one.
  endcomment
  assign size_oidx = -1
  if tp != blank and s.show_sizes
    for opt in tp.options_with_values
      assign oname = opt.name | downcase | strip
      if oname == 'размер' or oname == 'size'
        assign size_opt = opt
        assign size_oidx = forloop.index0
      endif
    endfor
    if size_oidx == -1 and tp.options_with_values.size == 1 and tp.variants.size > 1
      assign size_opt = tp.options_with_values[0]
      assign size_oidx = 0
    endif
  endif
%}
{%- capture scart_price -%}
  {%- if v != blank -%}
    <span class="khan-scart__price-amt" data-khan-scart-amt>{{ v.price | money }}</span>
    {%- if s.show_currency -%}<span class="khan-scart__price-cur">{{ cart.currency.iso_code }}</span>{%- endif -%}
  {%- else -%}
    <span class="khan-scart__price-amt">—</span>
  {%- endif -%}
{%- endcapture -%}
{%- capture scart_sub -%}
  {%- if s.servings != blank -%}<span>{{ s.servings }}</span>{%- endif -%}
  {%- if s.servings != blank and s.weight != blank -%}<span class="khan-scart__dot" aria-hidden="true">+</span>{%- endif -%}
  {%- if s.weight != blank -%}<span>{{ s.weight }}</span>{%- endif -%}
{%- endcapture -%}
{%- capture scart_sizes -%}
  {%- if size_oidx > -1 -%}
    <div class="khan-scart__sizes" role="group" aria-label="{{ size_opt.name | escape }}">
      {%- for val in size_opt.values -%}
        {%- assign matchv = blank -%}
        {%- for pvar in tp.variants -%}
          {%- if pvar.options[size_oidx] == val -%}
            {%- if matchv == blank -%}
              {%- assign matchv = pvar -%}
            {%- elsif pvar.available and matchv.available == false -%}
              {%- assign matchv = pvar -%}
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
        {%- if matchv != blank -%}
          <button
            type="button"
            class="khan-scart__size"
            data-khan-scart-size
            data-vid="{{ matchv.id }}"
            data-price="{{ matchv.price | money }}"
            aria-pressed="{% if v != blank and matchv.id == v.id %}true{% else %}false{% endif %}"
            {% if matchv.available == false %}disabled{% endif %}
          >{{ val }}</button>
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- endif -%}
{%- endcapture -%}

<div
  id="KhanSCart-{{ section.id }}"
  class="khan-scart khan-scart--{{ s.position }}"
  data-khan-scart
  style="
    --scart-glass: {{ s.glass_tint }};
    --scart-border: {{ s.border_color }};
    --scart-text: {{ s.text_color }};
    --scart-muted: {{ s.muted_color }};
    --scart-accent: {{ s.accent_color }};
    --scart-btn1: {{ s.button_top }};
    --scart-btn2: {{ s.button_bottom }};
    --scart-btn-text: {{ s.button_text }};
    --scart-blur: {{ s.blur }}px;
    --scart-h: {{ s.bar_height }}px;
    --scart-radius: {{ s.radius }}px;
    --scart-maxw: {{ s.max_width }}px;
    --scart-edge: {{ s.bottom_offset }}px;
    --scart-img: {{ s.img_size }}px;
    --scart-title: {{ s.title_size }}px;
    --scart-sub: {{ s.sub_size }}px;
    --scart-price: {{ s.price_size }}px;
    --scart-btn-size: {{ s.button_size }}px;
    --scart-sheet-h: {{ s.sheet_height }}vh;
  "
>
  <div class="khan-scart__backdrop" data-khan-scart-close aria-hidden="true"></div>

  <div class="khan-scart__inner">

    {%- comment -%} ===== Desktop bar ===== {%- endcomment -%}
    <div class="khan-scart__bar">
      {%- if s.image != blank -%}
        <div class="khan-scart__media">
          <img src="{{ s.image | image_url: width: 200 }}" alt="{{ scart_title | escape }}" width="{{ s.image.width }}" height="{{ s.image.height }}" loading="lazy">
        </div>
      {%- endif -%}
      <div class="khan-scart__info">
        <p class="khan-scart__title">{{ scart_title }}</p>
        {%- if scart_sub != blank -%}<p class="khan-scart__sub">{{ scart_sub }}</p>{%- endif -%}
      </div>
      {%- if scart_sizes != blank -%}
        <span class="khan-scart__div" aria-hidden="true"></span>
        {{ scart_sizes }}
      {%- endif -%}
      <span class="khan-scart__div" aria-hidden="true"></span>
      <div class="khan-scart__price">{{ scart_price }}</div>
      <span class="khan-scart__div" aria-hidden="true"></span>
      <form class="khan-scart__form" data-khan-scart-form action="{{ routes.cart_add_url }}" method="post" enctype="multipart/form-data">
        {%- if v != blank -%}<input type="hidden" name="id" value="{{ v.id }}">{%- endif -%}
        <input type="hidden" name="quantity" value="1">
        <button class="khan-scart__btn" type="submit"{% if scart_disabled %} disabled{% endif %}>
          <span class="khan-scart__btn-label">{{ scart_btn_label }}</span>
          <span class="khan-scart__btn-plus" aria-hidden="true">+</span>
        </button>
      </form>
    </div>

    {%- comment -%} ===== Mobile bottom-sheet ===== {%- endcomment -%}
    <div class="khan-scart__sheet" data-khan-scart-sheet aria-expanded="false">
      <button class="khan-scart__grip" type="button" data-khan-scart-toggle aria-label="{{ scart_title | escape }}"></button>

      <div class="khan-scart__peek" data-khan-scart-toggle>
        <div class="khan-scart__peek-info">
          <p class="khan-scart__title">{{ scart_title }}</p>
          {%- if scart_sub != blank -%}<p class="khan-scart__sub">{{ scart_sub }}</p>{%- endif -%}
        </div>
        <div class="khan-scart__price">{{ scart_price }}</div>
        <span class="khan-scart__chev" aria-hidden="true"></span>
      </div>

      <div class="khan-scart__expand">
        {%- if s.image != blank -%}
          <div class="khan-scart__media khan-scart__media--big">
            <img src="{{ s.image | image_url: width: 480 }}" alt="{{ scart_title | escape }}" width="{{ s.image.width }}" height="{{ s.image.height }}" loading="lazy">
          </div>
        {%- endif -%}
        {%- if scart_sizes != blank -%}{{ scart_sizes }}{%- endif -%}
        <div class="khan-scart__price khan-scart__price--big">{{ scart_price }}</div>
        <form class="khan-scart__form khan-scart__form--m" data-khan-scart-form action="{{ routes.cart_add_url }}" method="post" enctype="multipart/form-data">
          {%- if v != blank -%}<input type="hidden" name="id" value="{{ v.id }}">{%- endif -%}
          <input type="hidden" name="quantity" value="1">
          <button class="khan-scart__btn khan-scart__btn--m" type="submit"{% if scart_disabled %} disabled{% endif %}>
            <span class="khan-scart__btn-label">{{ scart_btn_label }}</span>
            <span class="khan-scart__btn-plus" aria-hidden="true">+</span>
          </button>
        </form>
      </div>
    </div>

  </div>
</div>

{% stylesheet %}
  .khan-scart {
    position: fixed;
    left: 0; right: 0;
    z-index: 55;
    padding-inline: clamp(12px, 3vw, 36px);
    pointer-events: none;
  }
  .khan-scart--bottom { bottom: var(--scart-edge, 20px); }
  .khan-scart--top { top: var(--scart-edge, 20px); }

  .khan-scart__backdrop { display: none; }
  .khan-scart__inner { position: relative; z-index: 1; max-width: var(--scart-maxw, 1100px); margin-inline: auto; }

  /* ===== Desktop bar ===== */
  .khan-scart__bar {
    pointer-events: auto;
    display: flex;
    align-items: center;
    gap: clamp(12px, 1.6vw, 22px);
    min-height: var(--scart-h, 72px);
    padding: 10px clamp(12px, 1.6vw, 18px) 10px 10px;
    border-radius: var(--scart-radius, 40px);
    color: var(--scart-text, #141414);
    background: var(--scart-glass, rgb(255 255 255 / 0.92));
    border: 1px solid var(--scart-border, rgb(0 0 0 / 0.1));
    -webkit-backdrop-filter: blur(var(--scart-blur, 14px));
            backdrop-filter: blur(var(--scart-blur, 14px));
    box-shadow: 0 14px 40px rgb(0 0 0 / 0.16);
  }

  .khan-scart__media {
    flex: 0 0 auto;
    width: var(--scart-img, 56px); height: var(--scart-img, 56px);
    display: flex; align-items: center; justify-content: center;
    background: transparent;
  }
  .khan-scart__media img { width: 100%; height: 100%; object-fit: contain; display: block; }

  .khan-scart__info { flex: 1 1 auto; min-width: 0; }
  .khan-scart__title {
    margin: 0;
    font-family: 'Nexa', var(--font-heading--family, sans-serif); font-weight: 900;
    font-size: var(--scart-title, 20px); letter-spacing: 0.04em; line-height: 1.05;
    text-transform: uppercase; color: var(--scart-text, #141414);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .khan-scart__sub {
    margin: 6px 0 0; display: flex; align-items: center; gap: 8px;
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: var(--scart-sub, 13px); letter-spacing: 0.12em; text-transform: uppercase; color: var(--scart-muted, #6f6f6f);
  }
  .khan-scart__dot { color: var(--scart-accent, #d8232a); }

  /* sizes */
  .khan-scart__sizes { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
  .khan-scart__size {
    min-width: 34px; height: 34px; padding: 0 9px;
    border-radius: 10px;
    border: 1px solid var(--scart-border, rgb(0 0 0 / 0.16));
    background: transparent;
    color: var(--scart-text, #141414);
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: 12px; letter-spacing: 0.06em; text-transform: uppercase;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }
  .khan-scart__size:hover:not([disabled]) { border-color: var(--scart-text, #141414); }
  .khan-scart__size[aria-pressed="true"] {
    background: var(--scart-text, #141414);
    color: var(--scart-glass, #fff);
    border-color: var(--scart-text, #141414);
  }
  .khan-scart__size[disabled] { opacity: 0.35; text-decoration: line-through; cursor: not-allowed; }

  /* divider */
  .khan-scart__div { flex: 0 0 1px; align-self: stretch; margin-block: 14px; background: var(--scart-border, rgb(0 0 0 / 0.12)); }

  /* price */
  .khan-scart__price { flex: 0 0 auto; display: flex; flex-direction: column; align-items: center; line-height: 1.05; }
  .khan-scart__price-amt {
    font-family: 'Nexa', var(--font-heading--family, sans-serif); font-weight: 900;
    font-size: var(--scart-price, 22px); letter-spacing: 0.02em; color: var(--scart-text, #141414);
  }
  .khan-scart__price-cur {
    margin-top: 4px;
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: 12px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--scart-accent, #d8232a);
  }

  /* button */
  .khan-scart__form { flex: 0 0 auto; margin: 0; }
  .khan-scart__btn {
    position: relative;
    display: inline-flex; align-items: center; justify-content: center; gap: 14px;
    min-width: clamp(148px, 12vw, 200px);
    height: calc(var(--scart-h, 72px) - 24px);
    padding: 0 22px;
    border: 0;
    border-radius: 999px;
    cursor: pointer;
    color: var(--scart-btn-text, #fff);
    background: linear-gradient(180deg, var(--scart-btn1, #b3122a), var(--scart-btn2, #b3122a));
    box-shadow: 0 6px 18px rgb(0 0 0 / 0.18);
    transition: transform 0.15s ease, filter 0.15s ease;
  }
  .khan-scart__btn:hover:not([disabled]) { transform: translateY(-1px); filter: brightness(1.08); }
  .khan-scart__btn[disabled] { opacity: 0.55; cursor: not-allowed; }
  .khan-scart__btn-label {
    font-family: 'Nexa', var(--font-heading--family, sans-serif); font-weight: 900;
    font-size: var(--scart-btn-size, 16px); letter-spacing: 0.14em; text-transform: uppercase;
  }
  .khan-scart__btn-plus { font-size: calc(var(--scart-btn-size, 16px) + 6px); line-height: 1; }
  .khan-scart__form.is-added .khan-scart__btn { filter: brightness(1.18); }

  /* ===== Mobile sheet (hidden on desktop) ===== */
  .khan-scart__sheet { display: none; }

  @media screen and (min-width: 750px) {
    .khan-scart__sheet { display: none !important; }
  }

  @media screen and (max-width: 749px) {
    .khan-scart { padding-inline: 0; }
    .khan-scart--bottom, .khan-scart--top { top: auto; bottom: 0; }
    .khan-scart__inner { max-width: none; }

    .khan-scart__bar { display: none; }

    .khan-scart__backdrop {
      display: block;
      position: fixed; inset: 0; z-index: 0;
      background: rgb(0 0 0 / 0.5);
      opacity: 0; pointer-events: none;
      transition: opacity 0.3s ease;
    }
    .khan-scart.is-expanded .khan-scart__backdrop { opacity: 1; pointer-events: auto; }

    .khan-scart__sheet {
      pointer-events: auto;
      display: flex; flex-direction: column;
      width: 100%;
      color: var(--scart-text, #141414);
      background: var(--scart-glass, rgb(255 255 255 / 0.94));
      border-top: 1px solid var(--scart-border, rgb(0 0 0 / 0.1));
      border-radius: 24px 24px 0 0;
      -webkit-backdrop-filter: blur(var(--scart-blur, 14px));
              backdrop-filter: blur(var(--scart-blur, 14px));
      box-shadow: 0 -12px 40px rgb(0 0 0 / 0.25);
      max-height: 118px;
      overflow: hidden;
      transition: max-height 0.42s cubic-bezier(0.4, 0, 0.2, 1);
      touch-action: pan-y;
    }
    .khan-scart.is-expanded .khan-scart__sheet { max-height: var(--scart-sheet-h, 60vh); }

    .khan-scart__grip {
      flex: 0 0 auto;
      width: 42px; height: 5px; padding: 0; border: 0;
      border-radius: 999px; background: var(--scart-muted, #9a9a9a);
      opacity: 0.5;
      margin: 10px auto 2px; cursor: pointer;
    }

    .khan-scart__peek { display: flex; align-items: center; gap: 14px; padding: 6px 18px 16px; cursor: pointer; }
    .khan-scart__peek-info { flex: 1 1 auto; min-width: 0; }
    .khan-scart__peek .khan-scart__title { font-size: 16px; }
    .khan-scart__peek .khan-scart__sub { font-size: 11px; }
    .khan-scart__peek .khan-scart__price { flex: 0 0 auto; flex-direction: row; align-items: baseline; gap: 6px; }
    .khan-scart__peek .khan-scart__price-cur { margin-top: 0; }
    .khan-scart__chev {
      flex: 0 0 auto; width: 0; height: 0;
      border-left: 6px solid transparent; border-right: 6px solid transparent;
      border-bottom: 7px solid var(--scart-muted, #9a9a9a);
      transition: transform 0.3s ease;
    }
    .khan-scart.is-expanded .khan-scart__chev { transform: rotate(180deg); }

    .khan-scart__expand {
      display: flex; flex-direction: column; align-items: center; gap: 16px;
      padding: 8px 22px calc(24px + env(safe-area-inset-bottom, 0px));
    }
    .khan-scart__expand .khan-scart__media { width: 42vw; max-width: 200px; height: auto; aspect-ratio: 1 / 1; }
    .khan-scart__expand .khan-scart__sizes { justify-content: center; }
    .khan-scart__expand .khan-scart__size { min-width: 44px; height: 42px; border-radius: 12px; font-size: 13px; }
    .khan-scart__price--big .khan-scart__price-amt { font-size: clamp(28px, 8vw, 40px); }
    .khan-scart__price--big { flex-direction: row; align-items: baseline; gap: 8px; }
    .khan-scart__price--big .khan-scart__price-cur { margin-top: 0; }
    .khan-scart__form--m { width: 100%; }
    .khan-scart__btn--m { width: 100%; min-width: 0; height: 56px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .khan-scart__btn, .khan-scart__sheet, .khan-scart__chev, .khan-scart__backdrop { transition: none; }
  }
{% endstylesheet %}

<script>
  (function () {
    function each(list, fn) { for (var i = 0; i < list.length; i++) fn(list[i]); }

    function init(root) {
      if (!root || root.__khanSCartReady) return;
      root.__khanSCartReady = true;
      var cleanups = [];

      // --- size pills: sync variant id + price across both forms ---
      each(root.querySelectorAll('[data-khan-scart-size]'), function (pill) {
        function onPick(e) {
          e.preventDefault();
          var vid = pill.getAttribute('data-vid');
          var price = pill.getAttribute('data-price');
          each(root.querySelectorAll('[data-khan-scart-size]'), function (p) {
            p.setAttribute('aria-pressed', p.getAttribute('data-vid') === vid ? 'true' : 'false');
          });
          each(root.querySelectorAll('input[name="id"]'), function (inp) { inp.value = vid; });
          if (price) each(root.querySelectorAll('[data-khan-scart-amt]'), function (el) { el.textContent = price; });
        }
        pill.addEventListener('click', onPick);
        cleanups.push(function () { pill.removeEventListener('click', onPick); });
      });

      // --- add to cart (desktop + mobile forms) ---
      each(root.querySelectorAll('[data-khan-scart-form]'), function (form) {
        function onSubmit(e) {
          if (!window.fetch || !window.FormData) return; // native submit fallback
          e.preventDefault();
          var btn = form.querySelector('button[type="submit"]');
          if (btn && btn.disabled) return;
          if (btn) btn.disabled = true;
          fetch(form.getAttribute('action') + '.js', {
            method: 'POST',
            headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
            body: new FormData(form)
          })
            .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, d: d }; }); })
            .then(function (res) {
              if (btn) btn.disabled = false;
              if (!res.ok) return;
              form.classList.add('is-added');
              setTimeout(function () { form.classList.remove('is-added'); }, 1600);
              document.dispatchEvent(new CustomEvent('khan:cart:refresh'));
            })
            .catch(function () { if (btn) btn.disabled = false; form.submit(); });
        }
        form.addEventListener('submit', onSubmit);
        cleanups.push(function () { form.removeEventListener('submit', onSubmit); });
      });

      // --- expand / collapse sheet ---
      function setExpanded(open) {
        root.classList.toggle('is-expanded', open);
        var sheet = root.querySelector('[data-khan-scart-sheet]');
        if (sheet) sheet.setAttribute('aria-expanded', open ? 'true' : 'false');
      }
      each(root.querySelectorAll('[data-khan-scart-toggle]'), function (t) {
        function onClick(e) {
          if (e.target.closest('[data-khan-scart-size]') || e.target.closest('form')) return;
          e.preventDefault();
          setExpanded(!root.classList.contains('is-expanded'));
        }
        t.addEventListener('click', onClick);
        cleanups.push(function () { t.removeEventListener('click', onClick); });
      });
      each(root.querySelectorAll('[data-khan-scart-close]'), function (c) {
        function onClose() { setExpanded(false); }
        c.addEventListener('click', onClose);
        cleanups.push(function () { c.removeEventListener('click', onClose); });
      });

      // --- swipe up/down on the sheet ---
      var sheet = root.querySelector('[data-khan-scart-sheet]');
      if (sheet) {
        var startY = 0, dy = 0, tracking = false;
        function ts(e) { startY = e.touches[0].clientY; dy = 0; tracking = true; }
        function tm(e) { if (tracking) dy = e.touches[0].clientY - startY; }
        function te() {
          if (!tracking) return;
          tracking = false;
          if (dy < -40) setExpanded(true);
          else if (dy > 40) setExpanded(false);
        }
        sheet.addEventListener('touchstart', ts, { passive: true });
        sheet.addEventListener('touchmove', tm, { passive: true });
        sheet.addEventListener('touchend', te);
        cleanups.push(function () {
          sheet.removeEventListener('touchstart', ts);
          sheet.removeEventListener('touchmove', tm);
          sheet.removeEventListener('touchend', te);
        });
      }

      // --- escape closes ---
      function onKey(e) { if (e.key === 'Escape') setExpanded(false); }
      document.addEventListener('keydown', onKey);
      cleanups.push(function () { document.removeEventListener('keydown', onKey); });

      root.__khanSCartCleanup = function () {
        each(cleanups, function (fn) { fn(); });
        root.__khanSCartReady = false;
        root.__khanSCartCleanup = null;
      };
    }

    function initAll(scope) {
      each((scope || document).querySelectorAll('[data-khan-scart]'), init);
    }
    if (document.readyState !== 'loading') initAll();
    else document.addEventListener('DOMContentLoaded', function () { initAll(); });
    document.addEventListener('shopify:section:load', function (e) { initAll(e.target); });
    document.addEventListener('shopify:section:unload', function (e) {
      var root = e.target.querySelector('[data-khan-scart]');
      if (root && root.__khanSCartCleanup) root.__khanSCartCleanup();
    });
  })();
</script>

{% schema %}
{
  "name": "Sticky add to cart",
  "tag": "section",
  "class": "khan-scart-wrapper",
  "settings": [
    { "type": "header", "content": "Product" },
    { "type": "product", "id": "product_fallback", "label": "Product", "info": "On a product page the current product is used automatically. Set this for preview or other pages." },
    { "type": "image_picker", "id": "image", "label": "Image (upload)", "info": "Shown in the bar instead of the product photo." },
    { "type": "checkbox", "id": "show_sizes", "label": "Show size picker (Размер / Size option)", "default": true },

    { "type": "header", "content": "Text" },
