{% liquid
  assign s = section.settings
  if product != blank
    assign tp = product
  elsif s.product_fallback != blank
    assign tp = s.product_fallback
  endif
  if tp != blank
    assign v = tp.selected_or_first_available_variant
  endif
  assign scart_title = s.title | default: tp.title | default: 'Продукт'
  assign scart_disabled = false
  if v == blank or v.available == false
    assign scart_disabled = true
  endif
  if v != blank and v.available == false
    assign scart_btn_label = s.soldout_label
  else
    assign scart_btn_label = s.button_label
  endif

  comment
    Image: only an uploaded override is shown — by default the bar stays
    image-free (name + variant bubbles + price + button).
  endcomment
  assign scart_img = s.image
  assign scart_dynimg = false
%}
{%- capture scart_price -%}
  {%- if v != blank -%}
    <span class="khan-scart__price-amt" data-khan-scart-amt>{{ v.price | money }}</span>
    {%- if s.show_currency -%}<span class="khan-scart__price-cur">{{ cart.currency.iso_code }}</span>{%- endif -%}
  {%- else -%}
    <span class="khan-scart__price-amt">—</span>
  {%- endif -%}
{%- endcapture -%}
{%- capture scart_fav -%}
  {%- if tp != blank -%}
    {%- liquid
      assign fav_img = scart_img
      if fav_img == blank
        assign fav_img = tp.featured_image
      endif
    -%}
    <button
      class="khan-scart__fav"
      type="button"
      data-khan-fav
      data-handle="{{ tp.handle | escape }}"
      data-title="{{ scart_title | escape }}"
      data-price="{{ v.price | money | strip_html | escape }}"
      data-image="{% if fav_img != blank %}{{ fav_img | image_url: width: 200 }}{% endif %}"
      data-url="{{ tp.url | escape }}"
      aria-pressed="false"
      aria-label="Добави в любими: {{ scart_title | escape }}"
    >
      <svg viewBox="0 0 70 84" aria-hidden="true" focusable="false">
        <path d="M0 0H70V57.12L35 84 0 57.12Z" fill="currentColor"/>
        <path d="M35 30.5l2.42 8.58L46 41.5l-8.58 2.42L35 52.5l-2.42-8.58L24 41.5l8.58-2.42Z" fill="#ffffff" opacity="0.65"/>
      </svg>
    </button>
  {%- endif -%}
{%- endcapture -%}
{%- capture scart_sub -%}
  {%- if s.servings != blank -%}<span>{{ s.servings }}</span>{%- endif -%}
  {%- if s.servings != blank and s.weight != blank -%}<span class="khan-scart__dot" aria-hidden="true">+</span>{%- endif -%}
  {%- if s.weight != blank -%}<span>{{ s.weight }}</span>{%- endif -%}
{%- endcapture -%}
{%- liquid
  assign scart_extra_colors = s.extra_colors | strip
  assign scart_color_done = false
-%}
{%- capture scart_opts -%}
  {%- if s.show_sizes and tp != blank and tp.variants.size > 1 -%}
    {%- for opt in tp.options_with_values -%}
      {%- assign oi = forloop.index0 -%}
      {%- assign oname = opt.name | downcase | strip -%}
      {%- assign is_color = false -%}
      {%- if oname == 'цвят' or oname == 'color' or oname == 'colour' -%}{%- assign is_color = true -%}{%- endif -%}
      <div class="khan-scart__opt{% if is_color %} khan-scart__opt--color{% endif %}">
        <span class="khan-scart__opt-name">{{ opt.name }}</span>
        <div class="khan-scart__opt-vals" role="group" aria-label="{{ opt.name | escape }}">
          {%- for val in opt.values -%}
            <button
              type="button"
              class="khan-scart__optbtn"
              data-khan-scart-opt
              data-oi="{{ oi }}"
              data-val="{{ val | escape }}"
              aria-pressed="{% if v != blank and v.options[oi] == val %}true{% else %}false{% endif %}"
              title="{{ val | escape }}"
            >{{ val }}</button>
          {%- endfor -%}
          {%- comment -%} hardcoded placeholder swatches appended to the real colour group {%- endcomment -%}
          {%- if is_color and scart_extra_colors != blank -%}
            {%- assign scart_color_done = true -%}
            {%- assign scart_faux = scart_extra_colors | split: ',' -%}
            {%- for fc in scart_faux -%}
              {%- assign fparts = fc | split: '|' -%}
              {%- assign flabel = fparts[0] | strip -%}
              {%- assign fhex = fparts[1] | strip -%}
              <button type="button" class="khan-scart__optbtn khan-scart__optbtn--faux" data-khan-scart-faux data-val="{{ flabel | escape }}" aria-pressed="false" title="{{ flabel | escape }}"{% if fhex != blank %} style="--faux-dot: {{ fhex }};"{% endif %}>{% if fhex != blank %}<span class="khan-scart__swatch" aria-hidden="true"></span>{% endif %}{{ flabel }}</button>
            {%- endfor -%}
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  {%- endif -%}
  {%- comment -%} the product has no colour option yet — still show the hardcoded swatches {%- endcomment -%}
  {%- if scart_extra_colors != blank and scart_color_done == false -%}
    <div class="khan-scart__opt khan-scart__opt--color">
      <span class="khan-scart__opt-name">{{ s.extra_colors_label | default: 'Вкус' }}</span>
      <div class="khan-scart__opt-vals" role="group" aria-label="{{ s.extra_colors_label | default: 'Вкус' | escape }}">
        {%- assign scart_faux = scart_extra_colors | split: ',' -%}
        {%- for fc in scart_faux -%}
          {%- assign fparts = fc | split: '|' -%}
          {%- assign flabel = fparts[0] | strip -%}
          {%- assign fhex = fparts[1] | strip -%}
          <button type="button" class="khan-scart__optbtn khan-scart__optbtn--faux" data-khan-scart-faux data-val="{{ flabel | escape }}" aria-pressed="{% if forloop.first %}true{% else %}false{% endif %}" title="{{ flabel | escape }}"{% if fhex != blank %} style="--faux-dot: {{ fhex }};"{% endif %}>{% if fhex != blank %}<span class="khan-scart__swatch" aria-hidden="true"></span>{% endif %}{{ flabel }}</button>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}
{%- endcapture -%}
{%- capture scart_variants_json -%}[{%- if tp != blank -%}{%- for var in tp.variants -%}{"id":{{ var.id }},"o":{{ var.options | json }},"p":{{ var.price | money | json }},"a":{% if var.available %}true{% else %}false{% endif %}{%- if scart_dynimg and var.image != blank -%},"img":{{ var.image | image_url: width: 480 | json }}{%- endif -%}}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}{%- endif -%}]{%- endcapture -%}

{%- comment -%}
  global_mode: this instance lives in the footer group and covers every
  NON-product page — product templates keep their own contextual instance.
{%- endcomment -%}
{%- unless s.global_mode and request.page_type == 'product' -%}
<div
  id="KhanSCart-{{ section.id }}"
  class="khan-scart khan-scart--{{ s.position }}"
  data-khan-scart
  data-stop-at-footer="{% if s.stop_at_footer %}true{% else %}false{% endif %}"
  style="
    --scart-glass: {{ s.glass_tint }};
    --scart-border: {{ s.border_color }};
    --scart-text: {{ s.text_color }};
    --scart-muted: {{ s.muted_color }};
    --scart-accent: {{ s.accent_color }};
    --scart-btn1: {{ s.button_top }};
    --scart-btn2: {{ s.button_bottom }};
    --scart-btn-text: {{ s.button_text }};
    --scart-blur: {{ s.blur }}px;
    --scart-h: {{ s.bar_height }}px;
    --scart-radius: {{ s.radius }}px;
    --scart-maxw: {{ s.max_width }}px;
    --scart-edge: {{ s.bottom_offset }}px;
    --scart-img: {{ s.img_size }}px;
    --scart-title: {{ s.title_size }}px;
    --scart-sub: {{ s.sub_size }}px;
    --scart-price: {{ s.price_size }}px;
    --scart-btn-size: {{ s.button_size }}px;
    --scart-sheet-h: {{ s.sheet_height }}vh;
  "
>
  <div class="khan-scart__backdrop" data-khan-scart-close aria-hidden="true"></div>

  <script type="application/json" data-khan-scart-variants>{{ scart_variants_json }}</script>

  <div class="khan-scart__inner">

    {%- comment -%} ===== Desktop bar ===== {%- endcomment -%}
    <div class="khan-scart__bar">
      {%- if scart_img != blank -%}
        <div class="khan-scart__media">
          <img data-khan-scart-img{% if scart_dynimg %} data-dyn="1"{% endif %} src="{{ scart_img | image_url: width: 200 }}" alt="{{ scart_title | escape }}" width="{{ scart_img.width | default: 200 }}" height="{{ scart_img.height | default: 200 }}" loading="lazy">
        </div>
      {%- endif -%}
      <div class="khan-scart__info">
        <p class="khan-scart__title">{{ scart_title }}{{ scart_fav }}</p>
        {%- if scart_sub != blank -%}<p class="khan-scart__sub">{{ scart_sub }}</p>{%- endif -%}
      </div>
      {%- if scart_opts != blank -%}
        <div class="khan-scart__opts">{{ scart_opts }}</div>
      {%- endif -%}
      <div class="khan-scart__price">{{ scart_price }}</div>
      <form class="khan-scart__form" data-khan-scart-form action="{{ routes.cart_add_url }}" method="post" enctype="multipart/form-data">
        {%- if v != blank -%}<input type="hidden" name="id" value="{{ v.id }}">{%- endif -%}
        <input type="hidden" name="quantity" value="1">
        <button class="khan-scart__btn" type="submit"{% if scart_disabled %} disabled{% endif %}>
          <span class="khan-scart__btn-label">{{ scart_btn_label }}</span>        </button>
      </form>
    </div>

    {%- comment -%} ===== Mobile bottom-sheet ===== {%- endcomment -%}
    <div class="khan-scart__sheet" data-khan-scart-sheet aria-expanded="false">
      <button class="khan-scart__grip" type="button" data-khan-scart-toggle aria-label="{{ scart_title | escape }}"></button>

      <div class="khan-scart__peek" data-khan-scart-toggle>
        {%- if scart_img != blank -%}
          <div class="khan-scart__media khan-scart__media--peek">
            <img data-khan-scart-img{% if scart_dynimg %} data-dyn="1"{% endif %} src="{{ scart_img | image_url: width: 200 }}" alt="{{ scart_title | escape }}" width="{{ scart_img.width | default: 200 }}" height="{{ scart_img.height | default: 200 }}" loading="lazy">
          </div>
        {%- endif -%}
        <div class="khan-scart__peek-info">
          <p class="khan-scart__title">{{ scart_title }}{{ scart_fav }}</p>
          {%- if scart_sub != blank -%}<p class="khan-scart__sub">{{ scart_sub }}</p>{%- endif -%}
        </div>
        {%- if scart_opts != blank -%}<span class="khan-scart__chev" aria-hidden="true"></span>{%- endif -%}
      </div>

      {%- if scart_opts != blank -%}
        <div class="khan-scart__expand">
          <div class="khan-scart__opts khan-scart__opts--m">{{ scart_opts }}</div>
        </div>
      {%- endif -%}

      <div class="khan-scart__action">
        <div class="khan-scart__price khan-scart__price--big">{{ scart_price }}</div>
        <form class="khan-scart__form khan-scart__form--m" data-khan-scart-form action="{{ routes.cart_add_url }}" method="post" enctype="multipart/form-data">
          {%- if v != blank -%}<input type="hidden" name="id" value="{{ v.id }}">{%- endif -%}
          <input type="hidden" name="quantity" value="1">
          <button class="khan-scart__btn khan-scart__btn--m" type="submit"{% if scart_disabled %} disabled{% endif %}>
            <span class="khan-scart__btn-label">{{ scart_btn_label }}</span>
            <span class="khan-scart__btn-plus" aria-hidden="true">+</span>
          </button>
        </form>
      </div>
    </div>

  </div>
</div>
{%- endunless -%}

{% stylesheet %}
  .khan-scart {
    position: fixed;
    left: 0; right: 0;
    z-index: 55;
    padding-inline: clamp(12px, 3vw, 36px);
    pointer-events: none;
  }
  .khan-scart--bottom { bottom: var(--scart-edge, 20px); }
  .khan-scart--top { top: var(--scart-edge, 20px); }

  .khan-scart__backdrop { display: none; }
  .khan-scart__inner {
    position: relative; z-index: 1; max-width: var(--scart-maxw, 1100px); margin-inline: auto;
    /* docked at the footer: rides up exactly as far as the footer has entered the viewport */
    transform: translateY(calc(-1 * var(--scart-push, 0px)));
    will-change: transform;
  }

  /* parked: cart slides out of view once the footer is reached */
  .khan-scart__bar, .khan-scart__sheet { transition: transform 0.3s ease, opacity 0.3s ease, max-height 0.42s cubic-bezier(0.4, 0, 0.2, 1); }
  .khan-scart.is-parked .khan-scart__bar { opacity: 0; transform: translateY(150%); pointer-events: none; }
  .khan-scart.is-parked .khan-scart__sheet { opacity: 0; transform: translateY(100%); pointer-events: none; }
  .khan-scart.is-parked .khan-scart__backdrop { opacity: 0 !important; pointer-events: none !important; }

  /* ===== Desktop bar ===== */
  .khan-scart__bar {
    pointer-events: auto;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    row-gap: 8px;
    gap: clamp(12px, 1.6vw, 22px);
    min-height: var(--scart-h, 72px);
    padding: 10px clamp(12px, 1.6vw, 18px) 10px clamp(20px, 2.2vw, 30px);
    border-radius: var(--scart-radius, 40px);
    color: var(--scart-text, #141414);
    position: relative;
    isolation: isolate;
    /* liquid glass: translucent frosted material (color-mix forces see-through even if the tint is opaque) */
    background: var(--scart-glass, rgb(20 20 20 / 0.55));
    background: color-mix(in srgb, var(--scart-glass, #1a1a1a) 60%, transparent);
    border: 1px solid color-mix(in srgb, var(--scart-text, #ffffff) 16%, transparent);
    -webkit-backdrop-filter: blur(max(var(--scart-blur, 18px), 16px)) saturate(180%);
            backdrop-filter: blur(max(var(--scart-blur, 18px), 16px)) saturate(180%);
    box-shadow:
      0 18px 50px rgb(0 0 0 / 0.32),
      inset 0 1px 0 rgb(255 255 255 / 0.30),
      inset 0 0 0 1px rgb(255 255 255 / 0.04);
  }
  .khan-scart__bar::before {
    content: ""; position: absolute; inset: 0; z-index: -1; pointer-events: none;
    border-radius: inherit;
    background:
      linear-gradient(180deg, rgb(255 255 255 / 0.18) 0%, rgb(255 255 255 / 0) 40%),
      radial-gradient(150% 130% at 6% -25%, rgb(255 255 255 / 0.14), transparent 55%);
  }

  .khan-scart__media {
    flex: 0 0 auto;
    width: var(--scart-img, 56px); height: var(--scart-img, 56px);
    display: flex; align-items: center; justify-content: center;
    background: transparent;
  }
  .khan-scart__media img { width: 100%; height: 100%; object-fit: contain; display: block; }

  .khan-scart__info { flex: 1 1 auto; min-width: 0; }
  .khan-scart__title {
    margin: 0;
    font-family: 'Nexa', var(--font-heading--family, sans-serif); font-weight: 900;
    font-size: var(--scart-title, 20px); letter-spacing: 0.04em; line-height: 1.05;
    text-transform: uppercase; color: var(--scart-text, #141414);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .khan-scart__sub {
    margin: 6px 0 0; display: flex; align-items: center; gap: 8px;
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: var(--scart-sub, 13px); letter-spacing: 0.12em; text-transform: uppercase; color: var(--scart-muted, #6f6f6f);
  }
  .khan-scart__dot { color: var(--scart-accent, #560B1E); }

  /* sizes */
  .khan-scart__sizes { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
  .khan-scart__size {
    min-width: 34px; height: 34px; padding: 0 9px;
    border-radius: 10px;
    border: 1px solid var(--scart-border, rgb(0 0 0 / 0.16));
    background: transparent;
    color: var(--scart-text, #141414);
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: 12px; letter-spacing: 0.06em; text-transform: uppercase;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }
  .khan-scart__size:hover:not([disabled]) { border-color: var(--scart-text, #141414); }
  .khan-scart__size[aria-pressed="true"] {
    background: var(--scart-text, #141414);
    color: var(--scart-glass, #fff);
    border-color: var(--scart-text, #141414);
  }
  .khan-scart__size[disabled] { opacity: 0.35; text-decoration: line-through; cursor: not-allowed; }

  /* favourite badge next to the product name */
  .khan-scart__fav {
    display: inline-flex; align-items: center; justify-content: center;
    vertical-align: middle; margin-left: 8px;
    width: 24px; height: 24px; padding: 4px; border: 0; border-radius: 50%;
    background: transparent; color: var(--scart-muted, #8a8a8a);
    cursor: pointer;
    transition: color 0.25s ease, transform 0.2s ease, background 0.15s ease;
  }
  .khan-scart__fav:hover { background: rgb(255 255 255 / 0.1); }
  .khan-scart__fav svg { height: 100%; width: auto; display: block; margin: 0 auto; }
  .khan-scart__fav.is-fav { color: var(--scart-fav-on, #9A1F33); }
  .khan-scart__fav.is-fav svg { animation: khan-scart-fav-pop 0.35s cubic-bezier(0.34, 1.56, 0.64, 1); }
  @keyframes khan-scart-fav-pop {
    0% { transform: scale(1); }
    45% { transform: scale(1.25); }
    100% { transform: scale(1); }
  }

  /* option groups (color, size, …) */
  .khan-scart__opts { display: flex; align-items: center; gap: clamp(10px, 1.4vw, 18px); flex-wrap: nowrap; min-width: 0; }
  .khan-scart__opt { display: flex; align-items: center; gap: 8px; }
  .khan-scart__opt-name { font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--scart-muted, #6f6f6f); white-space: nowrap; }
  .khan-scart__opt-vals { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
  .khan-scart__optbtn {
    min-width: 34px; height: 34px; padding: 0 12px;
    clip-path: polygon(6px 0, 100% 0, calc(100% - 6px) 100%, 0 100%);
    border: 1px solid var(--scart-border, rgb(0 0 0 / 0.16));
    background: transparent;
    color: var(--scart-text, #141414);
    font-family: 'Nexa', var(--font-heading--family, sans-serif);
    font-weight: 900;
    font-size: 12px; letter-spacing: 0.06em; text-transform: uppercase;
    cursor: pointer; white-space: nowrap;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease, opacity 0.15s ease;
  }
  .khan-scart__opt--color .khan-scart__optbtn { clip-path: none; border-radius: 999px; }
  .khan-scart__optbtn--faux { display: inline-flex; align-items: center; gap: 7px; }
  .khan-scart__swatch {
    flex: 0 0 auto; width: 12px; height: 12px; border-radius: 50%;
    background: var(--faux-dot, #2fae54);
    box-shadow: inset 0 0 0 1px rgb(0 0 0 / 0.28), 0 0 0 1px rgb(255 255 255 / 0.15);
  }
  /* selected flavour highlights in its own colour (keeps the brand's ring/tint language) */
  .khan-scart__optbtn--faux[aria-pressed="true"] {
    background: color-mix(in srgb, var(--faux-dot, #560B1E) 20%, transparent);
    border-color: var(--faux-dot, #560B1E);
    color: var(--scart-text, #141414);
    box-shadow: 0 0 0 1px var(--faux-dot, #560B1E);
  }
  .khan-scart__optbtn--faux[aria-pressed="true"] .khan-scart__swatch {
    box-shadow: inset 0 0 0 1px rgb(0 0 0 / 0.28), 0 0 0 2px rgb(255 255 255 / 0.9);
  }
  .khan-scart__optbtn:hover:not(.is-unavail) { border-color: var(--scart-btn1, #560B1E); }
  .khan-scart__optbtn[aria-pressed="true"] { background: var(--scart-btn1, #560B1E); color: #fff; border-color: var(--scart-btn1, #560B1E); }
  .khan-scart__optbtn.is-unavail { opacity: 0.35; text-decoration: line-through; }

  /* divider */
  .khan-scart__div { flex: 0 0 1px; align-self: stretch; margin-block: 14px; background: var(--scart-border, rgb(0 0 0 / 0.12)); }

  /* price */
  .khan-scart__price { flex: 0 0 auto; display: flex; flex-direction: column; align-items: center; line-height: 1.05; }
  .khan-scart__price-amt {
    font-family: 'Nexa', var(--font-heading--family, sans-serif); font-weight: 900;
    font-size: var(--scart-price, 22px); letter-spacing: 0.02em; color: var(--scart-text, #141414);
  }
  .khan-scart__price-cur {
    margin-top: 4px;
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: 12px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--scart-accent, #560B1E);
  }

  /* button */
  .khan-scart__form { flex: 0 0 auto; margin: 0; }
  .khan-scart__btn {
    position: relative;
    display: inline-flex; align-items: center; justify-content: center; gap: 14px;
    min-width: clamp(148px, 12vw, 200px);
    height: calc(var(--scart-h, 72px) - 24px);
    padding: 0 22px;
    border: 0;
    border-radius: var(--scart-radius, 40px);
    cursor: pointer;
    color: var(--scart-btn-text, #fff);
    background: linear-gradient(180deg, var(--scart-btn1, #560B1E), var(--scart-btn2, #560B1E));
    box-shadow: 0 6px 18px rgb(0 0 0 / 0.18);
    transition: transform 0.15s ease, filter 0.15s ease;
  }
  .khan-scart__btn:hover:not([disabled]) { transform: translateY(-1px); filter: brightness(1.08); }
  .khan-scart__btn[disabled] { opacity: 0.55; cursor: not-allowed; }
  .khan-scart__btn-label {
    font-family: 'Nexa', var(--font-heading--family, sans-serif); font-weight: 900;
    font-size: var(--scart-btn-size, 16px); letter-spacing: 0.14em; text-transform: uppercase;
  }
  .khan-scart__form.is-added .khan-scart__btn { filter: brightness(1.18); }

  /* ===== Mobile sheet (hidden on desktop) ===== */
  .khan-scart__sheet { display: none; }

  @media screen and (min-width: 750px) {
    .khan-scart__sheet { display: none !important; }
    /* one clean row: info flexes and truncates, controls stay put (no orphaned button) */
    .khan-scart__bar { flex-wrap: nowrap; }
    .khan-scart__info { flex: 1 1 auto; min-width: 40px; }
    .khan-scart__opts { flex: 0 1 auto; }
    .khan-scart__price { flex: 0 0 auto; padding-inline: clamp(4px, 1vw, 14px); }
    .khan-scart__form { flex: 0 0 auto; }
  }

  @media screen and (max-width: 749px) {
    .khan-scart { padding-inline: 0; }
    .khan-scart--bottom, .khan-scart--top { top: auto; bottom: 0; }
    .khan-scart__inner { max-width: none; }

    .khan-scart__bar { display: none; }

    .khan-scart__backdrop {
      display: block;
      position: fixed; inset: 0; z-index: 0;
      background: rgb(0 0 0 / 0.5);
      opacity: 0; pointer-events: none;
      transition: opacity 0.3s ease;
    }
    .khan-scart.is-expanded .khan-scart__backdrop { opacity: 1; pointer-events: auto; }

    .khan-scart__sheet {
      pointer-events: auto;
      position: relative;
      isolation: isolate;
      display: flex; flex-direction: column;
      width: 100%;
      color: var(--scart-text, #141414);
      background: var(--scart-glass, rgb(20 20 20 / 0.6));
      background: color-mix(in srgb, var(--scart-glass, #1a1a1a) 70%, transparent);
      border-top: 1px solid color-mix(in srgb, var(--scart-text, #ffffff) 18%, transparent);
      border-radius: 24px 24px 0 0;
      -webkit-backdrop-filter: blur(max(var(--scart-blur, 18px), 18px)) saturate(180%);
              backdrop-filter: blur(max(var(--scart-blur, 18px), 18px)) saturate(180%);
      box-shadow: 0 -16px 50px rgb(0 0 0 / 0.34), inset 0 1px 0 rgb(255 255 255 / 0.22);
      overflow: hidden;
      transition: transform 0.3s ease, opacity 0.3s ease;
      touch-action: pan-y;
    }
    .khan-scart__sheet::before {
      content: ""; position: absolute; left: 0; right: 0; top: 0; height: 140px; z-index: -1; pointer-events: none;
      background: linear-gradient(180deg, rgb(255 255 255 / 0.15) 0%, rgb(255 255 255 / 0) 100%);
    }

    .khan-scart__grip {
      flex: 0 0 auto;
      width: 42px; height: 5px; padding: 0; border: 0;
      border-radius: 999px; background: var(--scart-muted, #9a9a9a);
      opacity: 0.5;
      margin: 10px auto 2px; cursor: pointer;
    }

    .khan-scart__peek { display: flex; align-items: center; gap: 12px; padding: 2px 18px 12px; cursor: pointer; }
    .khan-scart__media--peek { flex: 0 0 auto; width: 44px; height: 44px; display: flex; align-items: center; justify-content: center; }
    .khan-scart__media--peek img { width: 100%; height: 100%; object-fit: contain; display: block; }
    .khan-scart__peek-info { flex: 1 1 auto; min-width: 0; }
    .khan-scart__peek .khan-scart__title { font-size: 16px; }
    .khan-scart__peek .khan-scart__sub { font-size: 11px; margin-top: 4px; }
    .khan-scart__chev {
      flex: 0 0 auto; width: 0; height: 0;
      border-left: 6px solid transparent; border-right: 6px solid transparent;
      border-bottom: 7px solid var(--scart-muted, #9a9a9a);
      transition: transform 0.3s ease;
    }
    .khan-scart.is-expanded .khan-scart__chev { transform: rotate(180deg); }

    /* configuring area — collapses to zero; the add-to-cart lives below in the action row */
    .khan-scart__expand {
      display: flex; flex-direction: column; align-items: stretch; gap: 14px;
      max-height: 0; opacity: 0; overflow: hidden;
      padding: 0 20px;
      transition: max-height 0.42s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.26s ease, padding 0.26s ease;
    }
    .khan-scart.is-expanded .khan-scart__expand {
      max-height: var(--scart-sheet-h, 60vh);
      overflow-y: auto;
      opacity: 1;
      padding: 4px 20px 6px;
    }
    .khan-scart__opts--m { flex-direction: column; align-items: stretch; gap: 14px; width: 100%; }
    .khan-scart__opts--m .khan-scart__opt { flex-direction: column; align-items: flex-start; gap: 8px; }
    .khan-scart__opts--m .khan-scart__opt-name { font-size: 11px; }
    .khan-scart__opts--m .khan-scart__opt-vals { gap: 8px; flex-wrap: wrap; }
    .khan-scart__opts--m .khan-scart__optbtn { min-width: 46px; height: 44px; border-radius: 12px; font-size: 13px; padding: 0 16px; }
    .khan-scart__opts--m .khan-scart__opt--color .khan-scart__optbtn { border-radius: 999px; }

    /* always-visible checkout row: price + add-to-cart (never clipped) */
    .khan-scart__action {
      display: flex; align-items: center; gap: 14px;
      padding: 8px 16px calc(14px + env(safe-area-inset-bottom, 0px));
    }
    .khan-scart__action .khan-scart__price { flex: 0 0 auto; flex-direction: row; align-items: baseline; gap: 6px; }
    .khan-scart__action .khan-scart__price-amt { font-size: 22px; }
    .khan-scart__action .khan-scart__price-cur { margin-top: 0; }
    .khan-scart__form--m { flex: 1 1 auto; width: auto; margin: 0; }
    .khan-scart__btn--m { width: 100%; min-width: 0; height: 54px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .khan-scart__btn, .khan-scart__sheet, .khan-scart__chev, .khan-scart__backdrop { transition: none; }
  }
{% endstylesheet %}

<script>
  (function () {
    function each(list, fn) { for (var i = 0; i < list.length; i++) fn(list[i]); }

    function init(root) {
      if (!root || root.__khanSCartReady) return;
      root.__khanSCartReady = true;
      var cleanups = [];

      // --- multi-option variant picker: resolve the variant from the selected option values ---
      var variants = [];
      var vdata = root.querySelector('[data-khan-scart-variants]');
      if (vdata) { try { variants = JSON.parse(vdata.textContent); } catch (err) { variants = []; } }
      var selected = [];
      each(root.querySelectorAll('[data-khan-scart-opt][aria-pressed="true"]'), function (b) {
        selected[parseInt(b.getAttribute('data-oi'), 10)] = b.getAttribute('data-val');
      });
      function findVariant() {
        for (var i = 0; i < variants.length; i++) {
          var vr = variants[i], ok = true;
          for (var oi = 0; oi < selected.length; oi++) {
            if (selected[oi] != null && vr.o[oi] !== selected[oi]) { ok = false; break; }
          }
          if (ok) return vr;
        }
        return null;
      }
      function updateAvailability() {
        each(root.querySelectorAll('[data-khan-scart-opt]'), function (btn) {
          var oi = parseInt(btn.getAttribute('data-oi'), 10), val = btn.getAttribute('data-val'), any = false;
          for (var i = 0; i < variants.length; i++) {
            var vr = variants[i];
            if (!vr.a || vr.o[oi] !== val) continue;
            var ok = true;
            for (var k = 0; k < selected.length; k++) {
              if (k !== oi && selected[k] != null && vr.o[k] !== selected[k]) { ok = false; break; }
            }
            if (ok) { any = true; break; }
          }
          btn.classList.toggle('is-unavail', !any);
        });
      }
      function applyVariant() {
        var vr = findVariant();
        if (vr) each(root.querySelectorAll('input[name="id"]'), function (inp) { inp.value = vr.id; });
        if (vr && vr.p) each(root.querySelectorAll('[data-khan-scart-amt]'), function (el) { el.innerHTML = vr.p; });
        if (vr && vr.img) each(root.querySelectorAll('[data-khan-scart-img][data-dyn]'), function (img) { img.src = vr.img; });
        var avail = !!(vr && vr.a);
        each(root.querySelectorAll('[data-khan-scart-form] button[type="submit"]'), function (btn) { btn.disabled = !avail; });
        updateAvailability();
      }
      each(root.querySelectorAll('[data-khan-scart-opt]'), function (btn) {
        function onPick(e) {
          e.preventDefault();
          var oi = parseInt(btn.getAttribute('data-oi'), 10), val = btn.getAttribute('data-val');
          selected[oi] = val;
          each(root.querySelectorAll('[data-khan-scart-opt][data-oi="' + oi + '"]'), function (b) {
            b.setAttribute('aria-pressed', b.getAttribute('data-val') === val ? 'true' : 'false');
          });
          // clear any hardcoded placeholder swatch in the same group
          var grp = btn.closest('.khan-scart__opt');
          if (grp) each(grp.querySelectorAll('[data-khan-scart-faux]'), function (f) { f.setAttribute('aria-pressed', 'false'); });
          applyVariant();
        }
        btn.addEventListener('click', onPick);
        cleanups.push(function () { btn.removeEventListener('click', onPick); });
      });
      if (variants.length && selected.length) applyVariant();

      // --- hardcoded placeholder swatches (e.g. a colour with no real variant yet) ---
      // Visual selection only: they don't resolve a variant or change price/availability.
      each(root.querySelectorAll('[data-khan-scart-faux]'), function (btn) {
        function onFaux(e) {
          e.preventDefault();
          var grp = btn.closest('.khan-scart__opt');
          if (grp) each(grp.querySelectorAll('button'), function (b) { b.setAttribute('aria-pressed', 'false'); });
          btn.setAttribute('aria-pressed', 'true');
        }
        btn.addEventListener('click', onFaux);
        cleanups.push(function () { btn.removeEventListener('click', onFaux); });
      });

      // --- add to cart (desktop + mobile forms) ---
      each(root.querySelectorAll('[data-khan-scart-form]'), function (form) {
        function onSubmit(e) {
          if (!window.fetch || !window.FormData) return; // native submit fallback
          e.preventDefault();
          var btn = form.querySelector('button[type="submit"]');
          if (btn && btn.disabled) return;
          if (btn) btn.disabled = true;
          fetch(form.getAttribute('action') + '.js', {
            method: 'POST',
            headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
            body: new FormData(form)
          })
            .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, d: d }; }); })
            .then(function (res) {
              if (btn) btn.disabled = false;
              if (!res.ok) return;
              form.classList.add('is-added');
              setTimeout(function () { form.classList.remove('is-added'); }, 1600);
              document.dispatchEvent(new CustomEvent('khan:cart:refresh'));
            })
            .catch(function () { if (btn) btn.disabled = false; form.submit(); });
        }
        form.addEventListener('submit', onSubmit);
        cleanups.push(function () { form.removeEventListener('submit', onSubmit); });
      });

      // --- expand / collapse sheet ---
      function setExpanded(open) {
        root.classList.toggle('is-expanded', open);
        var sheet = root.querySelector('[data-khan-scart-sheet]');
        if (sheet) sheet.setAttribute('aria-expanded', open ? 'true' : 'false');
      }
      each(root.querySelectorAll('[data-khan-scart-toggle]'), function (t) {
        function onClick(e) {
          if (e.target.closest('[data-khan-scart-opt]') || e.target.closest('[data-khan-fav]') || e.target.closest('form')) return;
          e.preventDefault();
          setExpanded(!root.classList.contains('is-expanded'));
        }
        t.addEventListener('click', onClick);
        cleanups.push(function () { t.removeEventListener('click', onClick); });
      });
      each(root.querySelectorAll('[data-khan-scart-close]'), function (c) {
        function onClose() { setExpanded(false); }
        c.addEventListener('click', onClose);
        cleanups.push(function () { c.removeEventListener('click', onClose); });
      });

      // --- swipe up/down on the sheet ---
      var sheet = root.querySelector('[data-khan-scart-sheet]');
      if (sheet) {
        var startY = 0, dy = 0, tracking = false;
        function ts(e) { startY = e.touches[0].clientY; dy = 0; tracking = true; }
        function tm(e) { if (tracking) dy = e.touches[0].clientY - startY; }
        function te() {
          if (!tracking) return;
          tracking = false;
          if (dy < -40) setExpanded(true);
          else if (dy > 40) setExpanded(false);
        }
        sheet.addEventListener('touchstart', ts, { passive: true });
        sheet.addEventListener('touchmove', tm, { passive: true });
        sheet.addEventListener('touchend', te);
        cleanups.push(function () {
          sheet.removeEventListener('touchstart', ts);
          sheet.removeEventListener('touchmove', tm);
          sheet.removeEventListener('touchend', te);
        });
      }

      // --- escape closes ---
      function onKey(e) { if (e.key === 'Escape') setExpanded(false); }
      document.addEventListener('keydown', onKey);
      cleanups.push(function () { document.removeEventListener('keydown', onKey); });

      // --- dock at the footer: the cart stops at the footer's top edge instead of covering it ---
      // Deterministic scroll math (no observer timing): push = how far the footer has
      // entered the viewport; the cart rides up by exactly that amount.
      var docking = root.getAttribute('data-stop-at-footer') === 'true';
      var parkEls = [];
      function inFixedOverlay(el) {
        for (var n = el; n && n !== document.body; n = n.parentElement) {
          var pos = window.getComputedStyle(n).position;
          if (pos === 'fixed' || pos === 'sticky') return true;
        }
        return false;
      }
      function resolveParkEls() {
        parkEls = [].slice.call(document.querySelectorAll('.khan-pf-wrapper, .khan-footer-wrapper, footer'))
          .filter(function (el) {
            if (!el.getClientRects().length) return false;      // hidden (display:none)
            if (el.closest('[data-khan-scart]')) return false;  // the cart itself
            return !inFixedOverlay(el);                          // e.g. the cart drawer's own <footer>
          });
      }
      var lastPush = -1, lastParked = null;
      function updateDock() {
        if (!docking) return;
        if (!parkEls.length) resolveParkEls();
        var top = Infinity;
        for (var i = 0; i < parkEls.length; i++) {
          var r = parkEls[i].getBoundingClientRect();
          if (r.top < top) top = r.top;
        }
        var push = 0;
        if (top !== Infinity && !root.classList.contains('is-expanded')) {
          push = window.innerHeight - top;
          if (push < 0) push = 0;
        }
        push = Math.round(push);
        // As soon as the footer starts entering the viewport, slide the cart
        // fully out of view (desktop + mobile) instead of covering/riding it.
        if (lastPush !== 0) { lastPush = 0; root.style.setProperty('--scart-push', '0px'); }
        var parked = push > 24;
        if (parked !== lastParked) {
          lastParked = parked;
          root.classList.toggle('is-parked', parked);
          if (parked) setExpanded(false);
        }
      }
      if (docking) {
        resolveParkEls();
        // direct handler (2 cheap rect reads) — an rAF gate can be starved/lost on heavy pages
        window.addEventListener('scroll', updateDock, { passive: true });
        window.addEventListener('resize', updateDock);
        var dockPoll = window.setInterval(updateDock, 500); // safety net if scroll events are missed
        // layout changes without scrolling (e.g. an accordion opening above the footer)
        // fire per-frame during the animation, keeping the cart glued instead of snapping
        var dockRO = null;
        if ('ResizeObserver' in window) {
          dockRO = new ResizeObserver(updateDock);
          dockRO.observe(document.body);
        }
        updateDock();
        cleanups.push(function () {
          window.removeEventListener('scroll', updateDock);
          window.removeEventListener('resize', updateDock);
          window.clearInterval(dockPoll);
          if (dockRO) dockRO.disconnect();
          root.style.removeProperty('--scart-push');
        });
      }
      root.__khanScartRepark = function () { resolveParkEls(); updateDock(); };
      cleanups.push(function () { root.__khanScartRepark = null; });

      root.__khanSCartCleanup = function () {
        each(cleanups, function (fn) { fn(); });
        root.__khanSCartReady = false;
        root.__khanSCartCleanup = null;
      };
    }

    function initAll(scope) {
      each((scope || document).querySelectorAll('[data-khan-scart]'), init);
    }
    if (document.readyState !== 'loading') initAll();
    else document.addEventListener('DOMContentLoaded', function () { initAll(); });
    document.addEventListener('shopify:section:load', function (e) {
      initAll(e.target);
      // a footer (or any section) may have just (re)loaded — re-resolve park targets for every cart
      each(document.querySelectorAll('[data-khan-scart]'), function (r) { if (r.__khanScartRepark) r.__khanScartRepark(); });
    });
    document.addEventListener('shopify:section:unload', function (e) {
      var root = e.target.querySelector('[data-khan-scart]');
      if (root && root.__khanSCartCleanup) root.__khanSCartCleanup();
    });
  })();
</script>

{% schema %}
{
  "name": "Sticky add to cart",
  "tag": "section",
  "class": "khan-scart-wrapper",
  "settings": [
    { "type": "header", "content": "Product" },
    { "type": "product", "id": "product_fallback", "label": "Product", "info": "On a product page the current product is used automatically. Set this for preview or other pages." },
    { "type": "checkbox", "id": "global_mode", "label": "Global bar (hide on product pages)", "default": false, "info": "For the footer-group instance that covers all non-product pages." },
    { "type": "image_picker", "id": "image", "label": "Image (upload)", "info": "Shown in the bar instead of the product photo." },
    { "type": "checkbox", "id": "show_sizes", "label": "Show option pickers (color, size, …)", "default": true },
    { "type": "text", "id": "extra_colors", "label": "Extra colour swatches (hardcoded)", "info": "TEMPORARY placeholder swatches with no real variant yet. Comma-separated; add an optional colour after |, e.g. Зелен|#2fae54, Син|#2b6cb0. They show in the colour picker but don't change price/variant." },
    { "type": "text", "id": "extra_colors_label", "label": "Colour picker label", "default": "Цвят", "info": "Used only when the product has no colour option of its own." },

    { "type": "header", "content": "Text" },
    { "type": "text", "id": "title", "label": "Title", "info": "Leave empty to use the product title." },
    { "type": "text", "id": "servings", "label": "Line 2 — left (e.g. servings / fit)" },
    { "type": "text", "id": "weight", "label": "Line 2 — right (e.g. weight)" },
    { "type": "checkbox", "id": "show_currency", "label": "Show currency code (e.g. EUR)", "default": true },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Добави в количката" },
    { "type": "text", "id": "soldout_label", "label": "Sold-out label", "default": "Изчерпан" },

    { "type": "header", "content": "Position & size" },
    { "type": "select", "id": "position", "label": "Stick to (desktop)", "options": [ { "value": "bottom", "label": "Bottom" }, { "value": "top", "label": "Top" } ], "default": "bottom" },
    { "type": "checkbox", "id": "stop_at_footer", "label": "Stop at the footer (never cover it)", "default": true },
    { "type": "range", "id": "bottom_offset", "label": "Edge offset (desktop)", "min": 0, "max": 60, "step": 2, "unit": "px", "default": 20 },
    { "type": "range", "id": "max_width", "label": "Max width (desktop)", "min": 700, "max": 1500, "step": 20, "unit": "px", "default": 1100 },
    { "type": "range", "id": "bar_height", "label": "Bar height (desktop)", "min": 56, "max": 110, "step": 2, "unit": "px", "default": 72 },
    { "type": "range", "id": "radius", "label": "Corner radius (desktop)", "min": 16, "max": 60, "step": 2, "unit": "px", "default": 40 },
    { "type": "range", "id": "img_size", "label": "Image size (desktop)", "min": 36, "max": 90, "step": 2, "unit": "px", "default": 56 },
    { "type": "range", "id": "sheet_height", "label": "Mobile sheet height", "min": 30, "max": 80, "step": 2, "unit": "%", "default": 60 },

    { "type": "header", "content": "Text sizes" },
    { "type": "range", "id": "title_size", "label": "Title size", "min": 14, "max": 30, "step": 1, "unit": "px", "default": 20 },
    { "type": "range", "id": "sub_size", "label": "Line 2 size", "min": 9, "max": 18, "step": 1, "unit": "px", "default": 13 },
    { "type": "range", "id": "price_size", "label": "Price size", "min": 14, "max": 34, "step": 1, "unit": "px", "default": 22 },
    { "type": "range", "id": "button_size", "label": "Button text size", "min": 12, "max": 22, "step": 1, "unit": "px", "default": 16 },

    { "type": "header", "content": "Colors (white minimal)" },
    { "type": "range", "id": "blur", "label": "Glass blur", "min": 0, "max": 40, "step": 2, "unit": "px", "default": 14 },
    { "type": "color", "id": "glass_tint", "label": "Bar background", "default": "#ffffffeb" },
    { "type": "color", "id": "border_color", "label": "Border / dividers", "default": "#00000019" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#141414" },
    { "type": "color", "id": "muted_color", "label": "Muted text", "default": "#6f6f6f" },
    { "type": "color", "id": "accent_color", "label": "Accent (red)", "default": "#560B1E" },

    { "type": "header", "content": "Button" },
    { "type": "color", "id": "button_top", "label": "Button gradient top", "default": "#560B1E" },
    { "type": "color", "id": "button_bottom", "label": "Button gradient bottom", "default": "#3B0211" },
    { "type": "color", "id": "button_text", "label": "Button text", "default": "#ffffff" }
  ],
  "presets": [
    { "name": "Sticky add to cart" }
  ]
}
{% endschema %}
