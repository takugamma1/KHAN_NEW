{% liquid
  assign s = section.settings
%}

{%- if s.hide_theme_footer -%}<style>footer { display: none !important; }</style>{%- endif -%}

<div
  id="KhanPF-{{ section.id }}"
  class="khan-pf color-{{ s.color_scheme }}{% if s.text_grain %} khan-pf--grain{% endif %}"
  style="
    --pf-bg: {{ s.bg_color }};
    --pf-text: {{ s.text_color }};
    --pf-accent: {{ s.accent_color }};
    --pf-muted: {{ s.muted_color }};
    --pf-overlay: {{ s.overlay_opacity | divided_by: 100.0 }};
    --pf-minh: {{ s.min_height }}px;
    --pf-logo-w: {{ s.logo_width }}px;
    --pf-head-size: {{ s.heading_size }}px;
    --pf-link-size: {{ s.link_size }}px;
    --pf-pt: {{ s.padding_top }}px;
    --pf-pb: {{ s.padding_bottom }}px;
    --pf-grain: url('{{ 'khan-grain.png' | asset_url }}');
  "
>
  {%- comment -%} Full-bleed background video {%- endcomment -%}
  <div class="khan-pf__bg" aria-hidden="true">
    {%- if s.bg_video != blank -%}
      {{ s.bg_video | video_tag: poster: nil, autoplay: true, loop: true, controls: false, muted: true, class: 'khan-pf__bg-el' }}
    {%- elsif s.bg_image != blank -%}
      {{ s.bg_image | image_url: width: 3000 | image_tag: class: 'khan-pf__bg-el', loading: 'lazy', widths: '800, 1200, 1600, 2000, 2600, 3000', sizes: '100vw', alt: '' }}
    {%- endif -%}
    <span class="khan-pf__overlay"></span>
  </div>

  {%- if s.show_deco -%}
    <span class="khan-pf__cross khan-pf__cross--1" aria-hidden="true"></span>
    <span class="khan-pf__cross khan-pf__cross--2" aria-hidden="true"></span>
    {%- if s.coordinates != blank -%}<span class="khan-pf__coords" aria-hidden="true">{{ s.coordinates }}</span>{%- endif -%}
  {%- endif -%}

  <div class="khan-pf__inner">
    <div class="khan-pf__layout">

      <div class="khan-pf__leftgroup">
        <div class="khan-pf__brand">
          {%- if s.logo != blank -%}
            <img class="khan-pf__logo" src="{{ s.logo | image_url: width: 700 }}" alt="{{ shop.name }}" width="{{ s.logo.width }}" height="{{ s.logo.height }}">
          {%- else -%}
            <span class="khan-pf__logo khan-pf__logo--svg">{{ 'white-logo.svg' | inline_asset_content }}</span>
          {%- endif -%}
          {%- if s.tagline != blank -%}<p class="khan-pf__tagline">{{ s.tagline }}</p>{%- endif -%}
        </div>

        <div class="khan-pf__cols">
          {%- for block in section.blocks -%}
            {%- if block.type == 'menu' -%}
              <nav class="khan-pf__col" {{ block.shopify_attributes }}>
                {%- if block.settings.heading != blank -%}<p class="khan-pf__col-head">{{ block.settings.heading }}</p>{%- endif -%}
                {%- if block.settings.menu != blank -%}
                  <ul class="khan-pf__col-list">
                    {%- for link in block.settings.menu.links -%}
                      <li><a class="khan-pf__link" href="{{ link.url }}">{{ link.title }}</a></li>
                    {%- endfor -%}
                  </ul>
                {%- endif -%}
              </nav>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>

      {%- if s.show_newsletter -%}
        <div class="khan-pf__right">
          {%- if s.news_heading != blank -%}<p class="khan-pf__news-head">{{ s.news_heading }}</p>{%- endif -%}
          {%- if s.news_text != blank -%}<p class="khan-pf__news-text">{{ s.news_text }}</p>{%- endif -%}
          {%- form 'customer' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="khan-pf__news-form">
              <input class="khan-pf__news-input" type="email" name="contact[email]" placeholder="{{ s.news_placeholder | default: 'Your email' }}" required>
              <button class="khan-pf__news-btn" type="submit" aria-label="Subscribe">+</button>
            </div>
            {%- if form.posted_successfully? -%}<p class="khan-pf__news-ok">{{ s.news_success | default: "You're in." }}</p>{%- endif -%}
            {%- if form.errors -%}<p class="khan-pf__news-err">{{ form.errors.translated_fields.email }} {{ form.errors.messages.email }}</p>{%- endif -%}
          {%- endform -%}
        </div>
      {%- endif -%}

    </div>

    <div class="khan-pf__legal">
      {%- if s.copyright != blank -%}<span>{{ s.copyright }}</span>{%- endif -%}
      {%- if s.tagline2 != blank -%}<span class="khan-pf__legal-sub">{{ s.tagline2 }}</span>{%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .khan-pf {
    position: relative;
    background: var(--pf-bg, #0a0a0a);
    min-height: var(--pf-minh, 640px);
    padding-block: var(--pf-pt, 56px) var(--pf-pb, 48px);
    padding-inline: clamp(20px, 4vw, 64px);
    overflow: hidden;
    isolation: isolate;
    display: flex;
  }

  .khan-pf__bg { position: absolute; inset: 0; z-index: 0; }
  .khan-pf__bg-el { width: 100%; height: 100%; object-fit: cover; object-position: center; display: block; }
  .khan-pf__overlay {
    position: absolute; inset: 0;
    background:
      linear-gradient(to top, rgb(0 0 0 / 0.92) 0%, rgb(0 0 0 / 0.6) 26%, rgb(0 0 0 / 0.18) 58%, rgb(0 0 0 / 0) 100%),
      rgb(0 0 0 / var(--pf-overlay, 0.35));
  }

  /* inner pinned to the bottom of the video */
  .khan-pf__inner {
    position: relative; z-index: 2;
    width: 100%; max-width: 1920px; margin-inline: auto;
    display: flex; flex-direction: column; justify-content: flex-end;
  }

  .khan-pf__layout {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: clamp(40px, 6vw, 120px);
  }

  .khan-pf__leftgroup { display: flex; gap: clamp(32px, 4vw, 80px); }

  /* ---- brand ---- */
  .khan-pf__brand { display: flex; flex-direction: column; align-items: flex-start; gap: 16px; }
  .khan-pf__logo { width: var(--pf-logo-w, 200px); height: auto; display: block; }
  .khan-pf__logo--svg svg { width: var(--pf-logo-w, 200px); height: auto; display: block; }
  .khan-pf__logo--svg svg path { fill: #fff; }
  .khan-pf__tagline {
    margin: 0; max-width: 16ch;
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: 15px; line-height: 1.4; letter-spacing: 0.1em; text-transform: uppercase; color: var(--pf-text, #f2f2f2);
  }

  /* ---- link columns ---- */
  .khan-pf__cols { display: flex; gap: clamp(28px, 3vw, 64px); }
  .khan-pf__col-head {
    margin: 0 0 16px;
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: var(--pf-head-size, 14px); letter-spacing: 0.18em; text-transform: uppercase; color: var(--pf-accent, #560B1E);
  }
  .khan-pf__col-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 12px; }
  .khan-pf__link {
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: var(--pf-link-size, 14px); letter-spacing: 0.12em; text-transform: uppercase; color: var(--pf-text, #f2f2f2);
    text-decoration: none; transition: color 0.18s ease;
  }
  .khan-pf__link:hover { color: var(--pf-accent, #560B1E); }

  /* ---- newsletter ---- */
  .khan-pf__right { max-width: 360px; flex: 0 0 auto; }
  .khan-pf__news-head { margin: 0 0 12px; font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace; font-size: var(--pf-head-size, 14px); letter-spacing: 0.14em; text-transform: uppercase; color: var(--pf-accent, #560B1E); }
  .khan-pf__news-text { margin: 0 0 20px; font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace; font-size: 13px; line-height: 1.6; letter-spacing: 0.06em; text-transform: uppercase; color: var(--pf-muted, #c9c9c9); }
  .khan-pf__news-form { display: flex; align-items: stretch; border: 1px solid rgb(255 255 255 / 0.4); background: rgb(0 0 0 / 0.25); }
  .khan-pf__news-input { flex: 1 1 auto; min-width: 0; background: transparent; border: 0; padding: 14px 16px; color: #fff; font-family: ui-monospace, monospace; font-size: 13px; letter-spacing: 0.14em; text-transform: uppercase; }
  .khan-pf__news-input::placeholder { color: rgb(255 255 255 / 0.5); }
  .khan-pf__news-input:focus { outline: none; }
  .khan-pf__news-btn { flex: 0 0 auto; width: 52px; background: transparent; border: 0; border-left: 1px solid rgb(255 255 255 / 0.4); color: var(--pf-accent, #560B1E); font-size: 22px; cursor: pointer; transition: background 0.18s ease; }
  .khan-pf__news-btn:hover { background: rgb(255 255 255 / 0.08); }
  .khan-pf__news-ok { margin: 12px 0 0; color: #9fe6a0; font-family: monospace; font-size: 12px; }
  .khan-pf__news-err { margin: 12px 0 0; color: #ff7a7a; font-family: monospace; font-size: 12px; }

  /* ---- legal ---- */
  .khan-pf__legal { display: flex; gap: 40px; margin-top: 44px; padding-top: 22px; border-top: 1px solid rgb(255 255 255 / 0.16); font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace; font-size: 12px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--pf-muted, #9a9a9a); }
  .khan-pf__legal-sub { padding-left: 40px; border-left: 1px solid rgb(255 255 255 / 0.22); }

  /* ---- decorations ---- */
  .khan-pf__cross { position: absolute; z-index: 1; width: 18px; height: 18px; pointer-events: none; }
  .khan-pf__cross::before, .khan-pf__cross::after { content: ""; position: absolute; background: var(--pf-accent, #560B1E); opacity: 0.7; }
  .khan-pf__cross::before { left: 50%; top: 0; bottom: 0; width: 1px; transform: translateX(-50%); }
  .khan-pf__cross::after { top: 50%; left: 0; right: 0; height: 1px; transform: translateY(-50%); }
  .khan-pf__cross--1 { top: 40px; left: 12%; }
  .khan-pf__cross--2 { top: 28%; right: 14%; }
  .khan-pf__coords { position: absolute; z-index: 1; right: 14px; top: 40%; transform: translateY(-50%) rotate(90deg); transform-origin: right center; font-family: ui-monospace, monospace; font-size: 11px; letter-spacing: 0.2em; color: var(--pf-muted, #8a8a8a); white-space: nowrap; }

  /* ---- grain on text ---- */
  .khan-pf--grain :is(.khan-pf__tagline, .khan-pf__col-head, .khan-pf__link, .khan-pf__news-head, .khan-pf__news-text, .khan-pf__legal, .khan-pf__logo) {
    -webkit-mask-image: var(--pf-grain); mask-image: var(--pf-grain);
    -webkit-mask-size: 170px 170px; mask-size: 170px 170px;
  }

  /* ---- responsive ---- */
  @media screen and (max-width: 1100px) {
    .khan-pf__layout { flex-direction: column; align-items: flex-start; gap: 44px; }
    .khan-pf__right { max-width: 420px; }
    .khan-pf__coords { display: none; }
  }
  @media screen and (max-width: 749px) {
    .khan-pf { min-height: 0; }
    .khan-pf__leftgroup { flex-direction: column; gap: 36px; }
    .khan-pf__cols { flex-wrap: wrap; gap: 32px; }
    .khan-pf__legal { flex-direction: column; gap: 8px; }
    .khan-pf__legal-sub { padding-left: 0; border-left: 0; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Product footer (video)",
  "tag": "section",
  "class": "khan-pf-wrapper section-wrapper",
  "disabled_on": { "groups": ["header"] },
  "settings": [
    { "type": "header", "content": "Behavior" },
    { "type": "checkbox", "id": "hide_theme_footer", "label": "Hide theme footer on this page", "default": true },

    { "type": "header", "content": "Background video (full-bleed)" },
    { "type": "video", "id": "bg_video", "label": "Background video (looped)" },
    { "type": "image_picker", "id": "bg_image", "label": "Image fallback / poster" },
    { "type": "range", "id": "overlay_opacity", "label": "Dark overlay", "min": 0, "max": 90, "step": 5, "unit": "%", "default": 35 },
    { "type": "range", "id": "min_height", "label": "Footer height", "min": 360, "max": 900, "step": 20, "unit": "px", "default": 640 },

    { "type": "header", "content": "Logo & tagline" },
    { "type": "image_picker", "id": "logo", "label": "Logo (upload)" },
    { "type": "range", "id": "logo_width", "label": "Logo width", "min": 80, "max": 400, "step": 4, "unit": "px", "default": 200 },
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "Built different. Made to last." },

    { "type": "header", "content": "Newsletter" },
    { "type": "checkbox", "id": "show_newsletter", "label": "Show newsletter", "default": true },
    { "type": "text", "id": "news_heading", "label": "Heading", "default": "Join the Khan society" },
    { "type": "text", "id": "news_text", "label": "Text", "default": "Exclusive drops. Early access. No noise. Just Khan." },
    { "type": "text", "id": "news_placeholder", "label": "Input placeholder", "default": "Your email" },
    { "type": "text", "id": "news_success", "label": "Success message", "default": "You're in." },

    { "type": "header", "content": "Legal (bottom bar)" },
    { "type": "text", "id": "copyright", "label": "Copyright", "default": "© 2026 Khan Apparel. All rights reserved." },
    { "type": "text", "id": "tagline2", "label": "Sub line", "default": "Born from past. Built for now." },

    { "type": "header", "content": "Decoration" },
    { "type": "checkbox", "id": "show_deco", "label": "Show crosshairs & coordinates", "default": false },
    { "type": "text", "id": "coordinates", "label": "Coordinates", "default": "42.6977° N  23.3219° E" },

    { "type": "header", "content": "Style" },
    { "type": "checkbox", "id": "text_grain", "label": "Grain on text", "default": true },
    { "type": "color", "id": "bg_color", "label": "Background fallback", "default": "#0a0a0a" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#f2f2f2" },
    { "type": "color", "id": "muted_color", "label": "Muted text color", "default": "#9a9a9a" },
    { "type": "color", "id": "accent_color", "label": "Accent (red) color", "default": "#560B1E" },
    { "type": "range", "id": "heading_size", "label": "Column heading size", "min": 11, "max": 22, "step": 1, "unit": "px", "default": 14 },
    { "type": "range", "id": "link_size", "label": "Link size", "min": 11, "max": 22, "step": 1, "unit": "px", "default": 14 },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 56 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 48 },

    { "type": "header", "content": "Appearance" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Link column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Navigate" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Product footer (video)",
      "blocks": [
        { "type": "menu", "settings": { "heading": "Navigate" } },
        { "type": "menu", "settings": { "heading": "Info" } },
        { "type": "menu", "settings": { "heading": "Connect" } }
      ]
    }
  ]
}
{% endschema %}
