{% liquid
  assign s = section.settings
%}

<div
  id="KhanPHero-{{ section.id }}"
  class="khan-phero color-{{ s.color_scheme }}"
  style="
    --ph-text: {{ s.text_color }};
    --ph-accent: {{ s.accent_color }};
    --ph-muted: {{ s.muted_color }};
    --ph-bg: {{ s.bg_color }};
    --ph-overlay: {{ s.overlay_opacity | divided_by: 100.0 }};
    --ph-minh: {{ s.min_height }}px;
    --ph-maxw: {{ s.max_width }}px;
    --ph-pad-y: {{ s.padding_y }}px;
    --ph-heading: {{ s.heading_size }}px;
    --ph-eyebrow: {{ s.eyebrow_size }}px;
    --ph-sub: {{ s.sub_size }}px;
    --ph-desc: {{ s.desc_size }}px;
    --ph-corner: {{ s.corner_size }}px;
    --ph-corner-top: {{ s.corner_top | default: 96 }}px;
    --ph-rightw: {{ s.right_width }}px;
  "
>
  <div class="khan-phero__bg" aria-hidden="true">
    {%- if s.bg_image != blank -%}
      {{ s.bg_image | image_url: width: 3200 | image_tag: class: 'khan-phero__bg-img', loading: 'eager', fetchpriority: 'high', widths: '800, 1200, 1600, 2000, 2600, 3200', sizes: '100vw', alt: '' }}
    {%- endif -%}
    <span class="khan-phero__overlay"></span>
  </div>

  {%- if s.top_left != blank -%}
    <span class="khan-phero__corner khan-phero__corner--tl">{{ s.top_left }}</span>
  {%- endif -%}
  {%- if s.top_right != blank -%}
    <span class="khan-phero__corner khan-phero__corner--tr">{{ s.top_right }}</span>
  {%- endif -%}

  <div class="khan-phero__inner">

    <div class="khan-phero__left">
      {%- if s.eyebrow != blank -%}
        <p class="khan-phero__eyebrow">{{ s.eyebrow }}</p>
      {%- endif -%}
      {%- if s.heading != blank -%}
        <div class="khan-phero__heading">{{ s.heading }}</div>
      {%- endif -%}
      {%- if s.subtext != blank -%}
        <div class="khan-phero__sub">{{ s.subtext }}</div>
      {%- endif -%}
    </div>

    <div class="khan-phero__right">
      {%- if s.show_asterisk -%}
        <svg class="khan-phero__star" viewBox="0 0 100 100" aria-hidden="true" focusable="false">
          <g stroke="currentColor" stroke-width="7" stroke-linecap="round">
            <line x1="50" y1="8" x2="50" y2="92"></line>
            <line x1="8" y1="50" x2="92" y2="50"></line>
            <line x1="20" y1="20" x2="80" y2="80"></line>
            <line x1="80" y1="20" x2="20" y2="80"></line>
          </g>
        </svg>
      {%- endif -%}
      {%- if s.right_heading != blank -%}
        <p class="khan-phero__right-head">{{ s.right_heading }}</p>
      {%- endif -%}
      {%- if s.right_text != blank -%}
        <div class="khan-phero__desc">{{ s.right_text }}</div>
      {%- endif -%}
    </div>

  </div>
</div>

{% stylesheet %}
  .khan-phero {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    min-height: var(--ph-minh, 820px);
    background: var(--ph-bg, #050505);
    display: flex;
    align-items: center;
    padding: calc(var(--ph-pad-y, 96px) + 40px) clamp(20px, 5vw, 72px) var(--ph-pad-y, 96px);
  }

  .khan-phero__bg { position: absolute; inset: 0; z-index: 0; }
  .khan-phero__bg-img { width: 100%; height: 100%; object-fit: cover; object-position: center; display: block; }
  .khan-phero__overlay {
    position: absolute; inset: 0;
    background:
      linear-gradient(90deg, rgb(0 0 0 / 0.78) 0%, rgb(0 0 0 / 0.2) 32%, rgb(0 0 0 / 0.2) 68%, rgb(0 0 0 / 0.78) 100%),
      rgb(0 0 0 / var(--ph-overlay, 0.3));
  }

  /* corners */
  .khan-phero__corner {
    position: absolute; z-index: 2; top: var(--ph-corner-top, 96px);
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: var(--ph-corner, 12px); letter-spacing: 0.2em; text-transform: uppercase; color: var(--ph-text, #f3f3f3);
    white-space: nowrap;
  }
  .khan-phero__corner--tl { left: clamp(20px, 5vw, 72px); color: var(--ph-muted, #b9b9b9); }
  .khan-phero__corner--tr { right: clamp(20px, 5vw, 72px); color: var(--ph-accent, #d8232a); }
  .khan-phero__corner--tr::before { content: "[ "; }
  .khan-phero__corner--tr::after { content: " ]"; }

  /* layout */
  .khan-phero__inner {
    position: relative; z-index: 1;
    width: 100%; max-width: var(--ph-maxw, 1680px); margin-inline: auto;
    display: flex; align-items: center; justify-content: space-between; gap: clamp(28px, 6vw, 120px);
  }

  /* left */
  .khan-phero__left { max-width: 50%; }
  .khan-phero__eyebrow {
    margin: 0 0 18px; display: flex; align-items: center; gap: 12px;
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: var(--ph-eyebrow, 13px); letter-spacing: 0.24em; text-transform: uppercase; color: var(--ph-accent, #d8232a);
  }
  .khan-phero__eyebrow::before { content: ""; width: 30px; height: 2px; background: var(--ph-accent, #d8232a); }
  .khan-phero__heading {
    font-family: 'Nexa', var(--font-heading--family, sans-serif); font-weight: 900;
    font-size: min(var(--ph-heading, 104px), 12vw); line-height: 0.94; letter-spacing: -0.01em;
    text-transform: uppercase; color: var(--ph-text, #f3f3f3);
  }
  .khan-phero__heading :where(p) { margin: 0; }
  .khan-phero__heading :where(strong) { color: var(--ph-accent, #d8232a); font-weight: 900; }
  .khan-phero__sub {
    margin-top: clamp(20px, 2.4vw, 32px);
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: var(--ph-sub, 16px); line-height: 1.5; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ph-text, #f3f3f3);
  }
  .khan-phero__sub :where(p) { margin: 0; }
  .khan-phero__sub :where(strong) { color: var(--ph-accent, #d8232a); font-weight: inherit; }

  /* right (description — NOT usps) */
  .khan-phero__right { flex: 0 0 auto; width: var(--ph-rightw, 300px); max-width: 42%; }
  .khan-phero__star { width: 46px; height: 46px; color: var(--ph-accent, #d8232a); display: block; margin: 0 0 22px; }
  .khan-phero__right-head {
    margin: 0 0 14px;
    font-family: 'Nexa', var(--font-heading--family, sans-serif); font-weight: 900;
    font-size: clamp(15px, 1.4vw, 19px); letter-spacing: 0.08em; text-transform: uppercase; color: var(--ph-accent, #d8232a);
  }
  .khan-phero__desc {
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: var(--ph-desc, 14px); line-height: 1.7; letter-spacing: 0.04em; color: var(--ph-muted, #b9b9b9);
  }
  .khan-phero__desc :where(p) { margin: 0 0 12px; }
  .khan-phero__desc :where(p):last-child { margin-bottom: 0; }
  .khan-phero__desc :where(strong) { color: var(--ph-text, #f3f3f3); }

  /* responsive */
  @media screen and (max-width: 900px) {
    .khan-phero { align-items: flex-end; }
    .khan-phero__inner { flex-direction: column; align-items: flex-start; gap: 36px; }
    .khan-phero__left, .khan-phero__right { max-width: 100%; width: 100%; }
    .khan-phero__heading { font-size: min(var(--ph-heading, 104px), 17vw); }
  }
  @media screen and (max-width: 600px) {
    .khan-phero__corner { font-size: 11px; letter-spacing: 0.14em; }
    .khan-phero__star { width: 38px; height: 38px; margin-bottom: 16px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Pre-workout hero",
  "tag": "section",
  "class": "khan-phero-wrapper",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "header", "content": "Background" },
    { "type": "image_picker", "id": "bg_image", "label": "Background image" },
    { "type": "range", "id": "overlay_opacity", "label": "Dark overlay", "min": 0, "max": 90, "step": 5, "unit": "%", "default": 30 },
    { "type": "range", "id": "min_height", "label": "Height", "min": 480, "max": 1000, "step": 20, "unit": "px", "default": 820 },

    { "type": "header", "content": "Corner labels" },
    { "type": "text", "id": "top_left", "label": "Top-left label", "default": "Khan collection" },
    { "type": "text", "id": "top_right", "label": "Top-right tag", "default": "Pre-workout", "info": "Shown inside [ brackets ]." },
    { "type": "range", "id": "corner_top", "label": "Corner labels: distance from top", "min": 16, "max": 200, "step": 4, "unit": "px", "default": 96 },

    { "type": "header", "content": "Left — name & subtext" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Pre-workout" },
    { "type": "richtext", "id": "heading", "label": "Heading / name", "default": "<p>Fuel the<br/><strong>discipline.</strong></p>" },
    { "type": "richtext", "id": "subtext", "label": "Subtext", "default": "<p>Clean energy.<br/>Relentless <strong>performance.</strong></p>" },

    { "type": "header", "content": "Right — description" },
    { "type": "checkbox", "id": "show_asterisk", "label": "Show asterisk mark", "default": true },
    { "type": "text", "id": "right_heading", "label": "Description heading", "default": "The formula" },
    { "type": "richtext", "id": "right_text", "label": "Description", "default": "<p>A precision-dosed pre-workout built for clean, relentless energy — sharp focus, bigger pumps, and zero crash. No fillers, no shortcuts.</p>" },

    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color", "label": "Background fallback", "default": "#050505" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#f3f3f3" },
    { "type": "color", "id": "muted_color", "label": "Muted text", "default": "#b9b9b9" },
    { "type": "color", "id": "accent_color", "label": "Accent (red)", "default": "#d8232a" },

    { "type": "header", "content": "Sizes & spacing" },
    { "type": "range", "id": "heading_size", "label": "Heading size", "min": 48, "max": 160, "step": 2, "unit": "px", "default": 104 },
    { "type": "range", "id": "eyebrow_size", "label": "Eyebrow size", "min": 11, "max": 20, "step": 1, "unit": "px", "default": 13 },
    { "type": "range", "id": "sub_size", "label": "Subtext size", "min": 12, "max": 22, "step": 1, "unit": "px", "default": 16 },
    { "type": "range", "id": "desc_size", "label": "Description size", "min": 11, "max": 20, "step": 1, "unit": "px", "default": 14 },
    { "type": "range", "id": "corner_size", "label": "Corner label size", "min": 10, "max": 18, "step": 1, "unit": "px", "default": 12 },
    { "type": "range", "id": "right_width", "label": "Description width", "min": 220, "max": 460, "step": 10, "unit": "px", "default": 300 },
    { "type": "range", "id": "max_width", "label": "Max width", "min": 1100, "max": 1900, "step": 20, "unit": "px", "default": 1680 },
    { "type": "range", "id": "padding_y", "label": "Vertical padding", "min": 40, "max": 160, "step": 4, "unit": "px", "default": 96 },

    { "type": "header", "content": "Appearance" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" }
  ],
  "presets": [
    { "name": "Pre-workout hero" }
  ]
}
{% endschema %}
